---
import type { Troop } from '../lib/parse-xml';

interface Props {
  troops: Troop[];
  culture: string;
}

const { troops, culture } = Astro.props;

// Build lookup maps
const troopById = new Map<string, Troop>();
for (const t of troops) troopById.set(t.id, t);

// Parent map
const parentMap = new Map<string, string[]>();
for (const t of troops) {
  for (const cid of t.upgradeTo) {
    if (troopById.has(cid)) {
      if (!parentMap.has(cid)) parentMap.set(cid, []);
      parentMap.get(cid)!.push(t.id);
    }
  }
}

// Tier assignment
const TIER_LEVELS = [1, 6, 11, 16, 21, 26, 31, 36, 41, 46];
function getTier(level: number): number {
  for (let i = TIER_LEVELS.length - 1; i >= 0; i--) {
    if (level >= TIER_LEVELS[i]) return i;
  }
  return 0;
}

// Root troops (no parents within this faction)
const rootTroops = troops
  .filter(t => !(parentMap.get(t.id)?.length))
  .sort((a, b) => a.level - b.level || a.name.localeCompare(b.name));

// === Column Layout Algorithm ===
// Each leaf gets its own column. Parents span their children's columns.
// Single-child parents stay in the same column as their child.

interface NodePos {
  troopId: string;
  col: number;
  span: number;
  tier: number;
}

const positions: NodePos[] = [];
let nextCol = 0;
const assigned = new Set<string>();

function layoutSubtree(nodeId: string): { start: number; width: number } {
  if (assigned.has(nodeId)) {
    const p = positions.find(p => p.troopId === nodeId);
    return p ? { start: p.col, width: p.span } : { start: nextCol, width: 0 };
  }
  assigned.add(nodeId);

  const node = troopById.get(nodeId)!;
  const tier = getTier(node.level);
  const unvisitedChildren = node.upgradeTo.filter(id => troopById.has(id) && !assigned.has(id));

  if (unvisitedChildren.length === 0) {
    // Leaf node — gets its own column
    const col = nextCol++;
    positions.push({ troopId: nodeId, col, span: 1, tier });
    return { start: col, width: 1 };
  }

  // Layout children first (bottom-up)
  const childResults = unvisitedChildren.map(cid => layoutSubtree(cid));
  const valid = childResults.filter(r => r.width > 0);

  if (valid.length === 0) {
    const col = nextCol++;
    positions.push({ troopId: nodeId, col, span: 1, tier });
    return { start: col, width: 1 };
  }

  const start = valid[0].start;
  const end = valid[valid.length - 1].start + valid[valid.length - 1].width;
  const span = end - start;

  positions.push({ troopId: nodeId, col: start, span, tier });
  return { start, width: span };
}

for (const root of rootTroops) {
  if (!assigned.has(root.id)) layoutSubtree(root.id);
}

// Pick up orphans
for (const t of troops) {
  if (!assigned.has(t.id)) {
    assigned.add(t.id);
    positions.push({ troopId: t.id, col: nextCol++, span: 1, tier: getTier(t.level) });
  }
}

const totalCols = nextCol;

// === Column Headers ===
// Derive from the first span-1 troop in each column, then merge adjacent same-label headers

function stripBrackets(name: string): string {
  return name.replace(/^\[.*?\]\s*/, '');
}

function deriveBranchLabel(troop: Troop): string {
  const name = stripBrackets(troop.name);
  const generic = new Set(['Recruit', 'Militia', 'Militiaman', 'Levyman', 'Footman', 'Warrior', 'Scout', 'Soldier', 'Peasant']);
  const words = name.split(/\s+/);
  if (words.length >= 2 && !generic.has(words[0])) return words[0];
  return name;
}

const rawColHeaders: string[] = [];
for (let c = 0; c < totalCols; c++) {
  const nodes = positions.filter(p => p.col === c && p.span === 1).sort((a, b) => a.tier - b.tier);
  if (nodes.length > 0) {
    rawColHeaders.push(deriveBranchLabel(troopById.get(nodes[0].troopId)!));
  } else {
    rawColHeaders.push('');
  }
}

// Merge adjacent same-label headers
interface MergedHeader {
  label: string;
  colStart: number;
  colSpan: number;
}
const mergedHeaders: MergedHeader[] = [];
for (let c = 0; c < totalCols; c++) {
  const label = rawColHeaders[c];
  if (mergedHeaders.length > 0 && mergedHeaders[mergedHeaders.length - 1].label === label) {
    mergedHeaders[mergedHeaders.length - 1].colSpan++;
  } else {
    mergedHeaders.push({ label, colStart: c, colSpan: 1 });
  }
}

// Tiers and row mapping
const sortedTiers = [...new Set(positions.map(p => p.tier))].sort((a, b) => a - b);
const tierToRow = new Map(sortedTiers.map((t, i) => [t, i + 2])); // row 1 = header
const totalRows = sortedTiers.length + 1;

// Edges for SVG lines
const edges: { parentId: string; childId: string }[] = [];
for (const t of troops) {
  for (const cid of t.upgradeTo) {
    if (troopById.has(cid)) edges.push({ parentId: t.id, childId: cid });
  }
}

// Color map
const GROUP_COLORS: Record<string, string> = {
  Infantry: '#E08080',
  Cavalry: '#B39DDB',
  Ranged: '#6DBF8A',
  HorseArcher: '#D4C96A',
  General: '#c9a44a',
};
---

<div class="troop-tree-container" data-culture={culture}>
  <div class="tree-legend">
    {Object.entries(GROUP_COLORS).map(([group, color]) => (
      <span class="legend-item">
        <span class="legend-dot" style={`background: ${color}`}></span>
        {group}
      </span>
    ))}
  </div>

  <div class="tree-scroll">
    <svg class="tree-lines" id={`tree-svg-${culture}`}></svg>
    <div class="tree-grid" style={`
      grid-template-columns: 70px repeat(${totalCols}, minmax(130px, 1fr));
      grid-template-rows: repeat(${totalRows}, auto);
    `}>
      {/* Header row — merged column headers */}
      <div class="header-label" style="grid-row: 1; grid-column: 1"></div>
      {mergedHeaders.map(h => (
        <div
          class="branch-header"
          style={`grid-row: 1; grid-column: ${h.colStart + 2} / span ${h.colSpan}`}
        >
          {h.label}
        </div>
      ))}

      {/* Tier labels */}
      {sortedTiers.map(tier => (
        <div class="tier-label" style={`grid-row: ${tierToRow.get(tier)}; grid-column: 1`}>
          <span class="tier-num">T{tier}</span>
          <span class="tier-level">Lv {TIER_LEVELS[tier]}</span>
        </div>
      ))}

      {/* Troop nodes — each placed explicitly in the grid */}
      {positions.map(pos => {
        const troop = troopById.get(pos.troopId)!;
        const color = GROUP_COLORS[troop.defaultGroup] || '#999';
        const row = tierToRow.get(pos.tier)!;
        const childIds = troop.upgradeTo.filter(id => troopById.has(id));
        return (
          <div
            class="tree-cell"
            style={`grid-row: ${row}; grid-column: ${pos.col + 2} / span ${pos.span}`}
          >
            <div
              class="tree-node"
              id={`node-${troop.id}`}
              data-id={troop.id}
              data-children={childIds.join(',')}
              style={`--node-color: ${color}; --node-color-dim: ${color}33`}
            >
              <span class="node-name">{stripBrackets(troop.name)}</span>
              <span class="node-level">Lv {troop.level}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <script type="application/json" class="tree-edges">{JSON.stringify(edges)}</script>
</div>

<style>
  .troop-tree-container {
    position: relative;
    margin: 1rem 0;
    width: 100%;
    min-width: 0;
  }

  .tree-legend {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .tree-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    position: relative;
    padding-bottom: 1rem;
    width: 100%;
    max-width: 100%;
    scrollbar-gutter: stable both-edges;
  }

  .tree-lines {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 1;
  }

  .tree-grid {
    position: relative;
    display: grid;
    width: max-content;
    min-width: 100%;
  }

  .header-label {
    background: var(--bg-secondary);
    border-bottom: 2px solid var(--accent-dim);
  }

  .branch-header {
    padding: 0.5rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    text-align: center;
    border-bottom: 2px solid var(--accent-dim);
    background: var(--bg-secondary);
    white-space: nowrap;
  }

  .tier-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0.5rem;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .tier-num {
    font-weight: 700;
    color: var(--accent);
    font-size: 0.85rem;
  }

  .tier-level {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .tree-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.2rem;
    min-height: 52px;
    border-bottom: 1px solid var(--border-color);
    overflow: hidden;
  }

  .tree-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.25rem 0.4rem;
    background: var(--node-color-dim);
    border: 1px solid var(--node-color);
    border-left: 3px solid var(--node-color);
    border-radius: 4px;
    cursor: default;
    white-space: normal;
    max-width: 100%;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
    position: relative;
    z-index: 2;
  }

  .tree-node:hover {
    transform: scale(1.08);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    z-index: 10;
  }

  .node-name {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
    text-align: center;
    word-break: break-word;
  }

  .node-level {
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  .tree-node.highlighted {
    box-shadow: 0 0 10px var(--node-color);
    transform: scale(1.08);
  }

  .tree-node.dimmed {
    opacity: 0.2;
  }
</style>

<script>
  function drawTreeLines() {
    document.querySelectorAll('.troop-tree-container').forEach(container => {
      const svg = container.querySelector('.tree-lines') as SVGSVGElement;
      const grid = container.querySelector('.tree-grid') as HTMLElement;
      if (!svg || !grid) return;

      svg.setAttribute('width', String(grid.scrollWidth));
      svg.setAttribute('height', String(grid.scrollHeight));
      svg.innerHTML = '';

      const gridRect = grid.getBoundingClientRect();
      const nodes = container.querySelectorAll('.tree-node');

      nodes.forEach(nodeEl => {
        const el = nodeEl as HTMLElement;
        const childIds = (el.dataset.children || '').split(',').filter(Boolean);

        for (const childId of childIds) {
          const childEl = container.querySelector(`#node-${CSS.escape(childId)}`) as HTMLElement;
          if (!childEl) continue;

          const pRect = el.getBoundingClientRect();
          const cRect = childEl.getBoundingClientRect();

          const x1 = pRect.left + pRect.width / 2 - gridRect.left;
          const y1 = pRect.bottom - gridRect.top;
          const x2 = cRect.left + cRect.width / 2 - gridRect.left;
          const y2 = cRect.top - gridRect.top;
          const midY = (y1 + y2) / 2;

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', `M${x1},${y1} C${x1},${midY} ${x2},${midY} ${x2},${y2}`);
          path.setAttribute('stroke', getComputedStyle(el).getPropertyValue('--node-color').trim() || '#555');
          path.setAttribute('stroke-width', '1.5');
          path.setAttribute('fill', 'none');
          path.setAttribute('opacity', '0.45');
          path.setAttribute('data-parent', el.dataset.id || '');
          path.setAttribute('data-child', childId);
          svg.appendChild(path);
        }
      });
    });
  }

  function setupHighlighting() {
    document.querySelectorAll('.troop-tree-container').forEach(container => {
      const allNodes = container.querySelectorAll('.tree-node');
      const svg = container.querySelector('.tree-lines');

      allNodes.forEach(nodeEl => {
        const el = nodeEl as HTMLElement;
        const nodeId = el.dataset.id || '';

        el.addEventListener('mouseenter', () => {
          const connected = new Set<string>();
          connected.add(nodeId);

          function addDescendants(id: string) {
            const node = container.querySelector(`[data-id="${CSS.escape(id)}"]`) as HTMLElement;
            if (!node) return;
            const children = (node.dataset.children || '').split(',').filter(Boolean);
            for (const child of children) {
              if (!connected.has(child)) {
                connected.add(child);
                addDescendants(child);
              }
            }
          }

          function addAncestors(id: string) {
            allNodes.forEach(n => {
              const nEl = n as HTMLElement;
              const children = (nEl.dataset.children || '').split(',').filter(Boolean);
              if (children.includes(id) && !connected.has(nEl.dataset.id || '')) {
                connected.add(nEl.dataset.id || '');
                addAncestors(nEl.dataset.id || '');
              }
            });
          }

          addDescendants(nodeId);
          addAncestors(nodeId);

          allNodes.forEach(n => {
            const nEl = n as HTMLElement;
            if (connected.has(nEl.dataset.id || '')) {
              nEl.classList.add('highlighted');
              nEl.classList.remove('dimmed');
            } else {
              nEl.classList.add('dimmed');
              nEl.classList.remove('highlighted');
            }
          });

          if (svg) {
            svg.querySelectorAll('path').forEach(path => {
              const parent = path.getAttribute('data-parent') || '';
              const child = path.getAttribute('data-child') || '';
              if (connected.has(parent) && connected.has(child)) {
                path.setAttribute('opacity', '1');
                path.setAttribute('stroke-width', '2.5');
              } else {
                path.setAttribute('opacity', '0.08');
              }
            });
          }
        });

        el.addEventListener('mouseleave', () => {
          allNodes.forEach(n => {
            (n as HTMLElement).classList.remove('highlighted', 'dimmed');
          });
          if (svg) {
            svg.querySelectorAll('path').forEach(path => {
              path.setAttribute('opacity', '0.45');
              path.setAttribute('stroke-width', '1.5');
            });
          }
        });
      });
    });
  }

  function init() {
    drawTreeLines();
    setupHighlighting();
  }

  // Use astro:page-load for View Transitions compatibility
  document.addEventListener('astro:page-load', () => setTimeout(init, 100));

  // Also run on initial load if astro:page-load already fired
  if (document.readyState !== 'loading') {
    setTimeout(init, 100);
  }

  window.addEventListener('resize', drawTreeLines);
</script>
