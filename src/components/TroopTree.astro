---
import type { Troop } from '../lib/parse-xml';

interface Props {
  troops: Troop[];
  culture: string;
}

const { troops, culture } = Astro.props;

// Build lookup maps
const troopById = new Map<string, Troop>();
for (const t of troops) {
  troopById.set(t.id, t);
}

// Find parent for each troop
const parentMap = new Map<string, string[]>();
for (const t of troops) {
  for (const targetId of t.upgradeTo) {
    if (troopById.has(targetId)) {
      if (!parentMap.has(targetId)) parentMap.set(targetId, []);
      parentMap.get(targetId)!.push(t.id);
    }
  }
}

// Tier assignment
const TIER_LEVELS = [1, 6, 11, 16, 21, 26, 31, 36, 41, 46];
function getTier(level: number): number {
  for (let i = TIER_LEVELS.length - 1; i >= 0; i--) {
    if (level >= TIER_LEVELS[i]) return i;
  }
  return 0;
}

// Find root troops (no parent within this faction)
const rootTroops = troops.filter(t => {
  const parents = parentMap.get(t.id) || [];
  return parents.length === 0;
}).sort((a, b) => a.level - b.level || a.name.localeCompare(b.name));

// --- Build branches ---
// A "branch" starts at each child of a root (or at a root with no children that splits)
// We trace each branch all the way down

interface Branch {
  label: string;
  nodes: Map<number, Troop[]>; // tier → troops at that tier
  allIds: Set<string>;
}

function deriveBranchLabel(troop: Troop): string {
  let name = troop.name.replace(/^\[.*?\]\s*/, '');
  // Try to extract a regional name (first word if multi-word, unless generic)
  const genericWords = new Set(['Recruit', 'Militia', 'Militiaman', 'Levyman', 'Footman', 'Warrior', 'Scout', 'Soldier', 'Peasant']);
  const words = name.split(/\s+/);
  if (words.length >= 2 && !genericWords.has(words[0])) {
    return words[0];
  }
  return name;
}

function traceBranch(startId: string, visited: Set<string>): Troop[] {
  const chain: Troop[] = [];
  const queue = [startId];
  while (queue.length > 0) {
    const id = queue.shift()!;
    if (visited.has(id)) continue;
    const troop = troopById.get(id);
    if (!troop) continue;
    visited.add(id);
    chain.push(troop);
    for (const childId of troop.upgradeTo) {
      if (troopById.has(childId) && !visited.has(childId)) {
        queue.push(childId);
      }
    }
  }
  return chain;
}

const branches: Branch[] = [];
const globalVisited = new Set<string>();

// Shared roots go into a special "root" section, then each of their children starts a branch
for (const root of rootTroops) {
  if (globalVisited.has(root.id)) continue;

  const childIds = root.upgradeTo.filter(id => troopById.has(id));

  if (childIds.length === 0) {
    // Standalone troop — its own branch
    globalVisited.add(root.id);
    const b: Branch = {
      label: deriveBranchLabel(root),
      nodes: new Map(),
      allIds: new Set([root.id]),
    };
    const tier = getTier(root.level);
    b.nodes.set(tier, [root]);
    branches.push(b);
  } else if (childIds.length === 1) {
    // Single chain — trace it as one branch
    const chain = traceBranch(root.id, globalVisited);
    const b: Branch = {
      label: deriveBranchLabel(root),
      nodes: new Map(),
      allIds: new Set(chain.map(t => t.id)),
    };
    for (const t of chain) {
      const tier = getTier(t.level);
      if (!b.nodes.has(tier)) b.nodes.set(tier, []);
      b.nodes.get(tier)!.push(t);
    }
    branches.push(b);
  } else {
    // Root splits into multiple branches
    globalVisited.add(root.id);
    for (const childId of childIds) {
      if (globalVisited.has(childId)) continue;
      const child = troopById.get(childId)!;
      const chain = traceBranch(childId, globalVisited);
      const b: Branch = {
        label: deriveBranchLabel(child),
        nodes: new Map(),
        allIds: new Set(chain.map(t => t.id)),
      };
      // Include root in this branch
      b.allIds.add(root.id);
      const rootTier = getTier(root.level);
      if (!b.nodes.has(rootTier)) b.nodes.set(rootTier, []);
      // Only add root to the first branch to avoid duplication in rendering
      // We'll handle root display specially

      for (const t of chain) {
        const tier = getTier(t.level);
        if (!b.nodes.has(tier)) b.nodes.set(tier, []);
        b.nodes.get(tier)!.push(t);
      }
      branches.push(b);
    }
  }
}

// Pick up any remaining orphans
for (const t of troops) {
  if (!globalVisited.has(t.id)) {
    globalVisited.add(t.id);
    const chain = traceBranch(t.id, globalVisited);
    const b: Branch = {
      label: deriveBranchLabel(t),
      nodes: new Map(),
      allIds: new Set(chain.map(tr => tr.id)),
    };
    for (const tr of chain) {
      const tier = getTier(tr.level);
      if (!b.nodes.has(tier)) b.nodes.set(tier, []);
      b.nodes.get(tier)!.push(tr);
    }
    branches.push(b);
  }
}

// Collect all tiers used
const allTiers = new Set<number>();
for (const b of branches) {
  for (const tier of b.nodes.keys()) {
    allTiers.add(tier);
  }
}
// Also add root tiers
for (const root of rootTroops) {
  allTiers.add(getTier(root.level));
}
const sortedTiers = Array.from(allTiers).sort((a, b) => a - b);

// Build edge map for SVG: parent id → child ids (only within this faction)
const edges: { parentId: string; childId: string }[] = [];
for (const t of troops) {
  for (const childId of t.upgradeTo) {
    if (troopById.has(childId)) {
      edges.push({ parentId: t.id, childId });
    }
  }
}

// Collect root troops that split (shown spanning across top)
const sharedRoots = rootTroops.filter(r => r.upgradeTo.filter(id => troopById.has(id)).length > 1);
const sharedRootIds = new Set(sharedRoots.map(r => r.id));

// Color map for default_group
const GROUP_COLORS: Record<string, string> = {
  Infantry: '#E08080',
  Cavalry: '#B39DDB',
  Ranged: '#6DBF8A',
  HorseArcher: '#D4C96A',
  General: '#c9a44a',
};

function stripBracketPrefix(name: string): string {
  return name.replace(/^\[.*?\]\s*/, '');
}
---

<div class="troop-tree-container" data-culture={culture}>
  <div class="tree-legend">
    {Object.entries(GROUP_COLORS).map(([group, color]) => (
      <span class="legend-item">
        <span class="legend-dot" style={`background: ${color}`}></span>
        {group}
      </span>
    ))}
  </div>

  <div class="tree-scroll">
    <svg class="tree-lines" id={`tree-svg-${culture}`}></svg>
    <div class="tree-grid" style={`--num-branches: ${branches.length}`}>
      {/* Header row with branch labels */}
      <div class="tree-row tree-header">
        <div class="tier-label"></div>
        {branches.map(b => (
          <div class="branch-header">{b.label}</div>
        ))}
      </div>

      {/* Shared roots row (if any) */}
      {sharedRoots.length > 0 && (
        <div class="tree-row root-row">
          <div class="tier-label">
            <span class="tier-num">T{getTier(sharedRoots[0].level)}</span>
            <span class="tier-level">Lv {TIER_LEVELS[getTier(sharedRoots[0].level)]}</span>
          </div>
          <div class="root-span" style={`grid-column: 2 / -1`}>
            {sharedRoots.map(root => {
              const color = GROUP_COLORS[root.defaultGroup] || '#999';
              return (
                <div
                  class="tree-node"
                  id={`node-${root.id}`}
                  data-id={root.id}
                  data-children={root.upgradeTo.filter(id => troopById.has(id)).join(',')}
                  style={`--node-color: ${color}; --node-color-dim: ${color}33`}
                >
                  <span class="node-name">{stripBracketPrefix(root.name)}</span>
                  <span class="node-level">Lv {root.level}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Tier rows */}
      {sortedTiers.filter(tier => {
        // Skip the shared root tier if all troops at that tier are shared roots
        if (sharedRoots.length > 0 && tier === getTier(sharedRoots[0].level)) {
          // Check if there are non-root troops at this tier
          return branches.some(b => {
            const nodesAtTier = b.nodes.get(tier) || [];
            return nodesAtTier.some(t => !sharedRootIds.has(t.id));
          });
        }
        return true;
      }).map(tier => (
        <div class="tree-row" data-tier={tier}>
          <div class="tier-label">
            <span class="tier-num">T{tier}</span>
            <span class="tier-level">Lv {TIER_LEVELS[tier]}</span>
          </div>
          {branches.map(b => {
            const nodesAtTier = (b.nodes.get(tier) || []).filter(t => !sharedRootIds.has(t.id));
            return (
              <div class="branch-cell">
                {nodesAtTier.map(t => {
                  const color = GROUP_COLORS[t.defaultGroup] || '#999';
                  const childIds = t.upgradeTo.filter(id => troopById.has(id));
                  return (
                    <div
                      class="tree-node"
                      id={`node-${t.id}`}
                      data-id={t.id}
                      data-children={childIds.join(',')}
                      style={`--node-color: ${color}; --node-color-dim: ${color}33`}
                    >
                      <span class="node-name">{stripBracketPrefix(t.name)}</span>
                      <span class="node-level">Lv {t.level}</span>
                    </div>
                  );
                })}
              </div>
            );
          })}
        </div>
      ))}
    </div>
  </div>

  {/* Edge data for JS line drawing */}
  <script type="application/json" class="tree-edges">{JSON.stringify(edges)}</script>
</div>

<style>
  .troop-tree-container {
    position: relative;
    margin: 1rem 0;
  }

  .tree-legend {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .tree-scroll {
    overflow-x: auto;
    position: relative;
    padding-bottom: 1rem;
  }

  .tree-lines {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 1;
  }

  .tree-grid {
    position: relative;
    display: grid;
    grid-template-columns: 70px repeat(var(--num-branches), minmax(140px, 1fr));
    min-width: fit-content;
  }

  .tree-row {
    display: contents;
  }

  .tree-header .branch-header {
    padding: 0.5rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    text-align: center;
    border-bottom: 2px solid var(--accent-dim);
    background: var(--bg-secondary);
    white-space: nowrap;
  }

  .tree-header .tier-label {
    border-bottom: 2px solid var(--accent-dim);
    background: var(--bg-secondary);
  }

  .tier-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .tier-num {
    font-weight: 700;
    color: var(--accent);
    font-size: 0.85rem;
  }

  .tier-level {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .root-span {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem 1rem;
    gap: 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .branch-cell {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.4rem 0.35rem;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-color);
    border-right: 1px dashed rgba(51, 51, 51, 0.5);
    min-height: 48px;
  }

  .branch-cell:last-child {
    border-right: none;
  }

  .tree-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.35rem 0.6rem;
    background: var(--node-color-dim);
    border: 1px solid var(--node-color);
    border-left: 3px solid var(--node-color);
    border-radius: 4px;
    cursor: default;
    white-space: nowrap;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
    position: relative;
    z-index: 2;
  }

  .tree-node:hover {
    transform: scale(1.08);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    z-index: 10;
  }

  .node-name {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
    text-align: center;
  }

  .node-level {
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  .tree-node.highlighted {
    box-shadow: 0 0 10px var(--node-color);
    transform: scale(1.08);
  }

  .tree-node.dimmed {
    opacity: 0.2;
  }
</style>

<script>
  function drawTreeLines() {
    document.querySelectorAll('.troop-tree-container').forEach(container => {
      const svg = container.querySelector('.tree-lines') as SVGSVGElement;
      const grid = container.querySelector('.tree-grid') as HTMLElement;
      if (!svg || !grid) return;

      svg.setAttribute('width', String(grid.scrollWidth));
      svg.setAttribute('height', String(grid.scrollHeight));
      svg.innerHTML = '';

      const gridRect = grid.getBoundingClientRect();
      const nodes = container.querySelectorAll('.tree-node');

      nodes.forEach(nodeEl => {
        const el = nodeEl as HTMLElement;
        const childIds = (el.dataset.children || '').split(',').filter(Boolean);

        for (const childId of childIds) {
          const childEl = container.querySelector(`#node-${CSS.escape(childId)}`) as HTMLElement;
          if (!childEl) continue;

          const pRect = el.getBoundingClientRect();
          const cRect = childEl.getBoundingClientRect();

          const x1 = pRect.left + pRect.width / 2 - gridRect.left;
          const y1 = pRect.bottom - gridRect.top;
          const x2 = cRect.left + cRect.width / 2 - gridRect.left;
          const y2 = cRect.top - gridRect.top;
          const midY = (y1 + y2) / 2;

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', `M${x1},${y1} C${x1},${midY} ${x2},${midY} ${x2},${y2}`);
          path.setAttribute('stroke', getComputedStyle(el).getPropertyValue('--node-color').trim() || '#555');
          path.setAttribute('stroke-width', '1.5');
          path.setAttribute('fill', 'none');
          path.setAttribute('opacity', '0.45');
          path.setAttribute('data-parent', el.dataset.id || '');
          path.setAttribute('data-child', childId);
          svg.appendChild(path);
        }
      });
    });
  }

  function setupHighlighting() {
    document.querySelectorAll('.troop-tree-container').forEach(container => {
      const allNodes = container.querySelectorAll('.tree-node');
      const svg = container.querySelector('.tree-lines');

      allNodes.forEach(nodeEl => {
        const el = nodeEl as HTMLElement;
        const nodeId = el.dataset.id || '';

        el.addEventListener('mouseenter', () => {
          const connected = new Set<string>();
          connected.add(nodeId);

          function addDescendants(id: string) {
            const node = container.querySelector(`[data-id="${CSS.escape(id)}"]`) as HTMLElement;
            if (!node) return;
            const children = (node.dataset.children || '').split(',').filter(Boolean);
            for (const child of children) {
              if (!connected.has(child)) {
                connected.add(child);
                addDescendants(child);
              }
            }
          }

          function addAncestors(id: string) {
            allNodes.forEach(n => {
              const nEl = n as HTMLElement;
              const children = (nEl.dataset.children || '').split(',').filter(Boolean);
              if (children.includes(id) && !connected.has(nEl.dataset.id || '')) {
                connected.add(nEl.dataset.id || '');
                addAncestors(nEl.dataset.id || '');
              }
            });
          }

          addDescendants(nodeId);
          addAncestors(nodeId);

          allNodes.forEach(n => {
            const nEl = n as HTMLElement;
            if (connected.has(nEl.dataset.id || '')) {
              nEl.classList.add('highlighted');
              nEl.classList.remove('dimmed');
            } else {
              nEl.classList.add('dimmed');
              nEl.classList.remove('highlighted');
            }
          });

          if (svg) {
            svg.querySelectorAll('path').forEach(path => {
              const parent = path.getAttribute('data-parent') || '';
              const child = path.getAttribute('data-child') || '';
              if (connected.has(parent) && connected.has(child)) {
                path.setAttribute('opacity', '1');
                path.setAttribute('stroke-width', '2.5');
              } else {
                path.setAttribute('opacity', '0.08');
              }
            });
          }
        });

        el.addEventListener('mouseleave', () => {
          allNodes.forEach(n => {
            (n as HTMLElement).classList.remove('highlighted', 'dimmed');
          });
          if (svg) {
            svg.querySelectorAll('path').forEach(path => {
              path.setAttribute('opacity', '0.45');
              path.setAttribute('stroke-width', '1.5');
            });
          }
        });
      });
    });
  }

  function init() {
    drawTreeLines();
    setupHighlighting();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(init, 100));
  } else {
    setTimeout(init, 100);
  }

  window.addEventListener('resize', drawTreeLines);
</script>
