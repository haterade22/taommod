---
import Topbar from '../components/Topbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const roadmapArtists = [
  {
    name: 'Solus',
    discipline: '3D Art',
    wip: ['Dale Armour', 'Gondor Weapon Revamp'],
    next: ['Dale Weapons', 'Rivendell Kitbash', 'Umbar Armours', 'Map Icons'],
  },
  {
    name: 'Keyforce',
    discipline: '3D Art',
    wip: ['Gondor Armour Revamp', 'Dwarven Kitbash'],
    next: ['Mordor Orc Armours & Mordor Black Númenorean Armours', 'Haradwaith armours', 'Khand armours'],
  },
  {
    name: 'Leovsilva',
    discipline: '3D Art',
    wip: [],
    next: ['Lothlorien armours'],
  },
  {
    name: 'Haterade',
    discipline: 'Coding',
    wip: ['Implementing 1.3 code'],
    next: [],
  },
  {
    name: 'Thyrell',
    discipline: '2D Art',
    wip: ['Clan banner overhaul for 1.3'],
    next: [],
  },
  {
    name: 'Lemmy',
    discipline: 'Map Design',
    wip: ['Map for 1.3'],
    next: [],
  },
];

const totalWip = roadmapArtists.reduce((sum, artist) => sum + artist.wip.length, 0);
const totalNext = roadmapArtists.reduce((sum, artist) => sum + artist.next.length, 0);
---

<BaseLayout
  title="Roadmap"
  description="Current TAOM art and map production roadmap by artist"
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-roadmap-body"
  mainClass="taom-roadmap-main"
>
  <div class="roadmap-page">
    <Topbar />

    <main class="page-shell">
      <section class="hero-panel">
        <div class="hero-copy">
          <p class="eyebrow">Production Outlook</p>
          <h1>Roadmap</h1>
          <p class="intro-copy">
            A quick look at what each artist is building now and what is queued next for the TAOM pipeline.
          </p>
        </div>

        <div class="hero-stats">
          <article class="stat-card">
            <span class="stat-value">{roadmapArtists.length}</span>
            <span class="stat-label">Contributors</span>
          </article>
          <article class="stat-card">
            <span class="stat-value">{totalWip}</span>
            <span class="stat-label">Items In Progress</span>
          </article>
          <article class="stat-card">
            <span class="stat-value">{totalNext}</span>
            <span class="stat-label">Queued Next</span>
          </article>
        </div>
      </section>

      <section class="artist-grid" aria-label="Roadmap by artist">
        {
          roadmapArtists.map((artist) => (
            <article class="artist-card">
              <div class="artist-header">
                <div>
                  <p class="card-kicker">{artist.discipline}</p>
                  <h2>{artist.name}</h2>
                </div>
                <div class="artist-meta">
                  {artist.wip.length > 0 && <span class="status-chip status-chip-active">{artist.wip.length} WIP</span>}
                  {artist.next.length > 0 && <span class="status-chip">{artist.next.length} Next</span>}
                </div>
              </div>

              <div class="artist-columns">
                <section class="task-block">
                  <div class="task-heading">
                    <span class="task-dot task-dot-wip" />
                    <h3>WIP</h3>
                  </div>
                  {artist.wip.length > 0 ? (
                    <ul class="task-list">
                      {artist.wip.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="empty-state">No active item listed yet.</p>
                  )}
                </section>

                <section class="task-block">
                  <div class="task-heading">
                    <span class="task-dot task-dot-next" />
                    <h3>Next</h3>
                  </div>
                  {artist.next.length > 0 ? (
                    <ul class="task-list">
                      {artist.next.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  ) : (
                    <p class="empty-state">Nothing queued after the current task.</p>
                  )}
                </section>
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  :global(body.taom-roadmap-body) {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(7, 5, 5, 0.68), rgba(7, 5, 5, 0.97)),
      radial-gradient(circle at 14% 18%, rgba(146, 98, 43, 0.22), transparent 24%),
      radial-gradient(circle at 84% 14%, rgba(98, 58, 26, 0.16), transparent 20%),
      linear-gradient(180deg, #18100e 0%, #0d0908 45%, #070505 100%);
    color: #ece4db;
  }

  :global(body.taom-roadmap-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(17, 11, 9, 0.34), rgba(7, 6, 6, 0.85)),
      radial-gradient(circle at center, rgba(222, 186, 103, 0.06), transparent 48%);
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-roadmap-main) {
    display: block;
  }

  .roadmap-page {
    min-height: 100vh;
    padding: 2rem;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .page-shell {
    width: min(100%, 80rem);
    margin: 0 auto;
    padding: 4rem 0 5rem;
    display: grid;
    gap: 1.5rem;
  }

  .hero-panel,
  .artist-card,
  .stat-card,
  .task-block {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(151, 110, 51, 0.44);
    background:
      linear-gradient(180deg, rgba(17, 13, 12, 0.88), rgba(10, 8, 8, 0.94)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
  }

  .hero-panel::before,
  .artist-card::before,
  .stat-card::before,
  .task-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(214, 168, 89, 0.08),
      transparent 42%,
      transparent 72%,
      rgba(214, 168, 89, 0.04)
    );
    pointer-events: none;
  }

  .hero-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.9fr);
    gap: 1.5rem;
    padding: 3rem;
  }

  .hero-copy,
  .artist-card,
  .task-block {
    position: relative;
    z-index: 1;
  }

  .eyebrow,
  .card-kicker,
  .stat-label,
  .task-heading h3,
  .status-chip {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .eyebrow,
  .card-kicker {
    margin: 0 0 0.8rem;
    font-size: 0.78rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(214, 176, 106, 0.84);
  }

  .hero-panel h1,
  .artist-card h2 {
    margin: 0;
    color: #f5eee5;
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .hero-panel h1 {
    font-size: clamp(2.5rem, 4vw, 4.3rem);
    line-height: 0.95;
  }

  .intro-copy {
    max-width: 44rem;
    margin: 1.15rem 0 0;
    color: rgba(231, 222, 214, 0.8);
    font-size: 1.04rem;
    line-height: 1.7;
  }

  .hero-stats {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .stat-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.35rem 1.4rem;
  }

  .stat-value {
    color: #f7f1e8;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1;
  }

  .stat-label {
    color: rgba(214, 176, 106, 0.82);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .artist-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .artist-card {
    padding: 2rem;
  }

  .artist-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
  }

  .artist-card h2 {
    font-size: clamp(1.55rem, 2vw, 2rem);
    line-height: 1.05;
  }

  .artist-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: end;
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(166, 134, 80, 0.4);
    color: #e9ddca;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: rgba(19, 15, 13, 0.72);
  }

  .status-chip-active {
    border-color: rgba(205, 153, 52, 0.44);
    color: #f7e7bf;
    background:
      linear-gradient(180deg, rgba(70, 50, 39, 0.82), rgba(38, 28, 24, 0.92)),
      radial-gradient(circle at top, rgba(255, 239, 193, 0.08), transparent 56%);
  }

  .artist-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .task-block {
    padding: 1.2rem 1.15rem 1.15rem;
    min-height: 100%;
  }

  .task-heading {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .task-heading h3 {
    margin: 0;
    color: #f6ede2;
    font-size: 0.92rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .task-dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    flex: 0 0 auto;
  }

  .task-dot-wip {
    background: #d6a858;
    box-shadow: 0 0 0 0.3rem rgba(214, 168, 88, 0.14);
  }

  .task-dot-next {
    background: #8da56e;
    box-shadow: 0 0 0 0.3rem rgba(141, 165, 110, 0.12);
  }

  .task-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .task-list li,
  .empty-state {
    color: rgba(231, 222, 214, 0.78);
    line-height: 1.55;
  }

  .task-list li {
    position: relative;
    padding-left: 1rem;
  }

  .task-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.42rem;
    height: 1px;
    background: rgba(214, 176, 106, 0.7);
  }

  .empty-state {
    margin: 1rem 0 0;
    font-style: italic;
    color: rgba(207, 191, 171, 0.62);
  }

  @media (max-width: 1080px) {
    .hero-panel,
    .artist-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .roadmap-page {
      padding: 1rem;
    }

    .page-shell {
      padding: 2.5rem 0 3.5rem;
    }

    .hero-panel,
    .artist-card {
      padding: 1.5rem;
    }

    .hero-panel {
      gap: 1rem;
    }

    .artist-header,
    .artist-columns {
      grid-template-columns: 1fr;
    }

    .artist-header {
      display: grid;
    }

    .artist-meta {
      justify-content: start;
    }
  }
</style>
