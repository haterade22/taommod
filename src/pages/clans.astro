---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseAllClans } from '../lib/parse-xml';

const clans = parseAllClans();

type ClanEntry = { name: string; region?: string };

// Override Gondor clans with exact order from game UI
const GONDOR_CLANS: ClanEntry[] = [
  { name: 'House of Húrinionath', region: 'Anórien' },
  { name: 'House of Imrazôrionath', region: 'Belfalas' },
  { name: 'House of Eärnurionath', region: 'Lebennin' },
  { name: 'House of Ausirionath', region: 'Lossarnach' },
  { name: 'House of Barahirionath', region: 'Anfalas' },
  { name: 'House of Halboronionath', region: 'Pinnath Gelin' },
  { name: 'House of Malandilionath', region: 'Lamedon' },
  { name: 'House of Olindurionath' },
  { name: 'House of Danuhirionath' },
  { name: 'House of Hyarthulionath' },
  { name: 'House of Caladionath' },
  { name: 'House of Hirilionath' },
  { name: 'House of Baranionath' },
  { name: 'House of Garvirionath' },
];

// Override Umbar clans with exact order from game UI
const UMBAR_CLANS: ClanEntry[] = [
  { name: 'House of Casimirioni' },
  { name: 'House of Jarjâx' },
  { name: 'House of Heshlâ' },
  { name: 'House of Bel Inzûl' },
  { name: 'House of Halrax' },
  { name: 'House of Khatûg' },
];

// Kingdom banner images
const KINGDOM_IMAGES: Record<string, string> = {
  Gondor: '/images/gondor_web_ready.png',
  Umbar: '/images/clans-umbar.png',
};

// Kingdoms with manual overrides (skip auto-sort)
const OVERRIDE_KINGDOMS = new Set(['Gondor', 'Umbar']);

// Group clans by kingdom
const clansByKingdom = new Map<string, ClanEntry[]>();
for (const clan of clans) {
  const kingdom = clan.kingdom || 'Unknown';
  if (!clansByKingdom.has(kingdom)) clansByKingdom.set(kingdom, []);
  clansByKingdom.get(kingdom)!.push({ name: clan.name });
}

// Override with exact lists
clansByKingdom.set('Gondor', GONDOR_CLANS);
clansByKingdom.set('Umbar', UMBAR_CLANS);

// Sort kingdoms alphabetically, sort clans within each kingdom by name (except overridden ones)
const sortedKingdoms = Array.from(clansByKingdom.entries())
  .filter(([k]) => k !== 'Unknown' && k !== '')
  .sort(([a], [b]) => a.localeCompare(b));

for (const [kingdom, entries] of sortedKingdoms) {
  if (!OVERRIDE_KINGDOMS.has(kingdom)) {
    entries.sort((a, b) => a.name.localeCompare(b.name));
  }
}
---

<BaseLayout title="Clans" description="All clans in TAOM organized by kingdom">
  <div class="page-content" style="max-width: 900px;">
    <h1 class="page-title">Clans of Middle-earth</h1>

    {sortedKingdoms.map(([kingdom, entries]) => (
      <section class="clan-section">
        <h2>{kingdom}</h2>
        {KINGDOM_IMAGES[kingdom] && (
          <img src={KINGDOM_IMAGES[kingdom]} alt={`${kingdom} clans`} class="clan-banner" />
        )}
        <ul>
          {entries.map(c => (
            <li>{c.name}{c.region && <span class="clan-region"> ({c.region})</span>}</li>
          ))}
        </ul>
      </section>
    ))}

    {sortedKingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No clans found. Check that spclans.xslt and clans.xml data is available.</p>
    )}
  </div>
</BaseLayout>

<style>
  .clan-section {
    margin-bottom: 2rem;
  }

  .clan-section h2 {
    color: var(--accent);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .clan-banner {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  .clan-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
  }

  .clan-section li {
    color: var(--text-primary);
    font-size: 0.95rem;
    padding: 0.2rem 0;
  }

  .clan-region {
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-style: italic;
  }
</style>
