---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseAllClans } from '../lib/parse-xml';

const clans = parseAllClans();

// Group clans by kingdom
const clansByKingdom = new Map<string, typeof clans>();
for (const clan of clans) {
  const kingdom = clan.kingdom || 'Unknown';
  if (!clansByKingdom.has(kingdom)) clansByKingdom.set(kingdom, []);
  clansByKingdom.get(kingdom)!.push(clan);
}

// Sort kingdoms alphabetically, sort clans within each kingdom by name
const sortedKingdoms = Array.from(clansByKingdom.entries())
  .filter(([k]) => k !== 'Unknown' && k !== '')
  .sort(([a], [b]) => a.localeCompare(b));

for (const [, kClans] of sortedKingdoms) {
  kClans.sort((a, b) => a.name.localeCompare(b.name));
}
---

<BaseLayout title="Clans" description="All clans in TAOM organized by kingdom">
  <div class="page-content" style="max-width: 900px;">
    <h1 class="page-title">Clans of Middle-earth</h1>

    {sortedKingdoms.map(([kingdom, kClans]) => (
      <section class="clan-section">
        <h2>{kingdom}</h2>
        <ul>
          {kClans.map(c => (
            <li>{c.name}</li>
          ))}
        </ul>
      </section>
    ))}

    {sortedKingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No clans found. Check that spclans.xslt and clans.xml data is available.</p>
    )}
  </div>
</BaseLayout>

<style>
  .clan-section {
    margin-bottom: 2rem;
  }

  .clan-section h2 {
    color: var(--accent);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .clan-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
  }

  .clan-section li {
    color: var(--text-primary);
    font-size: 0.95rem;
    padding: 0.2rem 0;
  }
</style>
