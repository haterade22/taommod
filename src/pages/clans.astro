---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseAllClans } from '../lib/parse-xml';

const clans = parseAllClans();

// Override Gondor clans with exact order from game UI
const GONDOR_CLANS = [
  'House of Húrinionath',
  'House of Imrazôrionath',
  'House of Eärnurionath',
  'House of Ausirionath',
  'House of Barahirionath',
  'House of Halboronionath',
  'House of Malandilionath',
  'House of Olindurionath',
  'House of Danuhirionath',
  'House of Hyarthulionath',
  'House of Caladionath',
  'House of Hirilionath',
  'House of Baranionath',
  'House of Garvirionath',
];

// Kingdom banner images
const KINGDOM_IMAGES: Record<string, string> = {
  Gondor: '/images/clans-gondor.png',
};

// Group clans by kingdom
const clansByKingdom = new Map<string, string[]>();
for (const clan of clans) {
  const kingdom = clan.kingdom || 'Unknown';
  if (!clansByKingdom.has(kingdom)) clansByKingdom.set(kingdom, []);
  clansByKingdom.get(kingdom)!.push(clan.name);
}

// Override Gondor with exact list
clansByKingdom.set('Gondor', GONDOR_CLANS);

// Sort kingdoms alphabetically, sort clans within each kingdom by name (except Gondor which has fixed order)
const sortedKingdoms = Array.from(clansByKingdom.entries())
  .filter(([k]) => k !== 'Unknown' && k !== '')
  .sort(([a], [b]) => a.localeCompare(b));

for (const [kingdom, names] of sortedKingdoms) {
  if (kingdom !== 'Gondor') {
    names.sort((a, b) => a.localeCompare(b));
  }
}
---

<BaseLayout title="Clans" description="All clans in TAOM organized by kingdom">
  <div class="page-content" style="max-width: 900px;">
    <h1 class="page-title">Clans of Middle-earth</h1>

    {sortedKingdoms.map(([kingdom, names]) => (
      <section class="clan-section">
        <h2>{kingdom}</h2>
        {KINGDOM_IMAGES[kingdom] && (
          <img src={KINGDOM_IMAGES[kingdom]} alt={`${kingdom} clans`} class="clan-banner" />
        )}
        <ul>
          {names.map(name => (
            <li>{name}</li>
          ))}
        </ul>
      </section>
    ))}

    {sortedKingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No clans found. Check that spclans.xslt and clans.xml data is available.</p>
    )}
  </div>
</BaseLayout>

<style>
  .clan-section {
    margin-bottom: 2rem;
  }

  .clan-section h2 {
    color: var(--accent);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .clan-banner {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  .clan-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
  }

  .clan-section li {
    color: var(--text-primary);
    font-size: 0.95rem;
    padding: 0.2rem 0;
  }
</style>
