---
import Topbar from '../../components/Topbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

type EntryTag = {
  label: string;
  kind: 'status' | 'faction';
  tone?: 'planned' | 'wip';
};

type EntryCard = {
  name: string;
  text: string;
  family: 'free' | 'shadow' | 'creature';
  status?: 'current' | 'planned' | 'wip';
  tags?: EntryTag[];
};

type EntrySection = {
  kicker: string;
  title: string;
  intro?: string;
  cards: EntryCard[];
};

const playableRaces: EntryCard[] = [
  {
    name: 'Men',
    family: 'free',
    status: 'current',
    text: 'The most widespread race of Middle-earth. Men are adaptable and varied, forming the bulk of human populations across most factions. Their strength lies in versatility, allowing them to excel in many roles depending on culture, training, and environment.',
  },
  {
    name: 'Dunedain',
    family: 'free',
    status: 'planned',
    tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
    text: 'Descendants of the Numenoreans who settled in Middle-earth. The Dunedain are longer-lived and more resilient than ordinary Men, often serving as elite warriors, leaders, and guardians. Though diminished in number, they retain strong martial traditions and discipline.',
  },
  {
    name: 'Numenorean',
    family: 'free',
    status: 'planned',
    tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
    text: 'Men of pure or near-pure Numenorean lineage. Taller, stronger, and longer-lived than other Men, Numenoreans represent the height of human achievement in craftsmanship, warfare, and leadership. They are rare and typically appear as elites, nobles, or ruling classes rather than common troops.',
  },
  {
    name: 'Elf',
    family: 'free',
    status: 'wip',
    tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
    text: 'The standard Elven race found across all Elven realms. Elves are agile, disciplined, and long-lived, excelling in archery.',
  },
  {
    name: 'Dwarf',
    family: 'free',
    status: 'current',
    text: 'The standard Dwarven race. Stocky, resilient, and heavily armored, Dwarves excel in defensive warfare, heavy infantry roles, and siege combat.',
  },
];

const genericOrcs: EntryCard[] = [
  {
    name: 'Snaga',
    family: 'shadow',
    status: 'current',
    text: 'Small, weak, and expendable Orcs used primarily as skirmishers, laborers, and disposable frontline troops. They rely on numbers rather than strength or armor and often suffer from low morale.',
  },
  {
    name: 'Goblin',
    family: 'shadow',
    status: 'current',
    text: 'Smaller and more cunning than standard Orcs, Goblins favor ambush tactics, ranged combat, and underground warfare. They are commonly found in mountains, caves, and tunnel networks.',
  },
  {
    name: 'Orc',
    family: 'shadow',
    status: 'current',
    text: 'The most widespread and balanced Orc breed. Capable of wearing proper armor and wielding standard weapons, Orcs form the backbone of most Orcish infantry forces.',
  },
];

const factionBreeds: EntryCard[] = [
  {
    name: 'Black Uruk',
    family: 'shadow',
    status: 'current',
    tags: [{ label: 'Mordor', kind: 'faction' }],
    text: "Large, disciplined Orcs bred for endurance and obedience. Black Uruks serve as Mordor's heavy infantry and professional garrison troops.",
  },
  {
    name: 'Uruk-Hai',
    family: 'shadow',
    status: 'current',
    tags: [{ label: 'Isengard', kind: 'faction' }],
    text: 'Strong, disciplined hybrid warriors bred for warfare in daylight. Uruk-Hai are trained for formation fighting and aggressive battlefield roles.',
  },
  {
    name: 'Uruk-Hai Berserker',
    family: 'shadow',
    status: 'current',
    tags: [{ label: 'Isengard', kind: 'faction' }],
    text: 'Frenzied shock troops with minimal armor and extreme aggression. Berserkers are designed to break enemy lines through brute force and terror.',
  },
  {
    name: 'Pale Uruk',
    family: 'shadow',
    status: 'current',
    tags: [{ label: 'Gundabad', kind: 'faction' }],
    text: 'Massive, pale-skinned Orcs adapted to cold and mountainous regions. They are physically powerful frontline fighters with a brutal combat style.',
  },
  {
    name: 'Snow Orc',
    family: 'shadow',
    status: 'planned',
    tags: [
      { label: 'Gundabad', kind: 'faction' },
      { label: 'Planned', kind: 'status', tone: 'planned' },
    ],
    text: 'A cold-adapted Orc strain native to high mountain regions. Snow Orcs focus on endurance, resilience, and survival in extreme climates.',
  },
  {
    name: 'Half-Troll',
    family: 'shadow',
    status: 'planned',
    tags: [
      { label: 'Gundabad', kind: 'faction' },
      { label: 'Planned', kind: 'status', tone: 'planned' },
    ],
    text: 'Rare Orc-Troll hybrids of enormous size and strength. Half-Trolls function as elite terror units rather than standard troops.',
  },
  {
    name: 'Guldur Uruks',
    family: 'shadow',
    status: 'current',
    tags: [{ label: 'Dol Guldur', kind: 'faction' }],
    text: 'Dark Uruks corrupted by necromantic influence. They are often heavily armored and serve as elite shock or guard units.',
  },
  {
    name: 'Mountain Uruk',
    family: 'shadow',
    status: 'planned',
    tags: [
      { label: 'Misty Mountains', kind: 'faction' },
      { label: 'Planned', kind: 'status', tone: 'planned' },
    ],
    text: 'Large, powerful Orcs adapted to rocky highlands and mountain passes. Less disciplined but physically imposing.',
  },
  {
    name: 'Hob-Goblins',
    family: 'shadow',
    status: 'planned',
    tags: [
      { label: 'Misty Mountains', kind: 'faction' },
      { label: 'Planned', kind: 'status', tone: 'planned' },
    ],
    text: 'A more organized and cunning Goblin strain. Hob-Goblins emphasize ambush tactics, traps, and overwhelming numbers.',
  },
  {
    name: 'Troll-Men',
    family: 'shadow',
    status: 'planned',
    tags: [
      { label: 'Harad', kind: 'faction' },
      { label: 'Planned', kind: 'status', tone: 'planned' },
    ],
    text: 'Corrupted Men infused with Troll-like strength and resilience. Troll-Men serve as elite heavy infantry and enforcers within Harad factions.',
  },
];

const creatureSections: EntrySection[] = [
  {
    kicker: 'Creature File',
    title: 'Trolls',
    cards: [
      {
        name: 'Mountain Troll',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Large, heavily built Trolls adapted to rocky and mountainous terrain. Strong frontline shock units.',
      },
      {
        name: 'Hill Troll',
        family: 'creature',
        status: 'planned',
        tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
        text: 'Leaner and faster Trolls commonly found in hilly and forested regions. Less armored but more aggressive.',
      },
      {
        name: 'Snow Troll',
        family: 'creature',
        status: 'planned',
        tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
        text: 'Cold-adapted Trolls native to frozen and high-altitude regions. Focused on endurance and resilience.',
      },
      {
        name: 'Cave Troll',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Massive Trolls bred or captured for underground warfare and siege assaults.',
      },
      {
        name: 'Olog-Hai',
        family: 'creature',
        status: 'planned',
        tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
        text: 'Highly disciplined and intelligent Trolls capable of wearing armor and fighting in formation.',
      },
    ],
  },
  {
    kicker: 'Creature File',
    title: 'Wargs & Spiders',
    cards: [
      {
        name: 'Isengard Warg',
        family: 'creature',
        status: 'current',
        text: "Bred for discipline and battlefield control. Used primarily by Isengard's mounted Orc units.",
      },
      {
        name: 'Fell Warg',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Larger, more vicious Wargs found in the wild or corrupted regions. Less disciplined but extremely aggressive.',
      },
      {
        name: 'Forest Spider',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Giant spiders native to dense forests. Effective ambush predators.',
      },
      {
        name: 'Mountain Spider',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Larger and more heavily armored spiders adapted to rocky terrain and highlands.',
      },
      {
        name: 'Spider Brood-Mother',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Enormous spiders capable of spawning or commanding lesser spiders. Rare terror units.',
      },
    ],
  },
  {
    kicker: 'Creature File',
    title: 'War Beasts & Vehicles',
    cards: [
      {
        name: 'War Elephants',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Armored elephants equipped with platforms for archers or spear troops. While currently associated primarily with Harad, their use may expand to other southern or eastern factions in the future.',
      },
      {
        name: 'Oliphaunts',
        family: 'creature',
        status: 'wip',
        tags: [{ label: 'WIP', kind: 'status', tone: 'wip' }],
        text: 'Colossal beasts of war used primarily for terror and huge effect on the battlefield.',
      },
      {
        name: 'Chariots',
        family: 'creature',
        status: 'planned',
        tags: [{ label: 'Planned', kind: 'status', tone: 'planned' }],
        text: 'Fast, high-impact units designed for open terrain and shock warfare. Multiple factions may field unique chariot variants, including Khand, Rhun, Harad, Erebor, some Elven factions, and some Orc factions.',
      },
    ],
  },
];

const currentPlayableCount = playableRaces.filter((race) => race.status === 'current').length;
const plannedPlayableCount = playableRaces.filter((race) => race.status === 'planned').length;
const orcBreedCount = genericOrcs.length + factionBreeds.length;
const creatureCount = creatureSections.reduce((sum, section) => sum + section.cards.length, 0);
---

<BaseLayout
  title="Races & Creatures"
  description="Playable races, orc breeds, and planned creatures for Tales From the Age of Men"
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-races-body"
  mainClass="taom-races-main"
>
  <div class="races-page">
    <div class="topbar-wrap">
      <Topbar />
    </div>

    <main class="races-shell">
      <section class="page-intro">
        <p class="eyebrow">Field Archive of Middle-earth</p>
        <h1>Races & Creatures</h1>
        <p class="intro-copy">
          This dossier tracks the peoples, breeds, and battlefield beasts that define TAOM's world. It separates core
          playable races from faction-bound strains and long-term creature plans so the scope of the setting is easy to
          read at a glance.
        </p>
        <nav class="page-breadcrumb"><a href="/mod-info">Mod Info</a> / Races & Creatures</nav>
      </section>

      <section class="races-summary" aria-label="Races page summary">
        <article class="summary-card">
          <span class="summary-label">Playable Now</span>
          <strong>{currentPlayableCount}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Playable Planned</span>
          <strong>{plannedPlayableCount}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Orc Breeds</span>
          <strong>{orcBreedCount}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Creature Files</span>
          <strong>{creatureCount}</strong>
        </article>
      </section>

      <section class="overview-grid">
        <article class="taxonomy-panel">
          <div class="panel-heading">
            <div>
              <p class="panel-kicker">Archive Structure</p>
              <h2>How The Roster Is Grouped</h2>
            </div>
            <p class="panel-copy">
              The page is organized from stable playable races outward into specialist breeds and then future creatures,
              so core worldbuilding stays separate from experimental or long-term content.
            </p>
          </div>

          <div class="taxonomy-grid">
            <article class="taxonomy-card is-free">
              <span class="taxonomy-label">Peoples</span>
              <h3>Playable Races</h3>
              <p>Core races that anchor factions, culture identity, and the current campaign experience.</p>
            </article>
            <article class="taxonomy-card is-shadow">
              <span class="taxonomy-label">Breeds</span>
              <h3>Orc Strains</h3>
              <p>Shared Orc stock plus faction-specific breeds shaped by region, breeding, and battlefield purpose.</p>
            </article>
            <article class="taxonomy-card is-creature">
              <span class="taxonomy-label">Beasts</span>
              <h3>Creature Pipeline</h3>
              <p>WIP and planned monsters, mounts, and war assets intended to deepen faction flavor over time.</p>
            </article>
          </div>
        </article>

        <article class="briefing-panel">
          <div class="panel-heading">
            <div>
              <p class="panel-kicker">Status Codes</p>
              <h2>What The Tags Mean</h2>
            </div>
            <p class="panel-copy">
              Some entries are in active production while others are longer-term concepts. The tags separate what
              already exists in the design from what is still exploratory.
            </p>
          </div>

          <div class="status-list">
            <div class="status-row">
              <span class="meta-pill is-current">Current</span>
              <p>Established concepts already represented as part of the core race or creature plan.</p>
            </div>
            <div class="status-row">
              <span class="meta-pill is-planned">Planned</span>
              <p>Ideas with a clear intended role that are not yet part of the current playable implementation.</p>
            </div>
            <div class="status-row">
              <span class="meta-pill is-wip">WIP</span>
              <p>Actively developing creature or support concepts that are further along than broad future ideas.</p>
            </div>
          </div>
        </article>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Core Peoples</p>
            <h2>Playable & Planned Races</h2>
          </div>
          <p class="section-copy">
            These are the foundational peoples of the setting, from the currently playable major races to the human
            bloodlines intended for elite or noble representation later on.
          </p>
        </div>

        <div class="card-grid">
          {
            playableRaces.map((race) => (
              <article class:list={['entry-card', 'is-free', { 'is-planned-card': race.status === 'planned' }]}>
                <div class="entry-head">
                  <h3>{race.name}</h3>
                  {race.tags && (
                    <div class="entry-tags">
                      {race.tags.map((tag) => (
                        <span
                          class:list={[
                            'meta-pill',
                            tag.kind === 'faction' ? 'is-faction' : '',
                            tag.tone ? `is-${tag.tone}` : 'is-current',
                          ]}
                        >
                          {tag.label}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <p>{race.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Shared Stock</p>
            <h2>Generic Orc-ish Races</h2>
          </div>
          <p class="section-copy">
            These breeds form the common foundation of Orc forces across Middle-earth even when their equipment,
            culture, or visual direction differs by faction.
          </p>
        </div>

        <div class="card-grid card-grid-wide">
          {
            genericOrcs.map((race) => (
              <article class="entry-card is-shadow">
                <div class="entry-head">
                  <h3>{race.name}</h3>
                </div>
                <p>{race.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Faction Strains</p>
            <h2>Specific & Faction-Bound Breeds</h2>
          </div>
          <p class="section-copy">
            These breeds are regional or faction-specific and usually exist to support elite troops, specialist roles,
            or a stronger local identity.
          </p>
        </div>

        <div class="card-grid">
          {
            factionBreeds.map((race) => (
              <article class:list={['entry-card', 'is-shadow', { 'is-planned-card': race.status === 'planned' }]}>
                <div class="entry-head">
                  <h3>{race.name}</h3>
                  {race.tags && (
                    <div class="entry-tags">
                      {race.tags.map((tag) => (
                        <span
                          class:list={[
                            'meta-pill',
                            tag.kind === 'faction' ? 'is-faction' : '',
                            tag.tone ? `is-${tag.tone}` : 'is-current',
                          ]}
                        >
                          {tag.label}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <p>{race.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Beast Registry</p>
            <h2>Planned Creatures</h2>
          </div>
          <p class="section-copy">
            Large units, mounts, war beasts, and battlefield assets intended to expand tactical variety and faction
            flavor without becoming universal across every realm.
          </p>
        </div>

        <div class="creature-stack">
          {
            creatureSections.map((section) => (
              <section class="creature-section">
                <div class="creature-heading">
                  <div>
                    <p class="creature-kicker">{section.kicker}</p>
                    <h3>{section.title}</h3>
                  </div>
                  <span class="creature-count">{section.cards.length} entries</span>
                </div>

                <div class="card-grid">
                  {section.cards.map((creature) => (
                    <article
                      class:list={[
                        'entry-card',
                        'is-creature',
                        { 'is-planned-card': creature.status === 'planned', 'is-wip-card': creature.status === 'wip' },
                      ]}
                    >
                      <div class="entry-head">
                        <h4>{creature.name}</h4>
                        {creature.tags && (
                          <div class="entry-tags">
                            {creature.tags.map((tag) => (
                              <span
                                class:list={[
                                  'meta-pill',
                                  tag.kind === 'faction' ? 'is-faction' : '',
                                  tag.tone ? `is-${tag.tone}` : 'is-current',
                                ]}
                              >
                                {tag.label}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                      <p>{creature.text}</p>
                    </article>
                  ))}
                </div>
              </section>
            ))
          }
        </div>

        <div class="callout-grid">
          <article class="callout is-warning">
            <p class="callout-kicker">Under Consideration</p>
            <h3>Flying Creatures</h3>
            <p>
              Flying creatures such as Fell Beasts, Great Bats, and Dragons are being considered for the future.
              Bannerlord battle AI still makes airborne units risky because they can disrupt pathfinding, targeting, and
              formation logic, so they are not planned right now.
            </p>
          </article>

          <article class="callout is-info">
            <p class="callout-kicker">Long-Term Scope</p>
            <h3>Future Creature Considerations</h3>
            <p>
              Other long-range possibilities include Were-Wolves, Giant Wolves, Siege Beasts, and wingless dragons in a
              Glaurung-like role. These remain dependent on technical feasibility, gameplay needs, and faction identity.
            </p>
          </article>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  :global(body.taom-races-body) {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(7, 5, 5, 0.74), rgba(7, 5, 5, 0.98)),
      radial-gradient(circle at 14% 12%, rgba(87, 127, 73, 0.14), transparent 24%),
      radial-gradient(circle at 84% 18%, rgba(132, 90, 46, 0.16), transparent 24%),
      linear-gradient(180deg, #15100f 0%, #0d0908 48%, #080606 100%);
    color: #ece4db;
  }

  :global(body.taom-races-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 10, 9, 0.36), rgba(8, 6, 6, 0.84)),
      url('/images/hero-bg.jpg') center top / cover no-repeat;
    opacity: 0.13;
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-races-main) {
    display: block;
  }

  .races-page {
    min-height: 100vh;
    padding: 2rem 0.5rem;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .topbar-wrap {
    max-width: 82.5rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .races-shell {
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    padding: 2.25rem 0.75rem 3.5rem;
    display: grid;
    gap: 1.5rem;
  }

  .page-intro {
    display: grid;
    gap: 0.8rem;
    max-width: 55rem;
  }

  .eyebrow,
  .summary-label,
  .panel-kicker,
  .section-kicker,
  .taxonomy-label,
  .creature-kicker,
  .creature-count,
  .callout-kicker,
  .meta-pill {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .eyebrow,
  .panel-kicker,
  .section-kicker,
  .creature-kicker,
  .callout-kicker {
    color: #c19748;
    font-size: 0.86rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .page-intro h1 {
    margin: 0;
    color: #f2ece4;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: clamp(3.7rem, 8vw, 6rem);
    line-height: 0.92;
    font-weight: 600;
    text-transform: uppercase;
  }

  .intro-copy {
    margin: 0;
    max-width: 48rem;
    color: rgba(238, 228, 219, 0.9);
    font-size: 1.18rem;
    line-height: 1.5;
  }

  .page-breadcrumb {
    color: rgba(214, 199, 176, 0.68);
    font-size: 0.88rem;
  }

  .page-breadcrumb a {
    color: #d7b26c;
    text-decoration: none;
  }

  .page-breadcrumb a:hover {
    text-decoration: underline;
  }

  .races-summary {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .summary-card,
  .taxonomy-panel,
  .briefing-panel,
  .section-block,
  .creature-section,
  .callout {
    border: 1px solid rgba(120, 89, 38, 0.55);
    background:
      linear-gradient(180deg, rgba(16, 12, 10, 0.95), rgba(8, 7, 7, 0.92)),
      linear-gradient(120deg, rgba(160, 111, 51, 0.07), transparent 52%);
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.28),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .summary-card {
    padding: 1.15rem 1.25rem;
    display: grid;
    gap: 0.45rem;
  }

  .summary-label {
    color: rgba(207, 182, 132, 0.85);
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .summary-card strong {
    color: #f6f0e6;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 1;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.95fr);
    gap: 1rem;
  }

  .taxonomy-panel,
  .briefing-panel,
  .section-block,
  .creature-section,
  .callout {
    padding: 1.35rem;
  }

  .panel-heading,
  .section-heading,
  .creature-heading {
    display: flex;
    justify-content: space-between;
