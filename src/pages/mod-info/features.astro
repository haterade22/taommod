---

<BaseLayout title="Features" description="Gameplay systems and custom features powering TAOM">
  <div class="page-content mod-info">
    <nav class="breadcrumb">
      <a href="/mod-info">&larr; Mod Info</a>
    </nav>

    <h1 class="page-title">Features</h1>
    <p class="page-subtitle">The gameplay systems that make every faction, battle, and campaign unique</p>

    {categories.map(cat => (
      <section class="feature-category">
        <h2 class="category-title">{cat.category}</h2>
        <div class="features-grid">
          {cat.features.map(f => (
            <div class="feature-card">
              <div class="feature-header">
                <h3>{f.title}</h3>
                {f.status === 'live' && <span class="status-badge live">Live</span>}
                {f.status === 'wip' && <span class="status-badge wip">In Development</span>}
              </div>
              <p class="feature-desc">{f.desc}</p>
              <ul class="feature-details">
                {f.details.map(d => (
                  <li>{d}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .mod-info {
    max-width: 1100px;
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-top: -0.5rem;
    margin-bottom: 2.5rem;
  }

  .feature-category {
    margin-bottom: 2.5rem;
  }

  .category-title {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
    gap: 1rem;
