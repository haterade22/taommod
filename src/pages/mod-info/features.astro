---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Coding Features" description="Technical features and custom systems in TAOM">
  <div class="page-content mod-info">
    <h1 class="page-title">Coding Features</h1>
    <div class="coming-soon">
      <p>Content coming soon.</p>
      <a href="/mod-info" class="btn btn-secondary">&larr; Back to Mod Info</a>
    </div>
  </div>
</BaseLayout>

<style>
  .mod-info {
    max-width: 1100px;
  }

  .coming-soon {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .coming-soon a {
    display: inline-block;
    margin-top: 1.5rem;
  }
</style>
