---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Feature {
  title: string;
  desc: string;
  details: string[];
  status?: 'live' | 'wip';
}

interface FeatureCategory {
  category: string;
  features: Feature[];
}

const categories: FeatureCategory[] = [
  {
    category: 'Strategic Campaign Systems',
    features: [
      {
        title: 'War Momentum System',
        desc: 'Victory is earned through meaningful military campaigns, not just conquest grinding. A momentum tracker measures each faction\'s strategic dominance across the campaign map.',
        details: [
          'Four event types build momentum: battle victories, siege conquests, village raids, and army mustering',
          'Momentum decays over 21 days — factions must sustain pressure to win',
          'Player involvement multiplies momentum by 1.5x — your actions matter',
          'Victory requires player participation in 5+ major events',
          'Soft-cap display formula prevents runaway snowballing',
          'All 16 cultures balanced with equal multipliers',
        ],
        status: 'live',
      },
      {
        title: 'Garrison Patrol System',
        desc: 'AI garrisons no longer sit idle behind walls. Settlements actively patrol surrounding territory, creating a living, breathing war front.',
        details: [
          'Settlements spawn patrol parties from their garrison (30% patrol, 70% stay)',
          'Configurable patrol radius — up to 100 units for major fortresses',
          'Max 1-2 patrol parties per settlement with 16-hour patrol cycles',
          'Minimum 70-troop garrison before patrols are dispatched',
          'Applies to castles, towns, and major cities',
        ],
        status: 'live',
      },
      {
        title: 'Startup Influence Distribution',
        desc: 'Every faction starts with meaningful political influence, ensuring even small kingdoms like Rivendell or Lothlorien can participate in council decisions from day one.',
        details: [
          'Major power centers (Rivendell, Lothlorien, Gundabad, Isengard) start with 2,000 influence',
          'Mid-tier factions like Rhun start with 1,000',
          'Prevents early-game influence starvation for smaller factions',
        ],
        status: 'live',
      },
      {
        title: 'Regional Bandit Factions',
        desc: 'Outlaws aren\'t generic — each region spawns culturally distinct bandits with unique equipment, fighting styles, and regional strongholds across Middle-earth.',
        details: [
          '77 bandit NPC templates across 7 regional variants',
          'Sea Raiders (Rohan coast), Gondor Bandits, Pale Uruk Bandits, Mountain/Forest/Desert/Steppe Bandits',
          'Each variant has 12-15 unique equipment loadouts with regional weapons',
          'Bandit boss parties for each region with elite troops',
          'Looters and deserters as low-tier universal bandits',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Battle & Combat Systems',
    features: [
      {
        title: 'Enhanced Auto-Resolve',
        desc: 'A completely overhauled battle resolution system with seven weighted factors, replacing vanilla\'s simplistic strength comparison with deep tactical calculations.',
        details: [
          'Troop Count (1.5x weight) — army size is the most important factor',
          'Troop Quality (1.3x weight) — elite tier troops have real advantages',
          'Special Units (1.3x weight) — rock-paper-scissors counter system',
          'Terrain Effects (1.0x weight) — environment bonuses for unit types',
          'Culture Bonuses (1.0x weight) — racial and cultural combat strengths',
          'Commander Skills (1.0x weight) — leadership matters',
          'Morale (0.9x weight) — army morale state affects outcomes',
        ],
        status: 'live',
      },
      {
        title: 'Culture Combat Matchups',
        desc: '30+ lore-driven tactical matchups that make every faction fight differently. Isengard\'s Uruks are bred to counter Rohan\'s cavalry; Elves devastate Mordor\'s hordes.',
        details: [
          'Dunland vs Rohan: +15% attack (historical hatred of the Rohirrim)',
          'Isengard vs Rohan: +15% attack, +8% defense (Uruks bred to counter cavalry)',
          'Elves vs Mordor: +20% attack, +15% defense (ancient enmity)',
          'Dwarves vs Mordor: +15% attack, +20% defense (siege expertise)',
          'Gondor vs Mordor: +10% attack, +15% defense (ancestral duty)',
          'Matchups include morale effects — some fights inspire or terrify',
        ],
        status: 'live',
      },
      {
        title: 'Casualty & Mercy System',
        desc: 'Death rates vary by culture alignment. Evil factions execute the wounded; good factions provide medical care — creating fundamentally different army growth rates.',
        details: [
          'Global death rate: 60-70% (vs vanilla 20-40%) — combat is brutal',
          'Evil cultures (Mordor, Dol Guldur): only 40% survival rate — orcs execute prisoners',
          'Good cultures (Gondor, Elves): 70-80% survival — medical care preserves troops',
          'Siege battles: 80% of base casualties (walls provide some protection)',
          'Hideout raids: 60-70% base = higher casualty ambushes',
          'Heroes never die by default — protect your lords',
        ],
        status: 'live',
      },
      {
        title: 'Faction Battle AI',
        desc: 'When enabled, each faction fights with a distinct tactical personality. Rohan charges with cavalry, Erebor holds shield walls, Mirkwood skirmishes from range — battles feel different every time.',
        details: [
          'Culture-specific army compositions drive AI tactics automatically',
          'Rohan: aggressive cavalry charges with heavy rider emphasis (25-60 elite cavalry)',
          'Gondor/Lossarnach: disciplined shield walls and defensive infantry formations',
          'Mirkwood/Lothlorien: ranged harassment with heavy archer emphasis (10-60 archers)',
          'Dunland: guerrilla hit-and-run tactics with skirmisher/raider focus',
          'Mordor/Dol Guldur: aggressive melee swarms with overwhelming orc numbers',
          'Erebor: slow-moving heavy dwarf formations with axe and hammer specialization',
        ],
        status: 'live',
      },
      {
        title: '81 Battle Terrain Scenes',
        desc: 'Battles take place on terrain that matches the campaign map location. Fight across plains, deserts, swamps, mountains, and forests — each with distinct tactical advantages.',
        details: [
          '81 battle terrain scenes mapped to specific map regions',
          'Terrain types: Plains (40 scenes), Steppe (27), Desert (8), Swamp (6)',
          'Forest density modifiers (low/high) affect visibility and archery',
          'Mountain, river, canyon, and lake features shape battlefield flow',
          'Map indices tie each scene to specific settlements for geographic accuracy',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Race & Creature Systems',
    features: [
      {
        title: '12 Playable Races',
        desc: 'Play as Dwarves, Orcs, Uruk-hai, and more with correct proportions, animations, voices, and camera heights. Not just cosmetic — races affect gameplay.',
        details: [
          'Full race system: Human, Dwarf, Elf, Orc, Uruk, Uruk-Hai, Berserker, Cave Troll, Half-Troll, Goblin, Hill Troll, Pale Uruk',
          '58 body property templates defining racial characteristics',
          'Race-specific body proportions, action sets, and skeleton scaling',
          'Correct eye height and camera positioning per race',
          'Race data persists across save/load cycles',
          'Character creation supports all custom races',
        ],
        status: 'live',
      },
      {
        title: 'Race-Based Perk System',
        desc: 'Character perks scale differently per race. Dwarves excel at smithing, Elves dominate archery, Trolls are unstoppable two-handed fighters — every race has a playstyle.',
        details: [
          '12 races with unique multipliers across 156+ perks',
          'Dwarves: +30% smithing, +20% crafting perks',
          'Elves: +30-40% archery bonuses',
          'Trolls: +80-100% two-handed bashing, -30% tactics',
          'Orcs/Uruks: strength bonuses, social skill penalties',
          'Covers all 16 skill trees: One-Handed through Steward',
          'Fully configurable via JSON — moddable by sub-modders',
        ],
        status: 'live',
      },
      {
        title: 'Warg Riders & Creature Units',
        desc: 'Command fantasy creatures in battle. Warg riders serve as savage cavalry for orc factions, while cave trolls and half-trolls tower over the battlefield as living siege engines.',
        details: [
          'Warg riders for Gundabad, Dol Guldur, and Isengard with unique saddle equipment',
          'Cave Trolls: 4.0x unit weight — massive impact on party movement and supply',
          'Half-Trolls: monstrous warriors wielding two-handed mauls',
          'Warg units at 2.0x weight — heavier than standard cavalry',
          'Creature units have unique racial perk multipliers in combat',
        ],
        status: 'live',
      },
      {
        title: 'Troop Weight System',
        desc: 'Not all units are equal in logistics. Heavy creatures slow your army and consume more supplies, forcing strategic decisions about army composition.',
        details: [
          'Cave Trolls: 4.0x weight (massive supply drain)',
          'Elven units: 2.0x weight (elite soldiers require more resources)',
          'Warg Riders: 2.0x weight (creature mounts are expensive)',
          'Standard troops: 1.0x weight baseline',
          'Affects party movement speed and supply consumption',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Faction & Culture Systems',
    features: [
      {
        title: '16 Unique Factions',
        desc: 'Every faction plays fundamentally differently thanks to culture-specific combat profiles, economic bonuses, and military strengths drawn from Tolkien lore.',
        details: [
          'Erebor: +15% infantry attack, +30% defense, +35% rout resistance — impenetrable formations',
          'Rohan: +15% cavalry attack, +12% charge bonus — open field dominance',
          'Lothlorien: Highest archer bonus (+35%), elite all-around — strongest elite troops',
          'Isengard: +22% infantry attack, +25% rout resistance — disciplined shock troops',
          'Rhun: +25% horse archer attack, +20% open field — steppe cavalry masters',
          'Dunland: +20% infantry attack, +20% morale — berserker tactics',
        ],
        status: 'live',
      },
      {
        title: 'Four-Tier Recruitment',
        desc: 'Armies are built from Regular, Noble, Regional, and Unique troop tiers. Regional units are tied to specific homelands, and Unique troops are locked to one or two key settlements.',
        details: [
          'Regular troops (40-50%): available everywhere in faction territory',
          'Noble troops (10-20%): globally recruitable but rare',
          'Regional troops (30-40%): tied to specific cities, castles, or villages',
          'Unique troops: locked to 1-2 key settlements — control them or lose access',
          'Encourages strategic expansion into key regions',
        ],
        status: 'live',
      },
      {
        title: 'Settlement-Based Recruitment',
        desc: 'Recruitment follows a Settlement > Clan > Culture hierarchy. Travel to specific regions to recruit their troops — Pelargir fields marines, Lossarnach musters axemen, the Wold breeds riders.',
        details: [
          '69+ settlement-specific and clan-specific party templates',
          'Pelargir: heavy marine/naval focus (sailors, marines, archers)',
          'Lossarnach: pure infantry emphasis (axemen, heavy axemen, wrathbearers)',
          'Rohan settlements: cavalry-dominant armies (6 cavalry types, minimal infantry)',
          'Erebor variants: axe-focus or spear-focus specialization templates',
          'Clan lords inherit recruitment pools from their assigned settlement template',
          'Regional recruitment cost bonuses: Dunland infantry 25% cheaper, Erebor infantry 15% cheaper',
        ],
        status: 'live',
      },
      {
        title: 'Culture Economic Bonuses',
        desc: 'Faction identity extends beyond the battlefield. Some cultures have cheaper garrisons, siege discounts, or influence penalties that shape long-term strategy.',
        details: [
          'Wage reductions: some cultures maintain garrisons 20-25% cheaper',
          'Siege discounts: Erebor and Isengard get 20-25% cheaper siege equipment',
          'Morale bonuses: Dunland gets +20% morale in battles',
          'Influence penalties: Lothlorien gets -25% influence from battles — elves care less for politics',
        ],
        status: 'live',
      },
      {
        title: 'Culture-Specific Caravans',
        desc: 'Trade caravans are customized per faction with culture-appropriate equipment and leaders, making the economic layer feel authentically Middle-earth.',
        details: [
          '7 caravan leader templates with culture-specific gear',
          'Faction-appropriate weapons: Eastern spears for Rhun, noble swords for Harad',
          'Caravan guards drawn from local troop pools',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Audio & Immersion',
    features: [
      {
        title: 'Custom Voice Acting',
        desc: 'Races don\'t just look different — they sound different. 750+ custom audio files bring Uruk-hai battle cries, Dwarf war chants, and creature roars to life.',
        details: [
          '302 custom sound entries across 5 audio categories',
          'Isengard/Uruk-hai: 207 sounds — deaths, grunts, yells, laughs, victory cries, attack commands',
          'Dwarf: 118 unique voice lines for combat and ambient dialogue',
          'Monster/creature sounds: 242 audio files for trolls, wargs, and beasts',
          'Rohan: 176 sounds including culture-specific horn calls',
          'Custom Lurtz voice samples for Isengard characters',
        ],
        status: 'live',
      },
      {
        title: 'Custom Music',
        desc: 'The vanilla Bannerlord soundtrack is replaced with a Middle-earth score. Custom LOTR-inspired tracks set the tone from the main menu onward.',
        details: [
          'Custom main menu theme replaces vanilla title screen music',
          '6+ original soundtrack tracks',
          'Music system integrated via XSLT transformation',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Content & World',
    features: [
      {
        title: 'Custom Middle-earth Map',
        desc: '658 settlements placed across a sprawling Middle-earth, from the Shire to Mordor. Region-appropriate battle terrain ensures every fight feels geographically authentic.',
        details: [
          '658 named settlements (towns, castles, villages) across all 16 faction territories',
          '81 battle scene definitions mapped to terrain types (plains, steppe, desert, swamp)',
          'Forest density variation and special terrain features',
          'Distance cache for optimized pathfinding across the massive map',
        ],
        status: 'live',
      },
      {
        title: '648 Custom Troop Types',
        desc: 'Every faction fields a unique military with culture-specific troops, equipment, and upgrade paths. 648 distinct unit types across 338 party templates create armies that feel authentically Middle-earth.',
        details: [
          '648 unique troop types across all 16 factions',
          '338 party templates defining militia, garrison, bandit, and army compositions',
          '1,260 troop composition entries controlling unit ratios per party',
          'Culture-specific party templates: villagers, militia, garrison, patrols',
          '198 equipment rosters with culture-appropriate armor and weapons',
        ],
        status: 'live',
      },
      {
        title: '500+ Custom Lords & Heroes',
        desc: 'Every lord and hero replaced with a Tolkien-inspired character. 504 lords with custom skills and traits, 415 heroes with biographies, 149 wanderer companions.',
        details: [
          '504 lords with custom appearances, skills, and trait distributions',
          '415 heroes with lore-accurate biographies',
          '149 wanderer companions (10 archetypes per kingdom)',
          '73+ clans with custom names and banner keys',
          'Gender-balanced where lore-appropriate',
        ],
        status: 'live',
      },
      {
        title: '453 Custom Banner Icons',
        desc: 'Hundreds of custom banner designs drawn from Tolkien heraldry. Every kingdom and clan has a lore-accurate insignia that persists across save/load cycles.',
        details: [
          '453 custom banner icons across 3+ icon packs',
          'Auto-applies 73+ custom clan/kingdom banners every session',
          'Detects when players manually edit banners and respects those changes',
          'Visual invalidation ensures war parties update immediately',
          'Lore-accurate designs: White Tree of Gondor, Eye of Sauron, and more',
        ],
        status: 'live',
      },
      {
        title: 'Custom Items & Equipment',
        desc: 'Uruk-hai crossbows, faction-specific armor sets, and lore-accurate weapons replace vanilla gear. Each culture equips troops with gear that matches their identity.',
        details: [
          '20+ custom Uruk-hai items: crossbows, helms, armor, shoulder guards',
          '198 equipment rosters for battle, civilian, and noble loadouts',
          'Culture-specific crafting templates for Uruk pikes, swords, and polearms',
          'Detailed weapon stats: damage, speed, weight, accuracy, missile speed',
          'Named hero equipment sets (Boromir, Faramir, and more)',
        ],
        status: 'live',
      },
      {
        title: 'Settlement Locations',
        desc: 'Towns, castles, and villages feature expanded interior locations. Visit taverns, arenas, lord\'s halls, and dungeons — each with prosperity-scaled population.',
        details: [
          '21 location types across 5 settlement complex templates',
          'Towns: 8 locations — center, arena, tavern, alley, lord\'s hall, prison, houses',
          'Castles: 3 locations — courtyard, lord\'s hall, dungeon',
          'Lord\'s halls scale with prosperity (up to 3 difficulty levels)',
          '16 passage connections between town locations',
        ],
        status: 'live',
      },
    ],
  },
  {
    category: 'Character & Progression',
    features: [
      {
        title: 'Culture Education Paths',
        desc: 'Character backstory and development are culture-specific. Choose from 6 branching education paths during character creation, each tied to a Middle-earth culture.',
        details: [
          '61 education character templates across 6 cultures',
          'Cultures: Mordor, Gondor, Erebor, Rivendell, Mirkwood, Dol Guldur',
          '6 branches per culture with unique skill and equipment progressions',
          '1,976 equipment roster configurations for development stages',
          'Culture-appropriate armor sets reflect your character\'s origin',
        ],
        status: 'live',
      },
      {
        title: '14 Language Localization',
        desc: 'Play TAOM in your language. Full localization support across 14 languages covers all custom culture names, troop types, lord names, and UI text.',
        details: [
          '14 languages: English, German, French, Spanish, Italian, Polish, Russian, Turkish, Japanese, Korean, Brazilian Portuguese, Simplified Chinese, Traditional Chinese, and more',
          '29 localization XML files covering all custom content',
          'Culture definitions, clan names, kingdom names, troop types all translated',
          'Special character support for non-Latin scripts',
        ],
        status: 'live',
      },
    ],
  },
];
---

<BaseLayout title="Features" description="Gameplay systems and custom features powering TAOM">
  <div class="page-content mod-info">
    <nav class="breadcrumb">
      <a href="/mod-info">&larr; Mod Info</a>
    </nav>

    <h1 class="page-title">Features</h1>
    <p class="page-subtitle">The gameplay systems that make every faction, battle, and campaign unique</p>

    {categories.map(cat => (
      <section class="feature-category">
        <h2 class="category-title">{cat.category}</h2>
        <div class="features-grid">
          {cat.features.map(f => (
            <div class="feature-card">
              <div class="feature-header">
                <h3>{f.title}</h3>
                {f.status === 'live' && <span class="status-badge live">Live</span>}
                {f.status === 'wip' && <span class="status-badge wip">In Development</span>}
              </div>
              <p class="feature-desc">{f.desc}</p>
              <ul class="feature-details">
                {f.details.map(d => (
                  <li>{d}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .mod-info {
    max-width: 1100px;
  }

  .breadcrumb {
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-top: -0.5rem;
    margin-bottom: 2.5rem;
  }

  .feature-category {
    margin-bottom: 2.5rem;
  }

  .category-title {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
    gap: 1rem;
  }

  .feature-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.25rem;
  }

  .feature-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .feature-header h3 {
    color: var(--text-primary);
    font-size: 1.05rem;
    margin: 0;
  }

  .status-badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .status-badge.live {
    background: rgba(76, 175, 80, 0.2);
    color: #4CAF50;
  }

  .status-badge.wip {
    background: rgba(255, 167, 38, 0.2);
    color: #FFA726;
  }

  .feature-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .feature-details {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .feature-details li {
    color: var(--text-secondary);
    font-size: 0.82rem;
    line-height: 1.5;
    padding: 0.2rem 0 0.2rem 1.2rem;
    position: relative;
  }

  .feature-details li::before {
    content: '\2022';
    color: var(--accent-dim);
    position: absolute;
    left: 0.2rem;
  }

  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
