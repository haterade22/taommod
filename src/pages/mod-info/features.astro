---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Feature {
  title: string;
  desc: string;
  details: string[];
  status?: 'live' | 'wip';
}

interface FeatureCategory {
  category: string;
  features: Feature[];
}

const categories: FeatureCategory[] = [
  {
    category: 'Strategic AI & Diplomacy',
    features: [
      {
        title: 'AI Strategic Intelligence',
        desc: 'A full strategic AI engine that evaluates military, economic, diplomatic, and cultural factors to drive faction decision-making. Each faction leader has a unique personality that shapes their strategy.',
