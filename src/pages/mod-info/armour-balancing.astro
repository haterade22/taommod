            <tr><td>Medium</td><td>24</td><td>2.5</td><td>Chainmail</td></tr>
            <tr><td>Heavy</td><td>32</td><td>3.5</td><td>Plate</td></tr>
            <tr><td>Elite</td><td>40</td><td>4.5</td><td>Plate</td></tr>
            <tr><td>Lord</td><td>48</td><td>5.0</td><td>Plate</td></tr>
          </tbody>
        </table>
      </div>

      <h3>Arm Armour</h3>
      <div class="table-wrapper">
        <table class="baseline-table">
          <thead>
            <tr><th>Tier</th><th>Arm</th><th>Weight</th><th>Material</th></tr>
          </thead>
          <tbody>
            <tr><td>Civilian</td><td>3</td><td>0.3</td><td>Cloth</td></tr>
            <tr><td>Light</td><td>8</td><td>0.6</td><td>Leather</td></tr>
            <tr><td>Medium</td><td>14</td><td>1.0</td><td>Chainmail</td></tr>
            <tr><td>Heavy</td><td>20</td><td>1.5</td><td>Plate</td></tr>
