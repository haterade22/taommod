<style>
  .mod-info {
    max-width: 1200px;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .info-section {
    margin-bottom: 3rem;
  }

  .info-section h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(212, 162, 76, 0.3);
    padding-bottom: 0.5rem;
  }

  .section-desc {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* Formula section */
  .formula-box {
    background: rgba(212, 162, 76, 0.1);
    border: 1px solid rgba(212, 162, 76, 0.3);
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .formula-box code {
    font-size: 1.05rem;
    color: var(--accent);
    font-weight: 600;
  }

  .formula-details {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .detail-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 1.25rem;
  }
  .detail-card h3 {
    color: var(--accent);
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }
  .detail-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Comparison table */
  .table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .comparison-table, .baseline-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .comparison-table th, .comparison-table td,
  .baseline-table th, .baseline-table td {
    padding: 0.5rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
  }

  .comparison-table th, .baseline-table th {
    background: rgba(212, 162, 76, 0.15);
    color: var(--accent);
    font-weight: 600;
    position: sticky;
    top: 0;
  }

  .comparison-table tbody tr:hover, .baseline-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .center { text-align: center; }
  .skill-col { text-align: center; min-width: 40px; }

  .mod-pos { color: #5dae5d; font-weight: 600; }
  .mod-neg { color: #d46a6a; font-weight: 600; }
  .mod-zero { color: rgba(255, 255, 255, 0.3); }

  .culture-cell {
    font-weight: 600;
  }
  .culture-cell a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
  }
  .culture-cell a:hover { text-decoration: underline; }

  /* Culture cards */
  .culture-card {
    border-radius: 10px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .culture-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .culture-header h3 {
    color: var(--accent);
    font-size: 1.35rem;
    margin: 0;
  }

  .culture-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .culture-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .culture-identity {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .modifiers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .mod-section {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    padding: 1rem;
  }
  .mod-section.strengths { border-top: 2px solid rgba(93, 174, 93, 0.4); }
  .mod-section.weaknesses { border-top: 2px solid rgba(212, 106, 106, 0.4); }

  .mod-section h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .strengths h4 { color: #5dae5d; }
  .weaknesses h4 { color: #d46a6a; }

  .mod-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mod-section li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
    font-size: 0.875rem;
  }

  .mod-skill {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    min-width: 90px;
  }
  .mod-value {
    font-weight: 700;
    font-family: monospace;
    min-width: 40px;
  }
  .mod-value.pos { color: #5dae5d; }
  .mod-value.neg { color: #d46a6a; }
  .mod-note {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .culture-groups {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }
  .culture-groups strong { color: rgba(255, 255, 255, 0.7); }

  .culture-notes {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
    font-style: italic;
    line-height: 1.6;
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Baseline tables */
  .info-section h3 {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    margin: 1.5rem 0 0.75rem;
  }

  .baseline-table td {
    text-align: center;
    font-family: monospace;
    font-size: 0.8rem;
  }
  .baseline-table td:first-child {
    font-weight: 600;
    color: var(--accent);
    text-align: left;
  }

  @media (max-width: 768px) {
    .culture-header { flex-direction: column; align-items: flex-start; }
    .modifiers-grid { grid-template-columns: 1fr; }
    .formula-details { grid-template-columns: 1fr; }
  }

  .section-toggle {
    cursor: pointer;
    user-select: none;
  }

  .section-toggle:hover {
    color: var(--text-primary);
  }

  .collapse-arrow {
    display: inline-block;
    font-size: 0.8em;
    transition: transform 0.2s;
  }
</style>

<script>
  document.querySelectorAll('.section-toggle').forEach(title => {
    title.addEventListener('click', () => {
      const section = title.closest('.collapsible-section') as HTMLElement;
      const content = section.querySelector('.collapsible-content') as HTMLElement;
      const arrow = title.querySelector('.collapse-arrow')!;
      const collapsed = section.dataset.collapsed === 'true';
      section.dataset.collapsed = collapsed ? 'false' : 'true';
      content.style.display = collapsed ? '' : 'none';
      arrow.textContent = collapsed ? '\u25BC' : '\u25B6';
    });
  });
</script>
