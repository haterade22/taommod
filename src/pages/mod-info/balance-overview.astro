      { name: 'Rohan', color: '#6db36d', reason: '13 ranged troops — Wold Scout/Horse Archer line (5 tiers of mounted archers), Eastfold Skirmisher/Bowman/Veteran Bowman (foot archers). Strong horse archer tradition' },
    ],
  },
  {
    tier: 'B', color: '#6a9fd4', label: 'Competent',
    cultures: [
      { name: 'Isengard', color: '#a0a0a0', reason: '11 ranged troops — Uruk Crossbowman/Veteran Crossbowman/Arbalest/Chosen Marksman (crossbow), Scout/Skirmisher/Hunter/Tracker/Archer (bow). Heavy crossbow focus' },
      { name: 'Harad', color: '#c43c3c', reason: '9 ranged troops — Skirmisher/Archer/Marksman/Vipereye/Serpent Eye (bow), Horse Archer/Serpent Horse Archer (mounted bow). Mix of foot and mounted archers' },
      { name: 'Erebor', color: '#6a9fd4', reason: '9 ranged troops — Scout/Archer/Veteran Archer (bow), Iron Hills Arbalest/Veteran Arbalest/Iron Tusk Sharpshooters (crossbow), plus Scout. Crossbow specialty' },
      { name: 'Rhun', color: '#d4a24c', reason: '8 ranged troops — Watcher/Archer/Marksman (bow), Horse Archer/Shadowguard/Sunbow/Eye/Eye of the Waste (mounted bow). Horse archer tradition' },
      { name: 'Gundabad', color: '#7a8a9a', reason: '8 ranged troops — Hunter/Scout (bow), Despoiler of the Vale/Lurker/Sentry/Archer (bow). All foot archers, no mounted' },
    ],
  },
  {
    tier: 'C', color: '#a0a0a0', label: 'Weak',
    cultures: [
      { name: 'Mordor', color: '#b44444', reason: '4 ranged troops only — Uruk Scout/Marksman (bow), 2 militia archers. Very limited ranged options for such a large faction' },
      { name: 'Mirkwood', color: '#4a9e6d', reason: '5 ranged troops — Sentinels/Borderwardens/Thingolheir (elite bow), 2 militia. Few but extremely skilled (Bow+50)' },
      { name: 'Rivendell', color: '#7ec8e3', reason: '9 ranged troops — Recruit/Bowman/Archer/Marksman/Marchwarden (bow), Horse Archer/Rider of Himring (mounted). Elven accuracy compensates for numbers' },
      { name: 'Umbar', color: '#5a8a8a', reason: '4 ranged troops in small roster. Weapons not yet implemented' },
    ],
  },
];

// Grade color mapping
const gradeColors: Record<string, string> = {
  'S+': '#ff9800',
  'S': '#d4a24c',
  'A': '#5dae5d',
  'B': '#6a9fd4',
  'C': '#a0a0a0',
  'D': '#d46a6a',
  '—': 'rgba(255,255,255,0.2)',
};
---

<BaseLayout title="Balance Overview" description="Comprehensive faction power rankings across troop skills, armor, and weapons">
  <div class="page-content mod-info">
    <nav class="breadcrumb"><a href="/mod-info">Mod Info</a> / Balance Overview</nav>
    <h1 class="page-title">Balance Overview</h1>

    <section class="info-section">
      <h2>The Balance Triangle</h2>
      <p class="section-desc">
        Every faction in TAOM is balanced across <strong>three axes</strong>: troop skills, armor protection, and weapon damage.
        Factions strong in one axis are deliberately weaker in others, creating asymmetric but balanced gameplay.
        No faction dominates all three — except elves, who are <strong>intentionally elite</strong> and balanced by extreme rarity and cost.
      </p>
      <div class="triangle-visual">
        <div class="triangle-axis">
          <div class="axis-icon">&#9876;</div>
          <div class="axis-info">
            <strong>Troop Skills</strong>
            <span>Cultural modifiers to combat skills — affects hit chance, block ability, and movement speed</span>
          </div>
        </div>
        <div class="triangle-axis">
          <div class="axis-icon">&#128737;</div>
          <div class="axis-info">
            <strong>Armor Protection</strong>
            <span>Cultural protection bonuses and weight multipliers — affects damage taken and mobility</span>
          </div>
        </div>
        <div class="triangle-axis">
          <div class="axis-icon">&#9876;</div>
          <div class="axis-info">
            <strong>Weapon Damage</strong>
            <span>Cultural damage_factor modifiers — affects raw damage output per hit</span>
          </div>
        </div>
      </div>
    </section>

    <section class="info-section">
      <h2>Faction Power Comparison</h2>
      <p class="section-desc">
        Grades reflect relative strength within each axis. <strong>S</strong> = dominant, <strong>A</strong> = strong, <strong>B</strong> = solid, <strong>C</strong> = below average, <strong>D</strong> = weak.
        See individual balancing pages for detailed numbers.
      </p>
      <div class="table-wrapper">
        <table class="power-table">
          <thead>
            <tr>
              <th>Culture</th>
              <th>Race</th>
              <th class="grade-col">Troops</th>
              <th class="grade-col">Armor</th>
              <th class="grade-col">Weapons</th>
              <th class="detail-col">Key Strength</th>
            </tr>
          </thead>
          <tbody>
            {cultures.map(c => (
              <tr>
                <td class="culture-cell" style={`border-left: 3px solid ${c.color}`}>
                  <span style={`color: ${c.color}`}>{c.name}</span>
                </td>
                <td class="race-cell">{c.race}</td>
                <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.troops.grade]}`}>{c.troops.grade}</span></td>
                <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.armor.grade]}`}>{c.armor.grade}</span></td>
                <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.weapons.grade]}`}>{c.weapons.grade}</span></td>
                <td class="detail-cell">{c.troops.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="elven-note">
        <h3>* Elven Factions <span class="elven-subtitle">— intentionally elite, balanced by rarity and cost</span></h3>
        <p class="section-desc">
          Elven factions operate on a different power scale. Their troops have +25 to +50 skill bonuses, the best armor in the game,
          and a -20% weapon modifier to compensate. They are balanced by <strong>extremely low population</strong>, high recruitment costs,
          and slow replenishment — not by statistical parity with other factions.
        </p>
        <div class="table-wrapper">
          <table class="power-table elven-table">
            <thead>
              <tr>
                <th>Culture</th>
                <th class="grade-col">Troops</th>
                <th class="grade-col">Armor</th>
                <th class="grade-col">Weapons</th>
                <th class="detail-col">Key Strength</th>
              </tr>
            </thead>
            <tbody>
              {elvenCultures.map(c => (
                <tr>
                  <td class="culture-cell" style={`border-left: 3px solid ${c.color}`}>
                    <span style={`color: ${c.color}`}>{c.name} *</span>
                  </td>
                  <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.troops.grade]}`}>{c.troops.grade}</span></td>
                  <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.armor.grade]}`}>{c.armor.grade}</span></td>
                  <td class="grade-cell"><span class="grade" style={`color: ${gradeColors[c.weapons.grade]}`}>{c.weapons.grade}</span></td>
                  <td class="detail-cell">{c.troops.detail}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="info-section">
      <h2>Infantry Power Rankings</h2>
      <p class="section-desc">
        Ranked by combined melee skill bonuses (1H, 2H, Polearm), Athletics, armor protection, and weapon damage.
        Elven factions would rank S+ across the board but are excluded — they are balanced by population, not by stats.
      </p>
      <h3 class="subsection-title">Overall Infantry</h3>
      {infantryTiers.map(t => (
        <div class="tier-row">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
            <span class="tier-desc">{t.label}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="info-section">
      <h2>Infantry Subcategories</h2>
      <p class="section-desc">
        Infantry is broken down into four combat roles. A faction may excel at one role while being poor at another —
        Dunland's skirmishers are S-tier but their frontline is B-tier, while Erebor dominates every role except skirmishing.
      </p>

      <h3 class="subsection-title">Front Line <span class="role-tag">Shield Wall / Defensive</span></h3>
      <p class="role-desc">1H + Polearm skill, heavy armor protection — troops that hold the line with shield and spear.</p>
      {frontLineTiers.map(t => (
        <div class="tier-row tier-compact">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <h3 class="subsection-title">Shock Troops <span class="role-tag">2H Charge / Berserker</span></h3>
      <p class="role-desc">2H skill + Athletics + weapon damage — troops that charge with two-handed weapons to break formations.</p>
      {shockTroopTiers.map(t => (
        <div class="tier-row tier-compact">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <h3 class="subsection-title">Line Breakers <span class="role-tag">Anti-Armor / Blunt</span></h3>
      <p class="role-desc">Heavy 2H axes and maces — troops with crushing weapons that bypass armor. Blunt damage ignores 60% of armor.</p>
      {lineBreakerTiers.map(t => (
        <div class="tier-row tier-compact">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <h3 class="subsection-title">Skirmishers <span class="role-tag">Javelin / Throwing</span></h3>
      <p class="role-desc">Throwing skill + Athletics — mobile troops that harass with javelins before closing to melee.</p>
      {skirmisherTiers.map(t => (
        <div class="tier-row tier-compact">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="info-section">
      <h2>Cavalry Power Rankings</h2>
      <p class="section-desc">
        Ranked by Riding skill, Polearm/OneHanded combat, armor weight (lighter = faster mounts), and weapon damage.
        Includes both traditional cavalry and warg/beast riders where applicable.
      </p>
      {cavalryTiers.map(t => (
        <div class="tier-row">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
            <span class="tier-desc">{t.label}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="info-section">
      <h2>Ranged Power Rankings</h2>
      <p class="section-desc">
        Ranked by Bow, Crossbow, and Throwing skill bonuses, armor weight (mobility for kiting), and relevant weapon damage.
        Elven factions would dominate — Mirkwood has +50 Bow, Rivendell +40 Bow, Lothlorien +35 Bow.
      </p>
      {archerTiers.map(t => (
        <div class="tier-row">
          <div class="tier-label" style={`background: ${t.color}25; border: 1px solid ${t.color}50; color: ${t.color}`}>
            <span class="tier-letter">{t.tier}</span>
            <span class="tier-desc">{t.label}</span>
          </div>
          <div class="tier-cultures">
            {t.cultures.map(c => (
              <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                <strong style={`color: ${c.color}`}>{c.name}</strong>
                <span class="tier-reason">{c.reason}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="info-section">
      <h2>Detailed Balancing Pages</h2>
      <div class="links-grid">
        <a href="/mod-info/troop-balancing" class="link-card" style="--lc-color: rgba(180, 120, 200, 0.35)">
          <strong>Troop Balancing</strong>
          <span>Cultural skill modifiers, baseline tables, and troop progression for all 16 cultures</span>
        </a>
        <a href="/mod-info/armour-balancing" class="link-card" style="--lc-color: rgba(200, 160, 100, 0.35)">
          <strong>Armour Balancing</strong>
          <span>Protection bonuses, weight multipliers, and tier breakdowns across 17 cultures</span>
        </a>
        <a href="/mod-info/weapon-balancing" class="link-card" style="--lc-color: rgba(220, 130, 130, 0.35)">
          <strong>Weapon Balancing</strong>
          <span>Damage analysis from TaleWorlds physics, cultural modifiers, and per-weapon breakdowns</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .mod-info {
    max-width: 1200px;
  }

  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .info-section {
    margin-bottom: 3rem;
  }

  .info-section h2 {
    color: var(--accent);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(212, 162, 76, 0.3);
    padding-bottom: 0.5rem;
  }

  .section-desc {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .coming-soon {
    background: rgba(212, 162, 76, 0.08);
    border: 1px solid rgba(212, 162, 76, 0.2);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
  }

  /* Triangle visual */
  .triangle-visual {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .triangle-axis {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 1.25rem;
    text-align: center;
  }

  .axis-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .axis-info strong {
    display: block;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .axis-info span {
    color: var(--text-secondary);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  /* Power comparison table */
  .table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .power-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .power-table th, .power-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
  }

  .power-table th {
    background: rgba(212, 162, 76, 0.15);
    color: var(--accent);
    font-weight: 600;
    position: sticky;
    top: 0;
  }

  .power-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .culture-cell {
    font-weight: 600;
    padding-left: 0.75rem !important;
  }

  .race-cell {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .grade-col {
    text-align: center;
    width: 70px;
  }

  .grade-cell {
    text-align: center;
  }

  .grade {
    font-weight: 800;
    font-size: 1rem;
    font-family: monospace;
  }

  .detail-col {
    min-width: 200px;
  }

  .detail-cell {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
    font-family: monospace;
  }

  /* Elven section */
  .elven-note {
    background: rgba(126, 200, 227, 0.05);
    border: 1px solid rgba(126, 200, 227, 0.15);
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  .elven-note h3 {
    color: #7ec8e3;
    font-size: 1.1rem;
    margin: 0 0 0.75rem 0;
  }

  .elven-subtitle {
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(126, 200, 227, 0.6);
  }

  .elven-table {
    font-size: 0.825rem;
  }

  .elven-table th {
    background: rgba(126, 200, 227, 0.1);
    color: #7ec8e3;
  }

  /* Tier rows */
  .tier-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
    min-height: 60px;
  }

  .tier-label {
    flex-shrink: 0;
    width: 80px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.5rem;
  }

  .tier-letter {
    font-size: 1.5rem;
    font-weight: 800;
    font-family: monospace;
    line-height: 1;
  }

  .tier-desc {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
    margin-top: 0.15rem;
  }

  .tier-cultures {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tier-culture {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    flex: 1;
    min-width: 250px;
  }

  .tier-culture strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .tier-reason {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.78rem;
    line-height: 1.4;
  }

  /* Links grid */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: block;
    padding: 1.25rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--lc-color);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .link-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none;
  }

  .link-card strong {
    display: block;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .link-card span {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  /* Subcategory styles */
  .subsection-title {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    margin: 2rem 0 0.5rem;
  }

  .subsection-title:first-of-type {
    margin-top: 0;
  }

  .role-tag {
    font-size: 0.7rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    margin-left: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    vertical-align: middle;
  }

  .role-desc {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.825rem;
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  .tier-compact {
    margin-bottom: 0.5rem;
  }

  .tier-compact .tier-label {
    width: 50px;
    padding: 0.35rem;
  }

  .tier-compact .tier-letter {
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .triangle-visual {
      grid-template-columns: 1fr;
    }
    .tier-row {
      flex-direction: column;
    }
    .tier-label {
      width: 100%;
      flex-direction: row;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
    }
    .tier-letter { font-size: 1.2rem; }
    .tier-culture { min-width: 100%; }
    .links-grid { grid-template-columns: 1fr; }
  }
</style>
