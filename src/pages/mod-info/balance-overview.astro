---

<BaseLayout
  title="Balance Overview"
  description="Comprehensive faction power rankings across troop skills, armor, and weapons"
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-balance-body"
  mainClass="taom-balance-main"
>
  <div class="balance-page">
    <div class="topbar-wrap">
      <Topbar />
    </div>

    <main class="balance-shell">
      <section class="page-intro">
        <p class="eyebrow">Master Ledger of Middle-earth</p>
        <h1>Balance Overview</h1>
        <p class="intro-copy">
          This archive compares how TAOM factions are tuned across troop skill, armor, and weapon quality. Use it as the
          top-level briefing before diving into the dedicated balancing pages for the full formulas and supporting data.
        </p>
        <nav class="page-breadcrumb"><a href="/mod-info">Mod Info</a> / Balance Overview</nav>
      </section>

      <section class="balance-summary" aria-label="Balance overview summary">
        <article class="summary-card">
          <span class="summary-label">Total Cultures</span>
          <strong>{totalCultures}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Standard Realms</span>
          <strong>{cultures.length}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Elven Exceptions</span>
          <strong>{elvenCultures.length}</strong>
        </article>
        <article class="summary-card">
          <span class="summary-label">Balance Axes</span>
          <strong>{axisCards.length}</strong>
        </article>
      </section>

      <section class="overview-grid">
        <article class="triangle-panel">
          <div class="panel-heading">
            <div>
              <p class="panel-kicker">The Balance Triangle</p>
              <h2>Three Forces Shape Every Faction</h2>
            </div>
            <p class="panel-copy">
              No standard faction is meant to dominate troop skill, armor, and weapon output all at once. Strength on
              one edge is usually paid for somewhere else.
            </p>
          </div>

          <div class="triangle-visual">
            {
              axisCards.map((axis) => (
                <article class="triangle-axis">
                  <span class="axis-icon">{axis.icon}</span>
                  <strong>{axis.title}</strong>
                  <p>{axis.detail}</p>
                </article>
              ))
            }
          </div>
        </article>

        <article class="briefing-panel">
          <div class="panel-heading">
            <div>
              <p class="panel-kicker">How To Read It</p>
              <h2>Use The Overview Like A Dossier</h2>
            </div>
            <p class="panel-copy">
              Start broad, then narrow down by battlefield role. The deeper pages are there when you need exact stat
              logic rather than just the faction-to-faction picture.
            </p>
          </div>

          <div class="reading-steps">
            {
              readingSteps.map((item) => (
                <div class="reading-step">
                  <span class="reading-step-number">{item.step}</span>
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.detail}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </article>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Faction Ledger</p>
            <h2>Power Comparison</h2>
          </div>
          <p class="section-copy">
            Grades represent relative strength within each axis. S means dominant, A strong, B solid, C below average,
            and D weak.
          </p>
        </div>

        <div class="comparison-layout">
          <article class="table-card">
            <div class="table-card-head">
              <p class="table-kicker">Standard Realms</p>
              <span class="table-count">{cultures.length} cultures</span>
            </div>

            <div class="table-wrapper">
              <table class="power-table">
                <thead>
                  <tr>
                    <th>Culture</th>
                    <th>Race</th>
                    <th class="grade-col">Troops</th>
                    <th class="grade-col">Armor</th>
                    <th class="grade-col">Weapons</th>
                    <th class="detail-col">Key Strength</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    cultures.map((c) => (
                      <tr>
                        <td class="culture-cell" style={`border-left: 3px solid ${c.color}`}>
                          <span style={`color: ${c.color}`}>{c.name}</span>
                        </td>
                        <td class="race-cell">{c.race}</td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.troops.grade]}`}>
                            {c.troops.grade}
                          </span>
                        </td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.armor.grade]}`}>
                            {c.armor.grade}
                          </span>
                        </td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.weapons.grade]}`}>
                            {c.weapons.grade}
                          </span>
                        </td>
                        <td class="detail-cell">{c.troops.detail}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </article>

          <aside class="elven-note">
            <div class="table-card-head">
              <p class="table-kicker">Elven Exception</p>
              <span class="table-count">{elvenCultures.length} cultures</span>
            </div>
            <h3>Elite By Design</h3>
            <p class="section-desc">
              Elven factions sit on a different power scale. Their troops, armour, and weapons are intentionally
              stronger, then balanced by rarity, cost, and slower replenishment rather than by numerical parity.
            </p>
            <div class="table-wrapper">
              <table class="power-table elven-table">
                <thead>
                  <tr>
                    <th>Culture</th>
                    <th class="grade-col">Troops</th>
                    <th class="grade-col">Armor</th>
                    <th class="grade-col">Weapons</th>
                    <th class="detail-col">Key Strength</th>
                  </tr>
                </thead>
                <tbody>
                  {
                    elvenCultures.map((c) => (
                      <tr>
                        <td class="culture-cell" style={`border-left: 3px solid ${c.color}`}>
                          <span style={`color: ${c.color}`}>{c.name}</span>
                        </td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.troops.grade]}`}>
                            {c.troops.grade}
                          </span>
                        </td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.armor.grade]}`}>
                            {c.armor.grade}
                          </span>
                        </td>
                        <td class="grade-cell">
                          <span class="grade" style={`color: ${gradeColors[c.weapons.grade]}`}>
                            {c.weapons.grade}
                          </span>
                        </td>
                        <td class="detail-cell">{c.troops.detail}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </aside>
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Role Archives</p>
            <h2>Battlefield Rankings</h2>
          </div>
          <p class="section-copy">
            These dossiers break the triangle down by real battlefield jobs so a culture can be excellent in one role
            but limited in another.
          </p>
        </div>

        <div class="details-stack">
          <section class="details-panel">
            <details open>
              <summary>
                <p class="details-kicker">Primary Ladder</p>
                <h3>Infantry Power Rankings</h3>
              </summary>
              <p class="section-desc">
                Ranked by combined melee skill bonuses, Athletics, armor protection, and weapon damage. Elven factions
                would rank S+ across the board but are excluded because they are balanced by population rather than
                parity.
              </p>
              <h4 class="subsection-title">Overall Infantry</h4>
              {
                infantryTiers.map((t) => (
                  <div class="tier-row">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                      <span class="tier-desc">{t.label}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }
            </details>
          </section>

          <section class="details-panel">
            <details>
              <summary>
                <p class="details-kicker">Role Breakdown</p>
                <h3>Infantry Subcategories</h3>
              </summary>
              <p class="section-desc">
                Infantry is split into four combat roles. A faction may dominate one lane while remaining merely
                average, or even poor, in the others.
              </p>

              <h4 class="subsection-title">Front Line <span class="role-tag">Shield Wall / Defensive</span></h4>
              <p class="role-desc">
                One-Handed and Polearm skill plus heavy armor protection for troops that hold ground.
              </p>
              {
                frontLineTiers.map((t) => (
                  <div class="tier-row tier-compact">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }

              <h4 class="subsection-title">Shock Troops <span class="role-tag">Two-Handed Charge</span></h4>
              <p class="role-desc">
                Two-Handed skill, Athletics, and damage output for troops built to break formations.
              </p>
              {
                shockTroopTiers.map((t) => (
                  <div class="tier-row tier-compact">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }

              <h4 class="subsection-title">Line Breakers <span class="role-tag">Anti-Armor / Blunt</span></h4>
              <p class="role-desc">
                Heavy axes and maces for cracking plate and forcing damage through high protection.
              </p>
              {
                lineBreakerTiers.map((t) => (
                  <div class="tier-row tier-compact">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }

              <h4 class="subsection-title">Skirmishers <span class="role-tag">Throwing / Harassment</span></h4>
              <p class="role-desc">
                Throwing skill and mobility for factions that soften the enemy before committed melee.
              </p>
              {
                skirmisherTiers.map((t) => (
                  <div class="tier-row tier-compact">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }
            </details>
          </section>

          <section class="details-panel">
            <details>
              <summary>
                <p class="details-kicker">Mounted Archives</p>
                <h3>Cavalry Power Rankings</h3>
              </summary>
              <p class="section-desc">
                Ranked by Riding skill, mounted melee profile, armor weight, and weapon quality. This includes both
                traditional cavalry and beast riders where relevant.
              </p>
              {
                cavalryTiers.map((t) => (
                  <div class="tier-row">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                      <span class="tier-desc">{t.label}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
                        <div class="tier-culture" style={`border-left: 3px solid ${c.color}`}>
                          <strong style={`color: ${c.color}`}>{c.name}</strong>
                          <span class="tier-reason">{c.reason}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }
            </details>
          </section>

          <section class="details-panel">
            <details>
              <summary>
                <p class="details-kicker">Missile Archives</p>
                <h3>Ranged Power Rankings</h3>
              </summary>
              <p class="section-desc">
                Ranked by Bow, Crossbow, and Throwing modifiers alongside armor weight and weapon quality. Elven
                cultures would dominate this ladder, which is why they are called out separately above.
              </p>
              {
                archerTiers.map((t) => (
                  <div class="tier-row">
                    <div
                      class="tier-label"
                      style={`background: ${t.color}18; border: 1px solid ${t.color}50; color: ${t.color}`}
                    >
                      <span class="tier-letter">{t.tier}</span>
                      <span class="tier-desc">{t.label}</span>
                    </div>
                    <div class="tier-cultures">
                      {t.cultures.map((c) => (
