---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Community" description="Join the TAOM community on Discord, Patreon, and YouTube">
  <div class="page-content" style="max-width: 800px;">
    <h1 class="page-title">Community</h1>

    <div class="card-grid" style="grid-template-columns: 1fr;">
      <a href="#" class="card" style="text-decoration: none;">
        <h3>Discord</h3>
        <p>Join our Discord server for discussions, support, and development updates.</p>
      </a>

      <a href="#" class="card" style="text-decoration: none;">
        <h3>Patreon</h3>
        <p>Support TAOM development and get early access to new content.</p>
      </a>

      <a href="#" class="card" style="text-decoration: none;">
        <h3>YouTube</h3>
        <p>Watch gameplay videos, development updates, and community showcases.</p>
      </a>

      <a href="#" class="card" style="text-decoration: none;">
        <h3>GitHub</h3>
        <p>View the source code, report issues, and contribute to development.</p>
      </a>
    </div>

    <p style="color: var(--text-muted); font-size: 0.8rem; margin-top: 1rem;">
      Links will be updated with actual URLs. Replace the # placeholders with your community links.
    </p>
  </div>
</BaseLayout>
