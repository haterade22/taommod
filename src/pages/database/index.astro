---
import Topbar from '../../components/Topbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const cards = [
  {
    href: '/troops',
    title: 'Troops',
    image: '/images/database/troops.png',
    imageClass: 'card-figure-troops',
  },
  {
    href: '/lords',
    title: 'Lords',
    image: '/images/database/lords.png',
    imageClass: 'card-figure-lords',
  },
  {
    href: '/armoury',
    title: 'Armours',
  },
  {
    href: '/weaponry',
    title: 'Weapons',
  },
];
---

<BaseLayout
  title="Database"
  description="Browse the complete TAOM database - troops, lords, armoury, and weaponry"
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-database-body"
  mainClass="taom-database-main"
>
  <div class="database-page">
    <Topbar />

    <main class="database-shell">
      <section class="page-intro">
        <p class="eyebrow">Archives of the Age of Men</p>
        <h1>Database</h1>
        <p class="intro-copy">
          Explore the core records of TAOM, from faction troop rosters and notable lords to the armoury and weaponry
          that define each realm.
        </p>
      </section>

      <section class="database-grid" aria-label="Database categories">
        {
          cards.map((card) => (
            <article class="database-column">
              <a class="database-tab" href={card.href}>
                <h2 class:list={['database-heading', { 'is-active': !!card.active }]}>{card.title}</h2>
              </a>

              <a class="database-card" href={card.href} aria-label={`Open ${card.title} database`}>
                <div class="card-canvas">
                  <img class="card-layer card-layer-base" src="/images/database/background.png" alt="" />
                  {card.image && <img class:list={['card-figure', card.imageClass]} src={card.image} alt="" />}
                  <img
                    class="card-layer card-layer-watermark"
                    src="/images/database/background-watermark.png"
                    alt=""
                    loading="eager"
                    decoding="sync"
                    fetchpriority="high"
                  />
                  <img class="card-layer card-layer-overlay" src="/images/database/border.png" alt="" />
                </div>
              </a>
            </article>
          ))
        }
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  :global(body.taom-database-body) {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(7, 5, 5, 0.66), rgba(7, 5, 5, 0.97)),
      radial-gradient(circle at 18% 16%, rgba(128, 72, 34, 0.16), transparent 24%),
      radial-gradient(circle at 82% 14%, rgba(98, 44, 26, 0.14), transparent 23%),
      linear-gradient(180deg, #17100e 0%, #0d0908 48%, #080606 100%);
    color: #ece4db;
  }

  :global(body.taom-database-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 10, 9, 0.28), rgba(8, 6, 6, 0.82)),
      url('/images/hero-bg.jpg') center top / cover no-repeat;
    opacity: 0.18;
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-database-main) {
    display: block;
  }

  .database-page {
    min-height: 100vh;
    padding: 2rem;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .topbar {
    position: sticky;
    top: 2rem;
    z-index: 100;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.75rem;
    padding: 1.15rem 1.6rem;
    border: 1px solid rgba(58, 48, 30, 0.7);
    background:
      linear-gradient(90deg, rgba(16, 12, 10, 0.92), rgba(9, 13, 10, 0.9) 45%, rgba(16, 11, 8, 0.92)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
    box-shadow: 0 22px 55px rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(10px);
  }

  .brand {
    display: inline-grid;
    gap: 0;
    justify-items: center;
    text-align: center;
    color: #d19a33;
    text-transform: uppercase;
    line-height: 0.9;
  }

  .brand:hover {
    color: #f7f2ec;
    text-decoration: none;
  }

  .brand-small,
  .brand-large,
  .main-nav a,
  .side-link,
  .eyebrow,
  .page-intro h1,
  .database-heading {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .brand-small {
    font-size: 0.95rem;
    letter-spacing: 0.06em;
  }

  .brand-large {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .main-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.1rem;
  }

  .main-nav a,
  .side-link {
    position: relative;
    padding: 0.35rem 0.35rem 0.5rem;
    color: #d19a33;
    font-size: 1rem;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .main-nav a::after,
  .side-link::after {
    content: '';
    position: absolute;
    left: 0.35rem;
    right: 0.35rem;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(205, 153, 52, 0.88), transparent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 180ms ease;
  }

  .main-nav a:hover,
  .main-nav a.is-active,
  .side-link:hover {
    color: #f7f2ec;
    text-decoration: none;
  }

  .main-nav a:hover::after,
  .main-nav a.is-active::after,
  .side-link:hover::after {
    transform: scaleX(1);
  }

  .side-link {
    color: #f7f2ec;
  }

  .database-shell {
    max-width: 82.5rem;
    margin: 0 auto;
    padding: 2.25rem 0.625rem 3.375rem;
  }

  .page-intro {
    max-width: 47.5rem;
    margin-bottom: 4rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: #b98a35;
  }

  .page-intro h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: #f7f2ec;
  }

  .intro-copy {
    margin: 1.125rem 0 0;
    max-width: 44ch;
    font-size: 1.35rem;
    line-height: 1.35;
    color: rgba(233, 226, 219, 0.76);
  }

  .database-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.4rem;
    align-items: start;
  }

  .database-column {
    display: grid;
    gap: 1.45rem;
    justify-items: center;
  }

  .database-tab {
    display: inline-block;
    color: inherit;
    text-decoration: none !important;
  }

  .database-tab:visited,
  .database-tab:hover,
  .database-tab:focus-visible {
    text-decoration: none !important;
  }

  .database-heading {
    position: relative;
    display: inline-block;
    margin: 0;
    padding-bottom: 1.5rem;
    font-size: clamp(1.3rem, 1.7vw, 1.95rem);
    font-weight: 600;
    text-transform: uppercase;
    color: #f0ebe5;
    text-decoration: none !important;
    transition:
      color 180ms ease,
      text-shadow 180ms ease;
  }

  .database-heading::before {
    content: none;
  }

  .database-heading::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.7rem;
    width: 7.9rem;
    height: 2px;
    transform: translateX(-50%) scaleX(0.82);
    background: linear-gradient(90deg, transparent, rgba(231, 220, 196, 0.88), transparent);
    transition:
      transform 220ms ease,
      background 220ms ease;
  }

  .database-tab:hover .database-heading,
  .database-tab:focus-visible .database-heading,
  .database-column:hover .database-heading,
  .database-column:focus-within .database-heading {
    color: #d39a3a;
    text-shadow: 0 0 12px rgba(211, 154, 58, 0.18);
  }

  .database-tab:hover .database-heading::after,
  .database-tab:focus-visible .database-heading::after,
  .database-column:hover .database-heading::after,
  .database-column:focus-within .database-heading::after {
    transform: translateX(-50%) scaleX(1.08);
    background: linear-gradient(90deg, transparent, #d39a3a, transparent);
  }

  .database-tab:focus-visible {
    outline: none;
  }

  .database-card {
    display: block;
    width: 100%;
    text-decoration: none;
    transition:
      transform 220ms ease,
      filter 220ms ease;
  }

  .database-card:hover {
    transform: translateY(-4px);
    filter: brightness(1.03);
  }

  .card-canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 573 / 1141;
    overflow: hidden;
  }

  .card-layer,
  .card-figure {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .card-layer {
    object-fit: cover;
  }

  .card-layer-base {
    z-index: 1;
  }

  .card-layer-watermark {
    z-index: 2;
    opacity: 0.9;
  }

  .card-figure {
    z-index: 3;
    object-fit: contain;
    object-position: center bottom;
    transform-origin: bottom center;
    transition: transform 220ms ease;
  }

  .database-card:hover .card-figure {
    transform: scale(1.015);
  }

  .card-layer-overlay {
    z-index: 4;
  }

  @media (max-width: 1180px) {
    .database-shell {
      max-width: 72rem;
    }

    .database-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .database-column {
      gap: 0.95rem;
    }

    .database-heading {
      padding-bottom: 1rem;
      font-size: clamp(1rem, 1.55vw, 1.35rem);
    }

    .database-heading::after {
      bottom: 0.45rem;
      width: 5.25rem;
    }

    .database-card {
      width: min(100%, 10.5rem);
    }
  }

  @media (max-width: 980px) {
    .topbar {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .brand {
      justify-items: start;
      text-align: left;
    }

    .main-nav {
      justify-content: flex-start;
    }

    .database-grid {
      gap: 0.9rem;
    }

    .database-heading {
      font-size: 0.98rem;
    }

    .database-heading::after {
      width: 4.25rem;
    }

    .database-card {
      width: min(100%, 9.25rem);
    }
  }

  @media (max-width: 760px) {
    .database-page {
      padding: 1rem;
    }

    .topbar {
      top: 1rem;
      gap: 1rem;
      padding: 1rem;
    }

    .brand-large {
      font-size: 1.6rem;
    }

    .main-nav {
      gap: 0.6rem 0.9rem;
    }

    .main-nav a,
    .side-link {
      font-size: 0.92rem;
    }

    .database-shell {
      max-width: 32rem;
      padding-top: 1.75rem;
    }

    .page-intro {
      margin-bottom: 3.5rem;
    }

    .intro-copy {
      font-size: 1.1rem;
    }

    .database-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 0.85rem;
    }

    .database-column {
      gap: 0.7rem;
    }

    .database-heading {
      padding-bottom: 0.8rem;
      font-size: 0.96rem;
    }

    .database-heading::after {
      bottom: 0.35rem;
      width: 3.6rem;
    }

    .database-card {
      width: min(100%, 9.5rem);
    }
  }
</style>
