<style>
  .credits-intro {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .credits-intro strong {
    color: var(--text-primary);
  }

  .credits-section {
    margin-bottom: 2rem;
  }

  .credits-section h2 {
    color: var(--text-primary);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .section-note {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .credits-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
  }

  .credits-section li {
    color: var(--text-primary);
    font-size: 0.95rem;
    padding: 0.2rem 0;
  }

  .credits-section a {
    color: var(--accent);
    text-decoration: underline;
  }

  .credits-section a:hover {
    color: var(--text-primary);
  }
</style>
