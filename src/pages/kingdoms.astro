---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseKingdomsFromXslt, getCultureDisplayName } from '../lib/parse-xml';

const kingdoms = parseKingdomsFromXslt();

// Map kingdom IDs to background images
const KINGDOM_IMAGES: Record<string, string> = {
  empire: '/images/faction-dunland.jpg',
  empire_s: '/images/faction-mordor.jpg',
  erebor: '/images/faction-erebor.jpg',

  gundabad: '/images/faction-gundabad.webp',
  khuzait: '/images/faction-rhun.webp',
};

// Emblem-style images — displayed as decorative banner overlays (keyed by kingdom ID)
const EMBLEM_IMAGES: Record<string, string> = {
  empire_w: '/images/kingdom-gondor-banner.png',
  aserai: '/images/kingdom-harad-banner.png',
  dolguldur: '/images/kingdom-dolguldur-banner.png',
  rivendell: '/images/kingdom-rivendell-banner.png',
  lothlorien: '/images/kingdom-lothlorien-banner.png',
  isengard: '/images/kingdom-isengard-banner.png',
  umbar: '/images/kingdom-umbar-banner.png',
};

// Override culture display names for kingdoms that share a vanilla culture ID
const CULTURE_OVERRIDES: Record<string, string> = {
  empire_w: 'Gondor',
  empire_s: 'Mordor',
  empire: 'Dunland',
  sturgia: 'Dale',
  aserai: 'Harad',
  vlandia: 'Rohan',
  battania: 'Variag',
  khuzait: 'Rhun',
};

// Lore-appropriate kingdom colors [primary, secondary]
const KINGDOM_COLORS: Record<string, [string, string]> = {
  empire_w: ['#C0C0C0', '#1A1A2E'],  // Gondor: silver + dark blue
  empire_s: ['#8B0000', '#1A1A1A'],   // Mordor: dark red + black
  empire:   ['#8B6914', '#2D1B00'],   // Dunland: brown/gold + dark brown
  sturgia:  ['#4169E1', '#C0C0C0'],   // Dale: royal blue + silver
  aserai:   ['#DC143C', '#2D0A0A'],   // Harad: crimson + dark red
  vlandia:  ['#228B22', '#C8A951'],   // Rohan: forest green + gold
  battania: ['#8B4513', '#4A0E0E'],   // Variag: saddle brown + dark red
  khuzait:  ['#DAA520', '#4B0082'],   // Rhun: goldenrod + indigo
  erebor:   ['#B8860B', '#4A4A4A'],   // Erebor: dark gold + stone grey
  isengard: ['#2F2F2F', '#F5F5F5'],   // Isengard: dark iron + white hand
  gundabad: ['#6B7B8D', '#1C1C1C'],   // Gundabad: cold steel + black
  dolguldur:['#5B8C3A', '#1A1A1A'],   // Dol Guldur: sickly green + black
};
---

<BaseLayout title="Kingdoms" description="All kingdoms in TAOM - rulers, cultures, and descriptions">
  <section class="page-banner">
    <img src="/images/banner-kingdoms.jpg" alt="Kingdoms of Middle-earth" class="banner-img" />
    <div class="banner-overlay"></div>
    <div class="banner-content">
      <h1>Kingdoms of Middle-earth</h1>
    </div>
  </section>
  <div class="page-content">

    <div class="kingdom-grid">
      {kingdoms.map(k => {
        const bgImage = KINGDOM_IMAGES[k.id];
        const emblemImage = EMBLEM_IMAGES[k.id];
        const colors = KINGDOM_COLORS[k.id];
        return (
          <div
            class:list={['kingdom-card', { 'has-bg': !!bgImage && !emblemImage, 'has-emblem': !!emblemImage }]}
            style={bgImage && !emblemImage ? `--bg-image: url('${bgImage}')` : ''}
          >
            {emblemImage && <img src={emblemImage} alt={`${k.name} emblem`} class="kingdom-emblem" />}
            <div class="kingdom-overlay"></div>
            <div class="kingdom-content">
              <h3>{k.name}</h3>
              <div class="kingdom-meta">
                {colors && (
                  <span
                    class="color-swatch"
                    style={`background: ${colors[0]};`}
                    title={`Primary`}
                  />
                )}
                {colors && (
                  <span
                    class="color-swatch"
                    style={`background: ${colors[1]};`}
                    title={`Secondary`}
                  />
                )}
                <span class="kingdom-title">{k.title}</span>
              </div>
              <p><strong>Ruler:</strong> {k.rulerTitle}</p>
              <p><strong>Culture:</strong> {CULTURE_OVERRIDES[k.id] || getCultureDisplayName(k.culture)}</p>
              {k.description && (
                <p class="kingdom-desc">
                  {k.description.length > 200 ? k.description.slice(0, 200) + '...' : k.description}
                </p>
              )}
            </div>
          </div>
        );
      })}
    </div>

    {kingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No kingdoms found. Check that spkingdoms.xslt data is available.</p>
    )}

    <section class="full-map">
      <h2>Map of Middle-earth</h2>
      <a href="/images/banner-kingdoms.jpg" target="_blank" class="map-link">
        <img src="/images/banner-kingdoms.jpg" alt="Map of Middle-earth" class="map-img" />
        <span class="map-hint">Click to view full size</span>
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .page-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    max-height: 300px;
  }

  .banner-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 300px;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.15) 60%,
      rgba(25, 25, 25, 0.95) 100%
    );
  }

  .banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .banner-content h1 {
    color: var(--accent);
    font-size: 2.2rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .kingdom-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    grid-auto-rows: 280px;
  }

  .kingdom-card {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kingdom-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.4);
  }

  .kingdom-card.has-bg {
    background: var(--bg-image) center center / cover no-repeat;
  }

  .kingdom-card.has-emblem {
    background: var(--bg-secondary);
  }

  .kingdom-emblem {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: auto;
    opacity: 0.6;
    z-index: 0;
    pointer-events: none;
    object-fit: contain;
    object-position: right center;
  }

  .kingdom-card.has-emblem:hover .kingdom-emblem {
    opacity: 0.75;
  }

  .kingdom-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    transition: background 0.2s;
  }

  .kingdom-card:hover .kingdom-overlay {
    background: rgba(0, 0, 0, 0.5);
  }

  .kingdom-card:not(.has-bg) .kingdom-overlay {
    background: transparent;
  }

  .kingdom-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
    height: 100%;
    overflow: hidden;
  }

  .kingdom-content h3 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7);
  }

  .kingdom-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .color-swatch {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .kingdom-title {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
  }

  .kingdom-content p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  .kingdom-content p strong {
    color: rgba(255, 255, 255, 0.7);
  }

  .kingdom-desc {
    font-size: 0.8rem !important;
    color: rgba(255, 255, 255, 0.7) !important;
    margin-top: 0.5rem !important;
  }

  .full-map {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .full-map h2 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .map-link {
    display: block;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    transition: border-color 0.2s;
  }

  .map-link:hover {
    border-color: var(--accent-dim);
    text-decoration: none;
  }

  .map-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .map-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(0, 0, 0, 0.7);
    color: var(--text-secondary);
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .kingdom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
