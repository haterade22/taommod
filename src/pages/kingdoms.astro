---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseKingdomsFromXslt } from '../lib/parse-xml';

const kingdoms = parseKingdomsFromXslt();
---

<BaseLayout title="Kingdoms" description="All kingdoms in TAOM - rulers, cultures, and descriptions">
  <div class="page-content">
    <h1 class="page-title">Kingdoms of Middle-earth</h1>

    <div class="card-grid">
      {kingdoms.map(k => (
        <div class="card">
          <h3>{k.name}</h3>
          <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem;">
            {k.color && (
              <span
                style={`display: inline-block; width: 16px; height: 16px; border-radius: 3px; background: #${k.color.replace(/^(0x|#)?(FF)?/i, '')};`}
                title={`Primary: ${k.color}`}
              />
            )}
            {k.color2 && (
              <span
                style={`display: inline-block; width: 16px; height: 16px; border-radius: 3px; background: #${k.color2.replace(/^(0x|#)?(FF)?/i, '')};`}
                title={`Secondary: ${k.color2}`}
              />
            )}
            <span style="color: var(--text-muted); font-size: 0.8rem;">
              {k.title}
            </span>
          </div>
          <p style="margin-bottom: 0.5rem;">
            <strong style="color: var(--text-secondary);">Ruler:</strong> {k.rulerTitle}
          </p>
          <p style="margin-bottom: 0.5rem;">
            <strong style="color: var(--text-secondary);">Culture:</strong> {k.culture}
          </p>
          {k.description && (
            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.5rem;">
              {k.description.length > 200 ? k.description.slice(0, 200) + '...' : k.description}
            </p>
          )}
        </div>
      ))}
    </div>

    {kingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No kingdoms found. Check that spkingdoms.xslt data is available.</p>
    )}
  </div>
</BaseLayout>
