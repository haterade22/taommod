---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseKingdomsFromXslt, getCultureDisplayName } from '../lib/parse-xml';

const kingdoms = parseKingdomsFromXslt();

// Map kingdom culture IDs to background images
const KINGDOM_IMAGES: Record<string, string> = {
  gondor: '/images/faction-gondor.png',
  mordor: '/images/faction-mordor.png',
  erebor: '/images/faction-erebor.jpg',
  isengard: '/images/faction-isengard.png',
  gundabad: '/images/faction-gundabad.webp',
  khuzait: '/images/faction-rhun.webp',
  empire: '/images/faction-dunland.png',
  dolguldur: '/images/faction-dolguldur.png',
  aserai: '/images/faction-harad.png',
};

// Emblem-style images (icons on light bg) — displayed as centered emblems, not full bg cover
const EMBLEM_IMAGES = new Set(['gondor', 'mordor']);
---

<BaseLayout title="Kingdoms" description="All kingdoms in TAOM - rulers, cultures, and descriptions">
  <section class="page-banner">
    <img src="/images/banner-kingdoms.jpg" alt="Kingdoms of Middle-earth" class="banner-img" />
    <div class="banner-overlay"></div>
    <div class="banner-content">
      <h1>Kingdoms of Middle-earth</h1>
    </div>
  </section>
  <div class="page-content">

    <div class="kingdom-grid">
      {kingdoms.map(k => {
        const bgImage = KINGDOM_IMAGES[k.culture];
        const isEmblem = EMBLEM_IMAGES.has(k.culture);
        return (
          <div
            class:list={['kingdom-card', { 'has-bg': !!bgImage && !isEmblem, 'has-emblem': isEmblem }]}
            style={bgImage && !isEmblem ? `--bg-image: url('${bgImage}')` : ''}
          >
            {isEmblem && bgImage && <img src={bgImage} alt={`${k.name} emblem`} class="kingdom-emblem" />}
            <div class="kingdom-overlay"></div>
            <div class="kingdom-content">
              <h3>{k.name}</h3>
              <div class="kingdom-meta">
                {k.color && (
                  <span
                    class="color-swatch"
                    style={`background: #${k.color.replace(/^(0x|#)?(FF)?/i, '')};`}
                    title={`Primary: ${k.color}`}
                  />
                )}
                {k.color2 && (
                  <span
                    class="color-swatch"
                    style={`background: #${k.color2.replace(/^(0x|#)?(FF)?/i, '')};`}
                    title={`Secondary: ${k.color2}`}
                  />
                )}
                <span class="kingdom-title">{k.title}</span>
              </div>
              <p><strong>Ruler:</strong> {k.rulerTitle}</p>
              <p><strong>Culture:</strong> {getCultureDisplayName(k.culture)}</p>
              {k.description && (
                <p class="kingdom-desc">
                  {k.description.length > 200 ? k.description.slice(0, 200) + '...' : k.description}
                </p>
              )}
            </div>
          </div>
        );
      })}
    </div>

    {kingdoms.length === 0 && (
      <p style="color: var(--text-muted);">No kingdoms found. Check that spkingdoms.xslt data is available.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .banner-img {
    display: block;
    width: 100%;
    height: auto;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.1) 0%,
      rgba(0, 0, 0, 0.15) 60%,
      rgba(25, 25, 25, 0.95) 100%
    );
  }

  .banner-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .banner-content h1 {
    color: var(--accent);
    font-size: 2.2rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
  }

  .kingdom-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .kingdom-card {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    height: 280px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kingdom-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.4);
  }

  .kingdom-card.has-bg {
    background: var(--bg-image) center center / cover no-repeat;
  }

  .kingdom-card.has-emblem {
    background: var(--bg-secondary);
  }

  .kingdom-emblem {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    height: 65%;
    width: auto;
    opacity: 0.2;
    z-index: 0;
    filter: brightness(0) invert(1);
    pointer-events: none;
  }

  .kingdom-card.has-emblem:hover .kingdom-emblem {
    opacity: 0.3;
  }

  .kingdom-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    transition: background 0.2s;
  }

  .kingdom-card:hover .kingdom-overlay {
    background: rgba(0, 0, 0, 0.5);
  }

  .kingdom-card:not(.has-bg) .kingdom-overlay {
    background: transparent;
  }

  .kingdom-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
    height: 100%;
    overflow: hidden;
  }

  .kingdom-content h3 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.7);
  }

  .kingdom-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .color-swatch {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .kingdom-title {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
  }

  .kingdom-content p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  .kingdom-content p strong {
    color: rgba(255, 255, 255, 0.7);
  }

  .kingdom-desc {
    font-size: 0.8rem !important;
    color: rgba(255, 255, 255, 0.7) !important;
    margin-top: 0.5rem !important;
  }

  @media (max-width: 600px) {
    .kingdom-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
