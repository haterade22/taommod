---
import BrandWordmark from '../components/BrandWordmark.astro';
import Topbar from '../components/Topbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" hideNav={true} hideFooter={true} bodyClass="taom-home-body" mainClass="taom-home-main">
  <div class="home-page">
    <div class="home-background" aria-hidden="true">
      <video class="home-background-video" autoplay muted loop playsinline preload="auto">
        <source src="/images/sauron.mp4" type="video/mp4" />
      </video>
      <div class="home-background-overlay"></div>
    </div>

    <Topbar />

    <section class="home-landing">
      <div class="home-landing-glow" aria-hidden="true"></div>

      <div class="home-hero" aria-label="Tales from the Age of Men landing page">
        <BrandWordmark variant="hero" class="home-hero-wordmark" ariaLabel="Tales from the Age of Men" />

        <div class="home-hero-copy">
          <p>Total Conversion Mod</p>
          <p>For Mount &amp; Blade II: Bannerlord</p>
        </div>

        <div class="home-hero-actions">
          <a class="home-download-button" href="/download">Download</a>
          <a class="home-secondary-button" href="/database">Browse Database</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  :global(body.taom-home-body) {
    min-height: 100vh;
    background: #060505;
    color: #ece7e0;
  }

  :global(.taom-home-main) {
    display: block;
  }

  .home-page {
    min-height: 100vh;
    position: relative;
    isolation: isolate;
    padding: 2rem;
    font-family: Georgia, 'Times New Roman', serif;
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .home-background {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    background: #050404;
  }

  .home-background-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    transform: scale(1.05);
    filter: blur(5px) brightness(0.42) saturate(0.9);
  }

  .home-background-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 7, 6, 0.42), rgba(6, 5, 5, 0.74)),
      radial-gradient(circle at 50% 50%, rgba(0, 0, 0, 0.06), rgba(0, 0, 0, 0.48) 72%);
    backdrop-filter: blur(2px);
  }

  .topbar {
    position: sticky;
    top: 2rem;
    z-index: 100;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.75rem;
    padding: 1.15rem 1.6rem;
    border: 1px solid rgba(58, 48, 30, 0.7);
    background:
      linear-gradient(90deg, rgba(16, 12, 10, 0.92), rgba(9, 13, 10, 0.9) 45%, rgba(16, 11, 8, 0.92)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
    box-shadow: 0 22px 55px rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(10px);
  }

  .brand {
    display: inline-grid;
    gap: 0;
    justify-items: center;
    color: #d19a33;
    text-align: center;
    text-transform: uppercase;
    line-height: 0.9;
  }

  .brand:hover {
    color: #f7f2ec;
    text-decoration: none;
  }

  .main-nav a,
  .side-link,
  .home-hero-copy p,
  .home-download-button,
  .home-secondary-button {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .main-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.1rem;
  }

  .main-nav a,
  .side-link {
    position: relative;
    padding: 0.35rem 0.35rem 0.5rem;
    color: #d19a33;
    font-size: 1rem;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .main-nav a::after,
  .side-link::after {
    content: '';
    position: absolute;
    left: 0.35rem;
    right: 0.35rem;
    bottom: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(205, 153, 52, 0.88), transparent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 180ms ease;
  }

  .main-nav a:hover,
  .main-nav a.is-active,
  .side-link:hover {
    color: #f7f2ec;
    text-decoration: none;
  }

  .main-nav a:hover::after,
  .main-nav a.is-active::after,
  .side-link:hover::after {
    transform: scaleX(1);
  }

  .side-link {
    color: #f7f2ec;
  }

  .home-landing {
    position: relative;
    min-height: calc(100vh - 7.5rem);
    display: grid;
    place-items: center;
    padding: 4rem 1rem 6rem;
  }

  .home-landing-glow {
    position: absolute;
    inset: auto 0 10% 0;
    height: 18rem;
    background: radial-gradient(circle, rgba(191, 125, 56, 0.08), transparent 70%);
    filter: blur(28px);
    pointer-events: none;
  }

  .home-hero {
    position: relative;
    width: min(100%, 72rem);
    display: grid;
    justify-items: center;
    gap: 1.75rem;
    text-align: center;
  }

  .home-hero-wordmark {
    filter: drop-shadow(0 10px 10px rgba(0, 0, 0, 0.42)) drop-shadow(0 28px 45px rgba(0, 0, 0, 0.35));
  }

  .home-hero-copy {
    display: grid;
    gap: 0.75rem;
  }

  .home-hero-copy p {
    margin: 0;
    font-size: clamp(1.2rem, 2vw, 1.95rem);
    font-weight: 500;
    letter-spacing: 0.24em;
    line-height: 1.12;
    text-transform: uppercase;
    color: rgba(236, 231, 224, 0.94);
    text-shadow:
      0 2px 0 rgba(0, 0, 0, 0.28),
      0 8px 20px rgba(0, 0, 0, 0.26);
  }

  .home-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .home-download-button,
  .home-secondary-button {
    display: inline-grid;
    place-items: center;
    min-width: 15rem;
    padding: 1.15rem 2rem;
    font-size: clamp(1rem, 1.2vw, 1.25rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.45);
    transition:
      transform 180ms ease,
      filter 180ms ease,
      border-color 180ms ease;
  }

  .home-download-button {
    color: #ece7e0;
    background:
      linear-gradient(180deg, rgba(70, 50, 39, 0.92), rgba(43, 31, 25, 0.96)),
      radial-gradient(circle at top, rgba(255, 239, 193, 0.08), transparent 56%);
    border: 1px solid rgba(234, 221, 200, 0.18);
  }

  .home-secondary-button {
    color: #d6c9ba;
    background: rgba(19, 15, 13, 0.72);
    border: 1px solid rgba(128, 101, 62, 0.4);
  }

  .home-download-button:hover,
  .home-secondary-button:hover {
    color: #fff3de;
    text-decoration: none;
    transform: translateY(-2px);
    filter: brightness(1.06);
    border-color: rgba(234, 221, 200, 0.28);
  }

  @media (max-width: 980px) {
    .topbar {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .brand {
      justify-items: start;
      text-align: left;
    }

    .main-nav {
      justify-content: flex-start;
    }
  }

  @media (max-width: 760px) {
    .home-page {
      padding: 1rem;
    }

    .topbar {
      top: 1rem;
      gap: 1rem;
      padding: 1rem;
    }

    .main-nav {
      gap: 0.6rem 0.9rem;
    }

    .main-nav a,
    .side-link {
      font-size: 0.92rem;
    }

    .home-landing {
      min-height: auto;
      padding: 3.5rem 0.5rem 4rem;
    }

    .home-hero-copy p {
      letter-spacing: 0.14em;
    }

    .home-download-button,
    .home-secondary-button {
      width: 100%;
      min-width: 0;
    }
  }
</style>
