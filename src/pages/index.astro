---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero-banner">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <img src="/images/logo.png" alt="Tales From the Age of Men" class="hero-logo" />
      <p class="subtitle">A Lord of the Rings Total Conversion Mod for Bannerlord</p>
      <div class="hero-buttons">
        <a href="/download" class="btn btn-primary">Download</a>
        <a href="/troops" class="btn btn-secondary">Browse Troops</a>
        <a href="/armoury" class="btn btn-secondary">Browse Armoury</a>
        <a href="/weaponry" class="btn btn-secondary">Browse Weaponry</a>
      </div>
    </div>
  </section>

  <div class="page-content">
    <p class="tagline">
      Experience Middle-earth in Mount &amp; Blade II: Bannerlord. Command the armies of Gondor, Rohan, Erebor, Mordor,
      and more across 16 factions with hundreds of unique troops, lords, and equipment.
    </p>

    <div class="card-grid">
      <div class="card">
        <h3>16 Factions</h3>
        <p>
          From the realms of Gondor and Rohan to the dark forces of Mordor and Isengard. Each faction features unique
          cultures, troops, and equipment.
        </p>
      </div>
      <div class="card">
        <h3>Hundreds of Troops</h3>
        <p>
          Custom troop trees for every faction with unique skills, equipment, and upgrade paths. Dwarven legionaries,
          Elven archers, Uruk-hai berserkers, and more.
        </p>
      </div>
      <div class="card">
        <h3>Custom Lords & Heroes</h3>
        <p>
          380+ lords and 415+ heroes with custom skills, traits, biographies, and appearances inspired by Tolkien's
          world.
        </p>
      </div>
      <div class="card">
        <h3>Custom Equipment</h3>
        <p>
          Faction-specific armor, weapons, and mounts. Dwarven plate, Elven mail, Gondorian steel, and Orcish crude
          iron.
        </p>
      </div>
      <div class="card">
        <h3>Custom Map</h3>
        <p>A sprawling Middle-earth map with 658 settlements across all regions, from the Shire to Mordor.</p>
      </div>
      <div class="card">
        <h3>Active Development</h3>
        <p>Built for Bannerlord v1.3. Regular updates with new content, balance changes, and features.</p>
      </div>
    </div>

    <!-- Video Showcase -->
    <section class="video-section">
      <video autoplay loop muted playsinline class="showcase-video">
        <source src="/images/sauron.mp4" type="video/mp4" />
      </video>
    </section>

    <!-- Award Section -->
    <section class="award-section">
      <div class="award-content">
        <img src="/images/moddb-award.jpg" alt="ModDB Mod of the Year 2025 - Best Upcoming" class="award-badge" />
        <div class="award-text">
          <h2>Best Upcoming Mod of 2025</h2>
          <p>Voted by the ModDB community as the Best Upcoming Mod in the 2025 Mod of the Year awards.</p>
          <a
            href="https://www.moddb.com/mods/tales-from-the-age-of-men"
            class="btn btn-secondary"
            target="_blank"
            rel="noopener">View on ModDB</a
          >
        </div>
      </div>
    </section>

    <!-- Art Gallery -->
    <section class="art-gallery">
      <div class="art-piece">
        <img src="/images/rohan-icon.jpg" alt="Rohan Rider" />
      </div>
      <div class="art-piece">
        <img src="/images/easterling-horsemen.jpg" alt="Easterling Horsemen" />
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: url('/images/hero-bg.jpg') center center / cover no-repeat;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.3) 50%, rgba(25, 25, 25, 0.85) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 1.5rem;
  }

  .hero-content .hero-logo {
    max-width: 550px;
    width: 90%;
    height: auto;
    filter: drop-shadow(0 4px 30px rgba(0, 0, 0, 0.7));
    margin-bottom: 1rem;
  }

  .hero-content .subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tagline {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 800px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .video-section {
    margin-top: 3rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .showcase-video {
    display: block;
    width: 100%;
    height: auto;
  }

  .award-section {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }

  .award-content {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .award-badge {
    width: 180px;
    height: auto;
    flex-shrink: 0;
  }

  .award-text h2 {
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .award-text p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .art-gallery {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  .art-piece img {
    max-height: 250px;
    width: auto;
    border-radius: 8px;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.5));
  }

  @media (max-width: 768px) {
    .hero-banner {
      min-height: 350px;
    }

    .hero-content .hero-logo {
      max-width: 350px;
    }

    .award-content {
      flex-direction: column;
      text-align: center;
    }

    .award-badge {
      width: 140px;
    }

    .art-gallery {
      flex-direction: column;
      align-items: center;
    }

    .art-piece img {
      max-height: 200px;
    }
  }
</style>
