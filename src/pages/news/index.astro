---
import Topbar from '../../components/Topbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import newsFeed from '../../data/patreon-posts.json';

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const shortFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
});

const fallbackImage = '/images/logo.png';

const stripHtml = (value = '') =>
  value
    .replace(/<[^>]*>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&#39;/g, "'")
    .replace(/&quot;/g, '"')
    .replace(/\s+/g, ' ')
    .trim();

const truncate = (value: string, maxLength: number) =>
  value.length > maxLength ? `${value.slice(0, maxLength).trimEnd()}...` : value;

const extractFirstImage = (html = '') => html.match(/<img[^>]+src=["']([^"']+)["']/i)?.[1] ?? fallbackImage;

const estimateReadingTime = (value = '') => {
  const words = stripHtml(value).split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 180));
};

const posts = [...newsFeed.posts]
  .sort((left, right) => {
    const leftTime = left.publishedAt ? Date.parse(left.publishedAt) : 0;
    const rightTime = right.publishedAt ? Date.parse(right.publishedAt) : 0;
    return rightTime - leftTime;
  })
  .map((post, index) => {
    const publishedDate = post.publishedAt ? new Date(post.publishedAt) : null;
    const textSource = stripHtml(post.excerpt || post.html || '');

    return {
      ...post,
      publishedDate,
      publishedLabel: publishedDate ? formatter.format(publishedDate) : 'Unpublished',
      shortLabel: publishedDate ? shortFormatter.format(publishedDate) : 'Unpublished',
      year: publishedDate ? String(publishedDate.getFullYear()) : 'unknown',
      coverImage: extractFirstImage(post.html),
      summary: truncate(textSource, index === 0 ? 520 : 180),
      searchText: `${post.title} ${textSource}`.toLowerCase(),
      readingTime: estimateReadingTime(post.html || post.excerpt || ''),
    };
  });

const featuredPost = posts[0] ?? null;
const feedPosts = posts.slice(1);
const popularPosts = posts.slice(0, 5);
const filterYears = [...new Set(posts.map((post) => post.year).filter((year) => year !== 'unknown'))];
const syncLabel = newsFeed.syncedAt ? formatter.format(new Date(newsFeed.syncedAt)) : 'Pending';
---

<BaseLayout
  title="News"
  description="Recent TAOM development posts mirrored from Patreon in a feed-style news hub."
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-news-body"
  mainClass="taom-news-main"
>
  <div class="news-page">
    <div class="topbar-wrap">
      <Topbar />
    </div>

    <main class="news-shell">
      <section class="feed-header">
        <div class="feed-heading">
          <p class="eyebrow">Patreon Mirror</p>
          <h1>Recent posts</h1>
        </div>

        <div class="feed-tools"></div>
      </section>

      {
        posts.length > 0 ? (
          <section class="feed-layout">
            <div class="feed-main">
              {featuredPost && (
                <article
                  class="featured-post news-entry"
                  data-news-card
                  data-year={featuredPost.year}
                  data-search={featuredPost.searchText}
                >
                  <a class="featured-media" href={`/news/${featuredPost.slug}`}>
                    <img src={featuredPost.coverImage} alt={featuredPost.title} loading="eager" />
                  </a>

                  <div class="featured-body">
                    <div class="post-meta-line">
                      <span>{featuredPost.shortLabel}</span>
                      <span>{featuredPost.readingTime} min read</span>
                    </div>

                    <h2>
                      <a href={`/news/${featuredPost.slug}`}>{featuredPost.title}</a>
                    </h2>

                    <p class="featured-summary">{featuredPost.summary}</p>

                    <div class="featured-footer">
                      <div class="post-links">
                        <a class="primary-link" href={`/news/${featuredPost.slug}`}>
                          Show more
                        </a>
                        {featuredPost.patreonUrl && (
                          <a class="secondary-link" href={featuredPost.patreonUrl} target="_blank" rel="noreferrer">
                            Patreon
                          </a>
                        )}
                      </div>

                      <a
                        class="share-link"
                        href={featuredPost.patreonUrl || `/news/${featuredPost.slug}`}
                        target={featuredPost.patreonUrl ? '_blank' : undefined}
                        rel={featuredPost.patreonUrl ? 'noreferrer' : undefined}
                      >
                        Share
                      </a>
                    </div>
                  </div>
                </article>
              )}

              <div class="post-stack">
                {feedPosts.map((post) => (
                  <article
                    class="post-card news-entry"
                    data-news-card
                    data-year={post.year}
                    data-search={post.searchText}
                  >
                    <a class="post-thumb" href={`/news/${post.slug}`}>
                      <img src={post.coverImage} alt={post.title} loading="lazy" />
                    </a>

                    <div class="post-copy">
                      <div class="post-meta-line">
                        <span>{post.shortLabel}</span>
                        <span>{post.readingTime} min read</span>
                      </div>

                      <h3>
                        <a href={`/news/${post.slug}`}>{post.title}</a>
                      </h3>

                      <p>{post.summary}</p>

                      <div class="post-links">
                        <a class="primary-link" href={`/news/${post.slug}`}>
                          Read post
                        </a>
                        {post.patreonUrl && (
                          <a class="secondary-link" href={post.patreonUrl} target="_blank" rel="noreferrer">
                            Patreon
                          </a>
                        )}
                      </div>
                    </div>
                  </article>
                ))}
              </div>

              <section class="empty-state" hidden data-news-empty>
                <p class="eyebrow">No Results</p>
                <h2>No posts match that search yet.</h2>
                <p>Try a different title keyword or switch back to all years.</p>
              </section>
            </div>

            <aside class="feed-sidebar">
              <section class="sidebar-card community-card">
                <p class="sidebar-label">Community</p>
                <h2>Join the fellowship</h2>
                <a class="community-link" href="https://discord.gg/taom" target="_blank" rel="noreferrer">
                  <span>Get support, previews, and team updates on Discord</span>
                  <span class="community-arrow" aria-hidden="true">
                    {'>'}
                  </span>
                </a>
              </section>

              <section class="sidebar-card popular-card" data-popular-card>
                <div class="sidebar-heading">
                  <p class="sidebar-label">Trending mirror</p>
                  <h2>Popular posts</h2>
                </div>

                <div class="popular-list" data-popular-list>
                  {popularPosts.map((post) => (
                    <a
                      class="popular-item"
                      href={`/news/${post.slug}`}
                      data-popular-item
                      data-year={post.year}
                      data-search={post.searchText}
                    >
                      <img src={post.coverImage} alt={post.title} loading="lazy" />
                      <span>
                        <strong>{post.title}</strong>
                        <small>{post.publishedLabel}</small>
                      </span>
                    </a>
                  ))}
                </div>
              </section>

              <section class="sidebar-card sync-card">
                <p class="sidebar-label">Build sync</p>
                <h2>{syncLabel}</h2>
                <p>{posts.length} public posts currently mirrored from Patreon to the website feed.</p>
              </section>
            </aside>
          </section>
        ) : (
          <section class="empty-state empty-state-static">
            <p class="eyebrow">Awaiting Sync</p>
            <h2>No Patreon posts have been mirrored yet.</h2>
            <p>Once the Patreon sync runs successfully, public posts will appear here automatically.</p>
          </section>
        )
      }
    </main>
  </div>
</BaseLayout>

<style>
  :global(body.taom-news-body) {
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(112, 75, 30, 0.18), transparent 26%),
      radial-gradient(circle at 86% 16%, rgba(87, 87, 87, 0.12), transparent 22%),
      linear-gradient(180deg, #090909 0%, #050505 100%);
    color: #f4f2ee;
  }

  :global(body.taom-news-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 7, 7, 0.72), rgba(5, 5, 5, 0.94)),
      url('/images/hero-bg.jpg') center top / cover no-repeat;
    opacity: 0.08;
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-news-main) {
    display: block;
  }

  .news-page {
    min-height: 100vh;
    padding: 2rem 0.5rem;
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
  }

  .topbar-wrap {
    width: 100%;
  }

  .news-shell {
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    padding: 2.4rem 0.75rem 3.5rem;
    display: grid;
    gap: 1.2rem;
  }

  .feed-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem 2rem;
    flex-wrap: wrap;
  }

  .feed-heading {
    display: grid;
    gap: 0.55rem;
  }

  .eyebrow,
  .sidebar-label,
  .filter-chip,
  .filter-toggle {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .eyebrow,
  .sidebar-label {
    margin: 0;
    color: rgba(211, 164, 81, 0.84);
    font-size: 0.78rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .feed-heading h1,
  .featured-body h2,
  .post-copy h3,
  .sidebar-card h2,
  .empty-state h2 {
    margin: 0;
    color: #ffffff;
  }

  .feed-heading h1 {
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 0.96;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .feed-tools {
    display: none;
  }

  .sidebar-card,
  .featured-post,
  .post-card,
  .empty-state {
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: rgba(19, 19, 19, 0.94);
    box-shadow:
      0 20px 44px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .feed-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(18rem, 0.82fr);
    gap: 1.5rem;
    align-items: start;
  }

  .feed-main {
    display: grid;
    gap: 1rem;
  }

  .featured-post,
  .post-card,
  .sidebar-card {
    border-radius: 1rem;
    overflow: hidden;
  }

  .featured-post {
    display: grid;
  }

  .featured-media {
    display: block;
    aspect-ratio: 16 / 7;
    background: #0b0b0b;
  }

  .featured-media img,
  .post-thumb img,
  .popular-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-body {
    display: grid;
    gap: 1rem;
    padding: 1.5rem 1.6rem 1.2rem;
    background: linear-gradient(180deg, rgba(34, 34, 34, 0.95), rgba(25, 25, 25, 0.98));
  }

  .post-meta-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.96rem;
  }

  .featured-body h2 {
    font-size: clamp(2rem, 3.6vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .featured-body h2 a,
  .post-copy h3 a,
  .popular-item,
  .community-link {
    color: inherit;
    text-decoration: none;
  }

  .featured-body h2 a:hover,
  .post-copy h3 a:hover,
  .popular-item:hover strong,
  .community-link:hover span:first-child {
    text-decoration: underline;
  }

  .featured-summary,
  .post-copy p,
  .sidebar-card p,
  .empty-state p {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.6;
  }

  .featured-footer,
  .post-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .post-links {
    justify-content: start;
  }

  .primary-link,
  .secondary-link,
  .share-link {
    color: #f6e1bb;
    text-decoration: none;
    font-weight: 700;
  }

  .primary-link:hover,
  .secondary-link:hover,
  .share-link:hover {
    text-decoration: underline;
  }

  .secondary-link,
  .share-link {
    color: rgba(246, 225, 187, 0.72);
  }

  .post-stack {
    display: grid;
    gap: 1rem;
  }

  .post-card {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
  }

  .post-thumb {
    display: block;
    min-height: 100%;
    background: #0b0b0b;
  }

  .post-copy {
    display: grid;
    gap: 0.8rem;
    padding: 1.1rem 1.2rem;
  }

  .post-copy h3 {
    font-size: 1.55rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .feed-sidebar {
    position: sticky;
    top: 7.5rem;
    display: grid;
    gap: 1rem;
  }

  .sidebar-card {
    padding: 1.4rem;
    display: grid;
    gap: 0.9rem;
  }

  .sidebar-card h2 {
    font-size: 1.5rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .community-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 0.9rem;
    background: #090909;
    font-weight: 700;
  }

  .community-arrow {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    aspect-ratio: 1;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    font-size: 1.25rem;
    line-height: 1;
  }

  .popular-card {
    gap: 1rem;
  }

  .sidebar-heading {
    display: grid;
    gap: 0.5rem;
  }

  .popular-list {
    display: grid;
    gap: 0.85rem;
  }

  .popular-item {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
  }

  .popular-item img {
    aspect-ratio: 1.1 / 1;
    border-radius: 0.75rem;
    background: #0b0b0b;
  }

  .popular-item span {
    display: grid;
    gap: 0.3rem;
  }

  .popular-item strong {
    color: #ffffff;
    font-size: 1.02rem;
    line-height: 1.15;
  }

  .popular-item small {
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.92rem;
  }

  .empty-state {
    padding: 1.4rem;
    border-radius: 1rem;
    display: grid;
    gap: 0.7rem;
  }

  .empty-state h2 {
    font-size: 1.8rem;
    line-height: 1.05;
  }

  .empty-state-static {
    max-width: 42rem;
  }

  @media (max-width: 1080px) {
    .feed-layout {
      grid-template-columns: 1fr;
    }

    .feed-sidebar {
      position: static;
    }
  }

  @media (max-width: 820px) {
    .post-card {
      grid-template-columns: 1fr;
    }

    .post-thumb {
      aspect-ratio: 16 / 8;
    }
  }

  @media (max-width: 760px) {
    .news-page {
      padding: 1rem 0.15rem;
    }

    .news-shell {
      padding-inline: 0.4rem;
      padding-top: 1.8rem;
    }

    .featured-body,
    .post-copy,
    .sidebar-card,
    .empty-state {
      padding: 1.15rem;
    }

    .featured-body h2 {
      font-size: clamp(1.9rem, 8vw, 2.5rem);
    }

    .post-copy h3 {
      font-size: 1.3rem;
    }
  }
</style>
