---
import Topbar from '../../components/Topbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import newsFeed from '../../data/patreon-posts.json';

export function getStaticPaths() {
  return newsFeed.posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={post.title}
  description={post.excerpt || 'TAOM development news mirrored from Patreon.'}
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-news-post-body"
  mainClass="taom-news-post-main"
>
  <div class="post-page">
    <div class="topbar-wrap">
      <Topbar />
    </div>

    <main class="post-shell">
      <section class="post-hero">
        <p class="eyebrow">Campaign Dispatch</p>
        <h1>{post.title}</h1>
        <div class="post-meta">
          <span>{post.publishedAt ? formatter.format(new Date(post.publishedAt)) : 'Unpublished'}</span>
          <span>Patreon Mirror</span>
        </div>
        <p class="page-breadcrumb"><a href="/news">News</a> / {post.title}</p>
      </section>

      <section class="post-layout">
        <article class="post-article">
          {
            post.html ? (
              <div class="article-body" set:html={post.html} />
            ) : (
              <p class="empty-copy">No post content was returned from Patreon for this entry.</p>
            )
          }
        </article>

        <aside class="post-sidebar">
          <section class="sidebar-card">
            <p class="sidebar-kicker">Source</p>
            <h2>Patreon Origin</h2>
            <p>This article was synced from the official TAOM Patreon post feed during the site build.</p>
            {
              post.patreonUrl && (
                <a href={post.patreonUrl} target="_blank" rel="noreferrer">
                  Open on Patreon
                </a>
              )
            }
          </section>
        </aside>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  :global(body.taom-news-post-body) {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(7, 5, 5, 0.74), rgba(7, 5, 5, 0.98)),
      radial-gradient(circle at 18% 14%, rgba(151, 94, 46, 0.16), transparent 24%),
      radial-gradient(circle at 84% 20%, rgba(82, 104, 128, 0.15), transparent 24%),
      linear-gradient(180deg, #17110f 0%, #0d0908 48%, #080606 100%);
    color: #ece4db;
  }

  :global(body.taom-news-post-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 10, 9, 0.34), rgba(8, 6, 6, 0.84)),
      url('/images/hero-bg.jpg') center top / cover no-repeat;
    opacity: 0.14;
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-news-post-main) {
    display: block;
  }

  .post-page {
    min-height: 100vh;
    padding: 2rem 0.5rem;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .topbar-wrap {
    width: 100%;
  }

  .post-shell {
    width: 100%;
    max-width: 84rem;
    margin: 0 auto;
    padding: 2.25rem 0.75rem 3.5rem;
    display: grid;
    gap: 1.5rem;
  }

  .post-hero {
    display: grid;
    gap: 0.8rem;
    max-width: 56rem;
  }

  .eyebrow,
  .sidebar-kicker {
    margin: 0;
    color: #c19748;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: 0.86rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .post-hero h1,
  .sidebar-card h2 {
    margin: 0;
    color: #f2ece4;
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .post-hero h1 {
    font-size: clamp(2.7rem, 6vw, 4.9rem);
    line-height: 0.96;
  }

  .post-meta,
  .page-breadcrumb,
  .sidebar-card p,
  .empty-copy {
    color: rgba(224, 213, 198, 0.78);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.92rem;
  }

  .page-breadcrumb a,
  .sidebar-card a {
    color: #d7b26c;
    text-decoration: none;
  }

  .page-breadcrumb a:hover,
  .sidebar-card a:hover {
    text-decoration: underline;
  }

  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.65fr);
    gap: 1rem;
    align-items: start;
  }

  .post-article,
  .sidebar-card {
    border: 1px solid rgba(120, 89, 38, 0.55);
    background:
      linear-gradient(180deg, rgba(16, 12, 10, 0.95), rgba(8, 7, 7, 0.92)),
      linear-gradient(120deg, rgba(160, 111, 51, 0.07), transparent 52%);
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.28),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .post-article {
    padding: 1.6rem;
  }

  :global(.article-body) {
    color: #f1eadf;
    line-height: 1.8;
    font-size: 1.03rem;
  }

  :global(.article-body > :first-child) {
    margin-top: 0;
  }

  :global(.article-body a) {
    color: #d7b26c;
  }

  :global(.article-body img) {
    max-width: 100%;
    height: auto;
  }

  :global(.article-body h1),
  :global(.article-body h2),
  :global(.article-body h3),
  :global(.article-body h4) {
    color: #f5efe6;
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  :global(.article-body blockquote) {
    margin: 1.4rem 0;
    padding-left: 1rem;
    border-left: 2px solid rgba(209, 154, 51, 0.42);
    color: rgba(241, 234, 223, 0.82);
  }

  .post-sidebar {
    display: grid;
    gap: 1rem;
  }

  .sidebar-card {
    padding: 1.2rem;
    display: grid;
    gap: 0.7rem;
  }

  .sidebar-card h2 {
    font-size: 1.45rem;
  }

  @media (max-width: 980px) {
    .post-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .post-page {
      padding: 1rem 0.15rem;
    }

    .post-shell {
      padding-inline: 0.4rem;
    }
  }
</style>
