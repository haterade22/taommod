---
import Topbar from '../components/Topbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseWeaponry, getCultureDisplayName, parseKingdomsFromXslt } from '../lib/parse-xml';

const kingdoms = parseKingdomsFromXslt();

const CATEGORY_LABELS: Record<string, string> = {
  Weapon: 'Melee',
  Bow: 'Ranged',
  Shield: 'Shield',
};

const WEAPON_CLASS_LABELS: Record<string, string> = {
  OneHandedSword: 'One-Handed Sword',
  TwoHandedSword: 'Two-Handed Sword',
  OneHandedAxe: 'One-Handed Axe',
  TwoHandedAxe: 'Two-Handed Axe',
  Mace: 'Mace',
  TwoHandedMace: 'Two-Handed Mace',
  TwoHandedPolearm: 'Polearm',
  Pike: 'Pike',
  Javelin: 'Javelin',
  Bow: 'Bow',
  Crossbow: 'Crossbow',
  Arrow: 'Arrow',
  Bolt: 'Bolt',
  Shield: 'Shield',
};

function normalizeColor(value: string): string | null {
  if (!value) return null;
  const cleaned = value.trim().replace(/^0x/i, '').replace(/^#/i, '');
  if (cleaned.length === 8) return `#${cleaned.slice(2).toUpperCase()}`;
  if (cleaned.length === 6) return `#${cleaned.toUpperCase()}`;
  return null;
}

function hexToRgb(hex: string): string {
  const cleaned = hex.replace('#', '');
  const numeric = Number.parseInt(cleaned, 16);
  const red = (numeric >> 16) & 255;
  const green = (numeric >> 8) & 255;
  const blue = numeric & 255;
  return `${red}, ${green}, ${blue}`;
}

function formatCategory(type: string): string {
  return CATEGORY_LABELS[type] || type;
}

function formatWeaponClass(weaponClass: string): string {
  if (WEAPON_CLASS_LABELS[weaponClass]) return WEAPON_CLASS_LABELS[weaponClass];
  return weaponClass.replace(/([a-z])([A-Z])/g, '$1 $2');
}

function cellClass(value: number, extra = ''): string {
  return ['col-num', extra, value === 0 ? 'is-empty' : ''].filter(Boolean).join(' ');
}

function formatTradeLabel(isMerchandise: boolean): string {
  return isMerchandise ? 'Market' : 'Locked';
}

const fallbackCultureColors: Record<string, string> = {
  mercenary: '#8F7A60',
  troll: '#6E6A48',
  lothlorien: '#D8C371',
};

const cultureColorMap = new Map<string, { hex: string; rgb: string }>();
for (const kingdom of kingdoms) {
  const hex = normalizeColor(kingdom.color);
  if (hex && kingdom.culture) {
    cultureColorMap.set(kingdom.culture, { hex, rgb: hexToRgb(hex) });
  }
}

for (const [culture, hex] of Object.entries(fallbackCultureColors)) {
  if (!cultureColorMap.has(culture)) {
    cultureColorMap.set(culture, { hex, rgb: hexToRgb(hex) });
  }
}

function getCultureRowStyle(culture: string): string {
  const tone = cultureColorMap.get(culture) ?? { hex: '#7A664A', rgb: '122, 102, 74' };
  return `--culture-accent:${tone.hex}; --culture-rgb:${tone.rgb};`;
}

const allItems = parseWeaponry()
  .filter((item) => !(item.culture === 'khuzait' && item.weaponClass === 'OneHandedSword'))
  .sort((a, b) => {
    const cultureCompare = getCultureDisplayName(a.culture).localeCompare(getCultureDisplayName(b.culture));
    if (cultureCompare !== 0) return cultureCompare;

    const categoryCompare = formatCategory(a.type).localeCompare(formatCategory(b.type));
    if (categoryCompare !== 0) return categoryCompare;

    const classCompare = formatWeaponClass(a.weaponClass).localeCompare(formatWeaponClass(b.weaponClass));
    if (classCompare !== 0) return classCompare;

    return a.name.localeCompare(b.name);
  });

const cultures = [...new Set(allItems.map((item) => item.culture).filter(Boolean))].sort((a, b) =>
  getCultureDisplayName(a).localeCompare(getCultureDisplayName(b)),
);

const classOptions = [...new Set(allItems.map((item) => item.weaponClass).filter(Boolean))].sort((a, b) =>
  formatWeaponClass(a).localeCompare(formatWeaponClass(b)),
);

const totalItems = allItems.length;
const merchantCount = allItems.filter((item) => item.isMerchandise).length;
const meleeCount = allItems.filter((item) => item.type === 'Weapon').length;
const rangedCount = allItems.filter((item) => item.type === 'Bow').length;
const shieldCount = allItems.filter((item) => item.type === 'Shield').length;

const cultureCounts = new Map<string, number>();
for (const item of allItems) {
  cultureCounts.set(item.culture, (cultureCounts.get(item.culture) || 0) + 1);
}

const cultureTabs = [
  { culture: 'all', label: 'All', count: totalItems },
  ...cultures.map((culture) => ({
    culture,
    label: getCultureDisplayName(culture) || culture,
    count: cultureCounts.get(culture) || 0,
  })),
];

const headerCols = [
  { col: 'name', label: 'Name', cls: '' },
  { col: 'culture', label: 'Culture', cls: '' },
  { col: 'type', label: 'Category', cls: '' },
  { col: 'weaponClass', label: 'Class', cls: '' },
  { col: 'swingDamage', label: 'Swing', cls: 'col-num section-start' },
  { col: 'swingDamageType', label: 'Swing Type', cls: '' },
  { col: 'estimatedSwingDamage', label: 'Est. Swing', cls: 'col-num est-cell' },
  { col: 'thrustDamage', label: 'Thrust', cls: 'col-num' },
  { col: 'thrustDamageType', label: 'Thrust Type', cls: '' },
  { col: 'estimatedThrustDamage', label: 'Est. Thrust', cls: 'col-num est-cell' },
  { col: 'accuracy', label: 'Accuracy', cls: 'col-num section-start' },
  { col: 'missileSpeed', label: 'Missile Speed', cls: 'col-num' },
  { col: 'speed', label: 'Speed', cls: 'col-num' },
  { col: 'difficulty', label: 'Difficulty', cls: 'col-num' },
  { col: 'weaponLength', label: 'Length', cls: 'col-num' },
  { col: 'weight', label: 'Weight', cls: 'col-num' },
  { col: 'bodyArmor', label: 'Armor', cls: 'col-num section-start' },
  { col: 'hitPoints', label: 'HP', cls: 'col-num' },
  { col: 'trade', label: 'Trade', cls: 'section-start' },
  { col: 'id', label: 'Id', cls: '' },
];
---

<BaseLayout
  title="Weaponry"
  description="Complete weapons and shields database for TAOM - browse every culture, class, and combat stat in one archive"
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-weaponry-body"
  mainClass="taom-weaponry-main"
>
  <div class="weaponry-page">
    <Topbar />

    <main class="weaponry-shell">
      <div class="weaponry-overview">
        <section class="page-intro">
          <p class="eyebrow">Arms of Middle-earth</p>
          <h1>Weaponry</h1>
          <p class="intro-copy">
            Browse the full TAOM arsenal through one searchable ledger. Compare blades, missile weapons, and shields by
            culture, handling, reach, and estimated damage without bouncing between separate sections.
          </p>
        </section>

        <section class="weaponry-summary" aria-label="Weapon database summary">
          <article class="summary-card">
            <span class="summary-label">Total Arms</span>
            <strong>{totalItems}</strong>
          </article>
          <article class="summary-card">
            <span class="summary-label">Realms Covered</span>
            <strong>{cultures.length}</strong>
          </article>
          <article class="summary-card">
            <span class="summary-label">Merchant Stock</span>
            <strong>{merchantCount}</strong>
          </article>
        </section>

        <section class="utility-panel">
          <div class="balance-callout">
            <p class="balance-kicker">Balance Notes</p>
            <h2>See How the Arsenal Was Tuned</h2>
            <p>
              Want the design logic behind faction quality, damage curves, and culture-specific weapon identities? The
              balancing notes break down the current approach in detail.
            </p>
            <a href="/mod-info/weapon-balancing">Open Weapon Balancing</a>
          </div>

          <div class="controls-card">
            <div class="controls-heading">
              <p class="controls-kicker">Filter the Arsenal</p>
              <span class="result-count" id="result-count">{totalItems} items</span>
            </div>

            <div class="table-controls">
              <label class="control-field control-search">
                <span>Search</span>
                <input type="text" id="search" placeholder="Search by name, ID, or class..." />
              </label>

              <label class="control-field">
                <span>Category</span>
                <select id="filter-category">
                  <option value="">All Categories</option>
                  <option value="Weapon">Melee</option>
                  <option value="Bow">Ranged</option>
                  <option value="Shield">Shields</option>
                </select>
              </label>

              <label class="control-field">
                <span>Class</span>
                <select id="filter-class">
                  <option value="">All Classes</option>
                  {
                    classOptions.map((weaponClass) => (
                      <option value={weaponClass}>{formatWeaponClass(weaponClass)}</option>
                    ))
                  }
                </select>
              </label>

              <label class="control-field">
                <span>Trade</span>
                <select id="filter-stock">
                  <option value="">All Items</option>
                  <option value="market">Market Stock</option>
                  <option value="locked">Locked / Hero Only</option>
                </select>
              </label>
            </div>

            <p class="est-note">
              <strong>Estimated damage</strong> follows the TaleWorlds physics pipeline used by TAOM&apos;s crafted weapons.
              In-game damage still shifts with speed bonus, impact point, perks, and armor.
            </p>
          </div>
        </section>
      </div>

      <section class="sections-stack">
        <div class="realm-browser">
          <div class="realm-header">
            <div class="realm-tabs-shell">
              <div class="realm-tabs" role="tablist" aria-label="Select a weapon culture">
                {
                  cultureTabs.map((tab) => (
                    <button
                      type="button"
                      class:list={['realm-tab', { 'is-selected': tab.culture === 'all' }]}
                      data-culture={tab.culture}
                      role="tab"
                      aria-selected={tab.culture === 'all' ? 'true' : 'false'}
                    >
                      <span>{tab.label}</span>
                      <small>({tab.count})</small>
                    </button>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="roster-panel">
            <div class="roster-panel-head">
              <div>
                <p class="roster-panel-title">Armory Ledger</p>
                <p class="roster-panel-subtitle">
                  {meleeCount} melee, {rangedCount} ranged, and {shieldCount} shields in one sortable archive.
                </p>
              </div>
              <span class="section-count" id="table-count">({totalItems})</span>
            </div>

            <div class="data-table-wrapper">
              <table class="data-table weapon-section">
                <thead>
                  <tr>
                    {
                      headerCols.map((header) => (
                        <th data-col={header.col} class={header.cls}>
                          {header.label}
                        </th>
                      ))
                    }
                  </tr>
                </thead>
                <tbody id="weaponry-table-body">
                  {
                    allItems.map((item) => (
                      <tr
                        data-name={item.name.toLowerCase()}
                        data-id={item.id.toLowerCase()}
                        data-culture={item.culture}
                        data-category={item.type}
                        data-class={item.weaponClass}
                        data-stock={item.isMerchandise ? 'market' : 'locked'}
                        data-search={`${item.name} ${item.id} ${formatWeaponClass(item.weaponClass)} ${getCultureDisplayName(item.culture)}`.toLowerCase()}
                        style={getCultureRowStyle(item.culture)}
                      >
                        <td class="weapon-name-cell">
                          <span class="weapon-name">{item.name}</span>
                        </td>
                        <td>{getCultureDisplayName(item.culture)}</td>
                        <td>{formatCategory(item.type)}</td>
                        <td>{formatWeaponClass(item.weaponClass)}</td>
                        <td class={cellClass(item.swingDamage, 'section-start')}>{item.swingDamage || ''}</td>
                        <td>{item.swingDamageType || ''}</td>
                        <td class={cellClass(item.estimatedSwingDamage, 'est-cell')}>
                          {item.estimatedSwingDamage || ''}
                        </td>
                        <td class={cellClass(item.thrustDamage)}>{item.thrustDamage || ''}</td>
                        <td>{item.thrustDamageType || ''}</td>
                        <td class={cellClass(item.estimatedThrustDamage, 'est-cell')}>
                          {item.estimatedThrustDamage || ''}
                        </td>
                        <td class={cellClass(item.accuracy, 'section-start')}>{item.accuracy || ''}</td>
                        <td class={cellClass(item.missileSpeed)}>{item.missileSpeed || ''}</td>
                        <td class={cellClass(item.speed)}>{item.speed || ''}</td>
                        <td class={cellClass(item.difficulty)}>{item.difficulty || ''}</td>
                        <td class={cellClass(item.weaponLength)}>{item.weaponLength || ''}</td>
                        <td class={cellClass(item.weight)}>{item.weight || ''}</td>
                        <td class={cellClass(item.bodyArmor, 'section-start')}>{item.bodyArmor || ''}</td>
                        <td class={cellClass(item.hitPoints)}>{item.hitPoints || ''}</td>
                        <td class="section-start">
                          <span class:list={['trade-badge', { 'is-market': item.isMerchandise }]}>
                            {formatTradeLabel(item.isMerchandise)}
                          </span>
                        </td>
                        <td class="col-id">{item.id}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>

            <p class="empty-state" id="empty-state" hidden>No weapons match the current realm and filter selection.</p>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  import { initSorting } from '../scripts/data-table';

  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const categoryFilter = document.getElementById('filter-category') as HTMLSelectElement;
    const classFilter = document.getElementById('filter-class') as HTMLSelectElement;
    const stockFilter = document.getElementById('filter-stock') as HTMLSelectElement;
    const resultCount = document.getElementById('result-count') as HTMLElement;
    const tableCount = document.getElementById('table-count') as HTMLElement;
    const emptyState = document.getElementById('empty-state') as HTMLElement;
    const tabButtons = Array.from(document.querySelectorAll('.realm-tab')) as HTMLButtonElement[];
    const tableBody = document.getElementById('weaponry-table-body') as HTMLTableSectionElement;
    const rows = Array.from(tableBody.querySelectorAll('tr')) as HTMLTableRowElement[];

    if (!searchInput || !categoryFilter || !classFilter || !stockFilter || !resultCount || !tableCount || !emptyState) {
      return;
    }

    const params = new URLSearchParams(window.location.search);
    searchInput.value = params.get('search') || '';
    categoryFilter.value = params.get('category') || '';
    classFilter.value = params.get('weaponClass') || '';
    stockFilter.value = params.get('stock') || '';

    let activeCulture = params.get('culture') || 'all';
    if (!tabButtons.some((button) => button.dataset.culture === activeCulture)) {
      activeCulture = 'all';
    }

    function updateUrl() {
      const nextParams = new URLSearchParams();
      if (searchInput.value) nextParams.set('search', searchInput.value);
      if (categoryFilter.value) nextParams.set('category', categoryFilter.value);
      if (classFilter.value) nextParams.set('weaponClass', classFilter.value);
      if (stockFilter.value) nextParams.set('stock', stockFilter.value);
      if (activeCulture !== 'all') nextParams.set('culture', activeCulture);

      const query = nextParams.toString();
      const url = query ? `${window.location.pathname}?${query}` : window.location.pathname;
      window.history.replaceState({}, '', url);
    }

    function filterRows() {
      const search = searchInput.value.toLowerCase();
      const category = categoryFilter.value;
      const weaponClass = classFilter.value;
      const stock = stockFilter.value;
      let visibleCount = 0;

      for (const row of rows) {
        const searchText = row.dataset.search || '';
        const rowCulture = row.dataset.culture || '';
        const rowCategory = row.dataset.category || '';
        const rowClass = row.dataset.class || '';
        const rowStock = row.dataset.stock || '';

        const matchesCulture = activeCulture === 'all' || rowCulture === activeCulture;
        const matchesSearch = !search || searchText.includes(search);
        const matchesCategory = !category || rowCategory === category;
        const matchesClass = !weaponClass || rowClass === weaponClass;
        const matchesStock = !stock || rowStock === stock;

        const show = matchesCulture && matchesSearch && matchesCategory && matchesClass && matchesStock;
        row.style.display = show ? '' : 'none';
        if (show) visibleCount += 1;
      }

      tabButtons.forEach((button) => {
        const selected = button.dataset.culture === activeCulture;
        button.classList.toggle('is-selected', selected);
        button.setAttribute('aria-selected', selected ? 'true' : 'false');
      });

      resultCount.textContent = `${visibleCount} items`;
      tableCount.textContent = `(${visibleCount})`;
      emptyState.hidden = visibleCount !== 0;
      updateUrl();
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCulture = button.dataset.culture || 'all';
        filterRows();
      });
    });

    searchInput.addEventListener('input', filterRows);
    categoryFilter.addEventListener('change', filterRows);
    classFilter.addEventListener('change', filterRows);
    stockFilter.addEventListener('change', filterRows);

    initSorting('table.weapon-section');
    filterRows();
  });
</script>

<style>
  :global(body.taom-weaponry-body) {
    min-height: 100vh;
    background:
      linear-gradient(180deg, rgba(8, 7, 8, 0.68), rgba(8, 7, 8, 0.97)),
      radial-gradient(circle at 14% 16%, rgba(114, 74, 37, 0.18), transparent 24%),
      radial-gradient(circle at 82% 18%, rgba(68, 82, 98, 0.16), transparent 24%),
      linear-gradient(180deg, #171210 0%, #0d0a09 46%, #070606 100%);
    color: #ece4db;
  }

  :global(body.taom-weaponry-body::before) {
    content: '';
    position: fixed;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(14, 11, 10, 0.36), rgba(8, 6, 6, 0.84)),
      url('/images/hero-bg.jpg') center top / cover no-repeat;
    opacity: 0.14;
    pointer-events: none;
    z-index: -2;
  }

  :global(.taom-weaponry-main) {
    display: block;
  }

  .weaponry-page {
    min-height: 100vh;
    padding: 2rem;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .weaponry-overview {
    max-width: 82.5rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .weaponry-shell {
    width: 100%;
    max-width: none;
    margin: 0 auto;
    padding: 2.25rem 0 3.375rem;
  }

  .weaponry-overview {
    display: grid;
    gap: 1.75rem;
  }

  .page-intro {
    display: grid;
    gap: 0.8rem;
    max-width: 54rem;
  }

  .eyebrow,
  .summary-label,
  .controls-kicker,
  .balance-kicker,
  .result-count,
  .roster-panel-title,
  .roster-panel-subtitle,
  .realm-tab {
    font-family: 'Cinzel', 'Times New Roman', serif;
  }

  .eyebrow,
  .controls-kicker,
  .balance-kicker {
    color: #c49245;
    font-size: 0.88rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .page-intro h1 {
    margin: 0;
    color: #f2ece4;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: clamp(3.8rem, 8vw, 6.1rem);
    line-height: 0.92;
    font-weight: 600;
    text-transform: uppercase;
  }

  .intro-copy {
    margin: 0;
    max-width: 46rem;
    color: rgba(238, 228, 219, 0.92);
    font-size: 1.25rem;
    line-height: 1.44;
  }

  .weaponry-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.95rem;
  }

  .summary-card,
  .controls-card,
  .roster-panel,
  .realm-header {
    border: 1px solid rgba(120, 89, 38, 0.55);
    background:
      linear-gradient(180deg, rgba(16, 12, 10, 0.95), rgba(8, 7, 7, 0.92)),
      linear-gradient(120deg, rgba(160, 111, 51, 0.07), transparent 52%);
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.28),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .summary-card {
    padding: 1.15rem 1.25rem;
    display: grid;
    gap: 0.45rem;
  }

  .summary-label {
    color: rgba(207, 182, 132, 0.85);
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .summary-card strong {
    color: #f6f0e6;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1;
  }

  .utility-panel {
    display: grid;
    grid-template-columns: minmax(18rem, 23rem) minmax(0, 1.3fr);
    gap: 1.15rem;
    align-items: stretch;
  }

  .balance-callout {
    padding: 1.35rem 1.4rem;
    border: 1px solid rgba(129, 90, 43, 0.5);
    background:
      linear-gradient(180deg, rgba(34, 24, 17, 0.95), rgba(12, 9, 8, 0.96)),
      radial-gradient(circle at top right, rgba(210, 145, 50, 0.14), transparent 42%);
    box-shadow:
      0 16px 34px rgba(0, 0, 0, 0.24),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    display: grid;
    gap: 0.85rem;
  }

  .balance-callout h2 {
    margin: 0;
    color: #f4ede3;
    font-family: 'Cinzel', 'Times New Roman', serif;
    font-size: 1.75rem;
    line-height: 1.08;
  }

  .balance-callout p {
    margin: 0;
    color: rgba(226, 216, 205, 0.88);
    line-height: 1.55;
  }

  .balance-callout a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 2.9rem;
    padding: 0.7rem 1.2rem;
    border: 1px solid rgba(190, 141, 57, 0.5);
    background: linear-gradient(180deg, rgba(67, 49, 27, 0.9), rgba(23, 18, 12, 0.95));
    color: #f7e7c7;
    font-family: 'Cinzel', 'Times New Roman', serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .balance-callout a:hover {
    color: #fff4df;
    border-color: rgba(235, 186, 83, 0.72);
    background: linear-gradient(180deg, rgba(93, 65, 31, 0.92), rgba(32, 23, 15, 0.97));
    transform: translateY(-1px);
    text-decoration: none;
  }

  .controls-card {
    padding: 1.35rem;
    overflow: visible;
  }

  .controls-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .result-count {
    color: rgba(240, 227, 206, 0.92);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
  }

  .table-controls {
    display: grid;
    grid-template-columns: minmax(18rem, 2.4fr) repeat(3, minmax(11rem, 1fr));
    gap: 1rem;
  }

  .control-field {
    display: grid;
    gap: 0.35rem;
  }

  .control-field span {
    color: rgba(207, 182, 132, 0.8);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .control-field input,
  .control-field select {
    width: 100%;
    min-width: 0;
    min-height: 3rem;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(140, 111, 70, 0.44);
    background: rgba(9, 8, 8, 0.88);
    color: #f0e7db;
