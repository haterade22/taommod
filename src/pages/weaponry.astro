---
import BaseLayout from '../layouts/BaseLayout.astro';
import { parseWeaponry, getCultureDisplayName } from '../lib/parse-xml';

const allItems = parseWeaponry();

// Sort by name by default
allItems.sort((a, b) => a.name.localeCompare(b.name));

// Get unique cultures, types, and weapon classes for filters
const cultures = [...new Set(allItems.map(i => i.culture).filter(Boolean))].sort();
const types = [...new Set(allItems.map(i => i.type).filter(Boolean))].sort();
const weaponClasses = [...new Set(allItems.map(i => i.weaponClass).filter(Boolean))].sort();
---

<BaseLayout title="Weaponry" description="Complete weapons and shields database for TAOM - all cultures and stats">
  <div class="page-content">
    <h1 class="page-title">Weaponry</h1>

    <div class="table-controls">
      <input type="text" id="search" placeholder="Search by name or ID..." />
      <select id="filter-culture">
        <option value="">All Cultures</option>
        {cultures.map(c => <option value={c}>{getCultureDisplayName(c)}</option>)}
      </select>
      <select id="filter-type">
        <option value="">All Types</option>
        {types.map(t => <option value={t}>{t}</option>)}
      </select>
      <select id="filter-class">
        <option value="">All Classes</option>
        {weaponClasses.map(c => <option value={c}>{c}</option>)}
      </select>
      <span class="result-count" id="result-count">{allItems.length} items</span>
    </div>

    <div class="data-table-wrapper">
      <table class="data-table" id="weapon-table">
        <thead>
          <tr>
            <th data-col="name">Name</th>
            <th data-col="culture">Culture</th>
            <th data-col="type">Type</th>
            <th data-col="weaponClass">Class</th>
            <th data-col="weight" class="col-num">Weight</th>
            <th data-col="weaponLength" class="col-num">Length</th>
            <th data-col="handling" class="col-num">Handling</th>
            <th data-col="bodyArmor" class="col-num">Armor</th>
            <th data-col="hitPoints" class="col-num">HP</th>
            <th data-col="id" class="col-id-header">Id</th>
          </tr>
        </thead>
        <tbody>
          {allItems.map(item => (
            <tr
              data-name={item.name.toLowerCase()}
              data-id={item.id.toLowerCase()}
              data-culture={item.culture}
              data-type={item.type}
              data-class={item.weaponClass}
            >
              <td>{item.name}</td>
              <td>{getCultureDisplayName(item.culture)}</td>
              <td>{item.type}</td>
              <td>{item.weaponClass}</td>
              <td class={`col-num${item.weight === 0 ? ' skill-zero' : ''}`}>{item.weight}</td>
              <td class={`col-num${item.weaponLength === 0 ? ' skill-zero' : ''}`}>{item.weaponLength}</td>
              <td class={`col-num${item.handling === 0 ? ' skill-zero' : ''}`}>{item.handling}</td>
              <td class={`col-num${item.bodyArmor === 0 ? ' skill-zero' : ''}`}>{item.bodyArmor}</td>
              <td class={`col-num${item.hitPoints === 0 ? ' skill-zero' : ''}`}>{item.hitPoints}</td>
              <td class="col-id">{item.id}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>

<script>
  const table = document.getElementById('weapon-table') as HTMLTableElement;
  const tbody = table.querySelector('tbody')!;
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const cultureFilter = document.getElementById('filter-culture') as HTMLSelectElement;
  const typeFilter = document.getElementById('filter-type') as HTMLSelectElement;
  const classFilter = document.getElementById('filter-class') as HTMLSelectElement;
  const resultCount = document.getElementById('result-count')!;

  let sortCol = '';
  let sortAsc = true;

  function filterRows() {
    const search = searchInput.value.toLowerCase();
    const culture = cultureFilter.value;
    const type = typeFilter.value;
    const weaponClass = classFilter.value;
    let visible = 0;

    for (const row of rows) {
      const name = row.dataset.name || '';
      const id = row.dataset.id || '';
      const rowCulture = row.dataset.culture || '';
      const rowType = row.dataset.type || '';
      const rowClass = row.dataset.class || '';

      const matchesSearch = !search || name.includes(search) || id.includes(search);
      const matchesCulture = !culture || rowCulture === culture;
      const matchesType = !type || rowType === type;
      const matchesClass = !weaponClass || rowClass === weaponClass;

      const show = matchesSearch && matchesCulture && matchesType && matchesClass;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    }

    resultCount.textContent = `${visible} items`;
  }

  const params = new URLSearchParams(window.location.search);
  if (params.get('culture')) cultureFilter.value = params.get('culture')!;
  if (params.get('type')) typeFilter.value = params.get('type')!;
  if (params.get('search')) searchInput.value = params.get('search')!;

  searchInput.addEventListener('input', filterRows);
  cultureFilter.addEventListener('change', filterRows);
  typeFilter.addEventListener('change', filterRows);
  classFilter.addEventListener('change', filterRows);

  filterRows();

  // Column sorting
  const headers = table.querySelectorAll('th[data-col]');
  headers.forEach(th => {
    th.addEventListener('click', () => {
      const col = (th as HTMLElement).dataset.col!;
      if (sortCol === col) {
        sortAsc = !sortAsc;
      } else {
        sortCol = col;
        sortAsc = true;
      }

      headers.forEach(h => {
        const indicator = h.querySelector('.sort-indicator');
        if (indicator) indicator.remove();
      });
      const indicator = document.createElement('span');
      indicator.className = 'sort-indicator';
      indicator.textContent = sortAsc ? '\u25B2' : '\u25BC';
      th.appendChild(indicator);

      const colIndex = Array.from(headers).indexOf(th);
      const isNumeric = th.classList.contains('col-num');

      rows.sort((a, b) => {
        const aVal = a.cells[colIndex]?.textContent?.trim() || '';
        const bVal = b.cells[colIndex]?.textContent?.trim() || '';

        if (isNumeric) {
          const aNum = parseFloat(aVal) || 0;
          const bNum = parseFloat(bVal) || 0;
          return sortAsc ? aNum - bNum : bNum - aNum;
        }

        return sortAsc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
      });

      for (const row of rows) {
        tbody.appendChild(row);
      }
    });
  });
</script>
