---
import Topbar from '../../components/Topbar.astro';
import TroopTree from '../../components/TroopTree.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  parseAllClans,
  parseAllLords,
  parseHeroClanMap,
  parseKingdomsFromXslt,
  parseTroops,
  getCultureDisplayName,
} from '../../lib/parse-xml';
import type { Clan, Kingdom, Lord } from '../../lib/parse-xml';
import { FACTION_TROOPS } from '../../data/faction-troops';

type RouteConfig = {
  routeId: string;
  kingdomId: string;
  troopCulture: string;
};

type ClanWithLords = Clan & {
  displayName: string;
  cultureName: string;
  leader: Lord | null;
  lords: (Lord & { isLeader: boolean })[];
};

const LEGACY_ROUTE_ALIASES: Record<string, { kingdomId: string; troopCulture: string }> = {
  gondor: { kingdomId: 'empire_w', troopCulture: 'gondor' },
  mordor: { kingdomId: 'empire_s', troopCulture: 'mordor' },
};

const KINGDOM_TROOP_CULTURES: Record<string, string> = {
  empire_w: 'gondor',
  empire_s: 'mordor',
};

const CULTURE_NAME_OVERRIDES: Record<string, string> = {
  empire_w: 'Gondor',
  empire_s: 'Mordor',
  empire: 'Dunland',
  sturgia: 'Dale',
  aserai: 'Harad',
  vlandia: 'Rohan',
  battania: 'Khand',
  khuzait: 'Rhun',
};

const CREST_IMAGES: Record<string, string> = {
  empire_w: '/images/factions/gondor.png',
  empire_s: '/images/factions/mordor.png',
  erebor: '/images/factions/erebor.png',
  rivendell: '/images/factions/imladris.png',
  mirkwood: '/images/factions/mirkwood.png',
  lothlorien: '/images/factions/lothlorien.png',
  dolguldur: '/images/factions/dolguldur.png',
  umbar: '/images/factions/umbar.png',
  aserai: '/images/factions/harad.png',
  battania: '/images/factions/khand.png',
  khuzait: '/images/factions/rhun.png',
  isengard: '/images/factions/isengard.png',
  gundabad: '/images/factions/gundabad.png',
  vlandia: '/images/factions/rohan.png',
  sturgia: '/images/factions/dale.png',
  empire: '/images/factions/dunland.png',
};

const HERO_IMAGES: Record<string, string> = {
  mordor: '/images/faction-mordor.jpg',
  dolguldur: '/images/faction-dolguldur.webp',
  erebor: '/images/faction-erebor.jpg',
  khuzait: '/images/faction-rhun.webp',
  gundabad: '/images/faction-gundabad.webp',
  isengard: '/images/faction-isengard.jpg',
  empire: '/images/faction-dunland.jpg',
  rivendell: '/images/faction-rivendell.png',
  mirkwood: '/images/faction-mirkwood.png',
  aserai: '/images/faction-harad.png',
  vlandia: '/images/faction-rohan.png',
  gondor: '/images/gondor_web_ready.jpg',
};

const GROUP_ORDER = ['Infantry', 'Cavalry', 'Ranged', 'HorseArcher', 'General'];
const GROUP_LABELS: Record<string, string> = {
  Infantry: 'Infantry',
  Cavalry: 'Cavalry',
  Ranged: 'Ranged',
  HorseArcher: 'Horse Archers',
  General: 'Companions',
};

const TYPE_LABELS: Record<string, string> = {
  regular: 'Regular',
  noble: 'Noble',
  regional: 'Regional',
  unique: 'Unique',
};

const TYPE_COLORS: Record<string, string> = {
  regular: '#8ca764',
  noble: '#c8a86a',
  regional: '#6a95c8',
  unique: '#cb744b',
};

function normalizeColor(value: string): string | null {
  if (!value) return null;
  const cleaned = value.trim().replace(/^0x/i, '').replace(/^#/i, '');
  if (cleaned.length === 8) return `#${cleaned.slice(2).toUpperCase()}`;
  if (cleaned.length === 6) return `#${cleaned.toUpperCase()}`;
  return null;
}

function hexToRgb(hex: string): string {
  const cleaned = hex.replace('#', '');
  const numeric = Number.parseInt(cleaned, 16);
  const red = (numeric >> 16) & 255;
  const green = (numeric >> 8) & 255;
  const blue = numeric & 255;
  return `${red}, ${green}, ${blue}`;
}

function getDisplayName(kingdom: Kingdom): string {
  return CULTURE_NAME_OVERRIDES[kingdom.id] || kingdom.shortName || kingdom.name;
}

function getMonogram(label: string): string {
  const words = label
    .replace(/[^A-Za-z\s]/g, ' ')
    .split(/\s+/)
    .filter(Boolean);

  if (words.length === 0) return 'TA';
  if (words.length === 1) return words[0].slice(0, 2).toUpperCase();
  return `${words[0][0]}${words[1][0]}`.toUpperCase();
}

function skillCell(value: number, extra = ''): string {
  return ['col-num', extra, value === 0 ? 'skill-zero' : ''].filter(Boolean).join(' ');
}

const LORD_SKILL_LABELS: Record<string, string> = {
  OneHanded: 'One-Handed',
  TwoHanded: 'Two-Handed',
  Polearm: 'Polearm',
  Bow: 'Bow',
  Crossbow: 'Crossbow',
  Throwing: 'Throwing',
  Riding: 'Riding',
  Athletics: 'Athletics',
  Scouting: 'Scouting',
  Tactics: 'Tactics',
  Leadership: 'Leadership',
  Charm: 'Charm',
  Steward: 'Steward',
  Trade: 'Trade',
  Roguery: 'Roguery',
  Engineering: 'Engineering',
  Medicine: 'Medicine',
  Smithing: 'Smithing',
};

function getLordSkillMetrics(lord: Lord) {
  const ordered = Object.entries(LORD_SKILL_LABELS).map(([skill, label]) => ({
    skill,
    label,
    value: lord.skills[skill] || 0,
  }));

  const extras = Object.entries(lord.skills)
    .filter(([skill]) => !(skill in LORD_SKILL_LABELS))
    .map(([skill, value]) => ({
      skill,
      label: skill,
      value,
    }));

  return [...ordered, ...extras];
}

function getTraitEntries(lord: Lord) {
  return Object.entries(lord.traits)
    .filter(([, value]) => value !== 0)
    .sort(([, a], [, b]) => Math.abs(b) - Math.abs(a));
}

export function getStaticPaths() {
  const kingdomTroopCultures: Record<string, string> = {
    empire_w: 'gondor',
    empire_s: 'mordor',
  };
  const legacyRouteAliases: Record<string, { kingdomId: string; troopCulture: string }> = {
    gondor: { kingdomId: 'empire_w', troopCulture: 'gondor' },
    mordor: { kingdomId: 'empire_s', troopCulture: 'mordor' },
  };
  const kingdoms = parseKingdomsFromXslt();
  const routeConfigs: RouteConfig[] = kingdoms.map((kingdom) => ({
    routeId: kingdom.id,
    kingdomId: kingdom.id,
    troopCulture: kingdomTroopCultures[kingdom.id] || kingdom.culture,
  }));

  for (const [routeId, config] of Object.entries(legacyRouteAliases)) {
    routeConfigs.push({ routeId, ...config });
  }

  return routeConfigs.map((config) => ({
    params: { id: config.routeId },
    props: config,
  }));
}

const { routeId, kingdomId, troopCulture } = Astro.props as RouteConfig;

const kingdoms = parseKingdomsFromXslt();
const kingdom = kingdoms.find((entry) => entry.id === kingdomId);

if (!kingdom) {
  throw new Error(`Faction route "${routeId}" could not resolve kingdom "${kingdomId}".`);
}

const allTroops = parseTroops()
  .filter((troop) => troop.culture === troopCulture)
  .sort((a, b) => a.level - b.level || a.name.localeCompare(b.name));

const troopGroups = [...new Set(allTroops.map((troop) => troop.defaultGroup).filter(Boolean))].sort((a, b) => {
  const ai = GROUP_ORDER.indexOf(a);
  const bi = GROUP_ORDER.indexOf(b);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi) || a.localeCompare(b);
});

const troopTabs = [
  { id: 'all', label: 'All Units', count: allTroops.length },
  ...troopGroups.map((group) => ({
    id: group,
    label: GROUP_LABELS[group] || group,
    count: allTroops.filter((troop) => troop.defaultGroup === group).length,
  })),
];

const allClans = parseAllClans()
  .filter((clan) => clan.kingdomId === kingdom.id)
  .sort((a, b) => b.tier - a.tier || a.name.localeCompare(b.name));
const allLords = parseAllLords();
const heroClanMap = parseHeroClanMap();
const lordById = new Map<string, Lord>(allLords.map((lord) => [lord.id, lord]));

const clansWithLords: ClanWithLords[] = allClans.map((clan) => {
  const memberIds = new Set<string>();

  for (const [heroId, clanId] of heroClanMap) {
    if (clanId === clan.id) memberIds.add(heroId);
  }

  if (clan.owner) memberIds.add(clan.owner);

  const lords = Array.from(memberIds)
    .map((id) => lordById.get(id))
    .filter((lord): lord is Lord => Boolean(lord))
    .map((lord) => ({ ...lord, isLeader: lord.id === clan.owner }))
    .sort((a, b) => {
      if (a.isLeader && !b.isLeader) return -1;
      if (!a.isLeader && b.isLeader) return 1;
      return a.name.localeCompare(b.name);
    });

  return {
    ...clan,
    displayName: clan.name || clan.id,
    cultureName: getCultureDisplayName(clan.culture),
    leader: lords.find((lord) => lord.isLeader) || null,
    lords,
  };
});

const initialClan = clansWithLords[0] || null;
const troopBranches = FACTION_TROOPS[troopCulture] || [];
const displayName = getDisplayName(kingdom);
const canonicalFactionOrder = kingdoms.map((entry) => entry.id);
const currentFactionIndex = canonicalFactionOrder.indexOf(kingdom.id);
const nextFaction =
  currentFactionIndex === -1 ? null : kingdoms[(currentFactionIndex + 1) % canonicalFactionOrder.length] || null;
const nextFactionName = nextFaction ? getDisplayName(nextFaction) : '';
const nextFactionHref = nextFaction ? `/factions/${nextFaction.id}` : '';
const primaryColor = normalizeColor(kingdom.color) || '#C49A47';
const secondaryColor = normalizeColor(kingdom.color2) || '#221712';
const primaryRgb = hexToRgb(primaryColor);
const secondaryRgb = hexToRgb(secondaryColor);
const heroImage = HERO_IMAGES[troopCulture] || HERO_IMAGES[kingdom.id] || '/images/hero-bg.jpg';
const crestImage = CREST_IMAGES[kingdom.id] || '';
const totalLordCount = clansWithLords.reduce((sum, clan) => sum + clan.lords.length, 0);
const troopLevelRange = allTroops.length
  ? `${Math.min(...allTroops.map((troop) => troop.level))}-${Math.max(...allTroops.map((troop) => troop.level))}`
  : 'Pending';
const leaderName =
  (kingdom.owner ? lordById.get(kingdom.owner)?.name : '') || initialClan?.leader?.name || kingdom.rulerTitle;
const troopHeaderCols = [
  { col: 'name', label: 'Unit', cls: '' },
  { col: 'level', label: 'Tier', cls: 'col-num' },
  { col: 'defaultGroup', label: 'Class', cls: '' },
  { col: 'athletics', label: 'Ath', cls: 'col-num section-start' },
  { col: 'riding', label: 'Ride', cls: 'col-num' },
  { col: 'oneHanded', label: '1H', cls: 'col-num' },
  { col: 'twoHanded', label: '2H', cls: 'col-num' },
  { col: 'polearm', label: 'Pole', cls: 'col-num' },
  { col: 'bow', label: 'Bow', cls: 'col-num' },
  { col: 'crossbow', label: 'XBow', cls: 'col-num' },
  { col: 'throwing', label: 'Throw', cls: 'col-num' },
  { col: 'item0', label: 'Primary', cls: 'section-start' },
  { col: 'item1', label: 'Secondary', cls: '' },
  { col: 'head', label: 'Head', cls: '' },
  { col: 'body', label: 'Body', cls: '' },
  { col: 'id', label: 'Id', cls: 'section-start' },
];
---

<BaseLayout
  title={displayName}
  description={`${displayName} faction archive in TAOM - troop tree, military roster, clans, and lords`}
  hideNav={true}
  hideFooter={true}
  bodyClass="taom-faction-detail-body"
  mainClass="taom-faction-detail-main"
>
  <div
    class="faction-page"
    style={`--realm-primary:${primaryColor}; --realm-secondary:${secondaryColor}; --realm-primary-rgb:${primaryRgb}; --realm-secondary-rgb:${secondaryRgb};`}
  >
    <Topbar />

    <main class="faction-shell">
      <section class="hero-panel">
        <div class="hero-backdrop" style={`background-image: url('${heroImage}')`}></div>
        <div class="hero-overlay"></div>
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Faction Archive</p>
            <h1>{displayName}</h1>
            <p class="hero-subtitle">{kingdom.title || kingdom.rulerTitle}</p>
            <p class="hero-description">
              {
                kingdom.description ||
                  `${displayName} now carries both the military roster and noble record in one place: upgrade lines, troop classes, clans, and the lords who command them.`
              }
            </p>

            <nav class="page-breadcrumb"><a href="/factions">Faction</a> / {displayName}</nav>

            <div class="hero-links">
              <a href="#troop-tree">Troop Tree</a>
              <a href="#military-roster">Military Roster</a>
              <a href="#clan-archive">Clan Archive</a>
              {
                nextFaction && (
                  <a class="hero-next-link" href={nextFactionHref}>
                    <span>Next Faction</span>
                    <strong>{nextFactionName}</strong>
                  </a>
                )
              }
            </div>
          </div>

          <aside class="realm-seal" aria-label={`${displayName} realm dossier`}>
            <div class="seal-mark" aria-hidden="true">
              {crestImage ? <img src={crestImage} alt="" /> : <span>{getMonogram(displayName)}</span>}
            </div>

            <dl class="seal-meta">
              <div>
                <dt>Culture</dt>
                <dd>{getCultureDisplayName(troopCulture)}</dd>
              </div>
              <div>
                <dt>Ruler</dt>
                <dd>{leaderName || 'Unknown'}</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <section class="summary-grid" aria-label="Faction summary">
        <article class="summary-card">
          <span class="summary-label">Fielded Units</span>
          <strong>{allTroops.length}</strong>
          <small>Across {troopGroups.length || 0} battlefield classes</small>
        </article>
        <article class="summary-card">
          <span class="summary-label">Level Spread</span>
          <strong>{troopLevelRange}</strong>
          <small>Tracks the current troop progression ladder</small>
        </article>
        <article class="summary-card">
          <span class="summary-label">Clans</span>
          <strong>{clansWithLords.length}</strong>
          <small>Major houses tied to this realm</small>
        </article>
        <article class="summary-card">
          <span class="summary-label">Named Lords</span>
          <strong>{totalLordCount}</strong>
          <small>Clan leaders, heirs, and household members</small>
        </article>
      </section>

      <section class="utility-panel">
        <article class="dossier-card">
          <p class="panel-kicker">Realm Dossier</p>
          <h2>Military and Noble Records in One Archive</h2>
          <p>
            This page folds the old faction and kingdom views together, so you can read the military structure and noble
            hierarchy of {displayName} without jumping between routes.
          </p>

          <dl class="dossier-grid">
            <div>
              <dt>Troop Culture</dt>
              <dd>{getCultureDisplayName(troopCulture)}</dd>
            </div>
            <div>
              <dt>Ruler Title</dt>
              <dd>{kingdom.rulerTitle || 'Unknown'}</dd>
            </div>
            <div>
              <dt>Primary Color</dt>
              <dd class="color-chip">
                <span class="color-swatch" style={`background:${primaryColor}`}></span>
                <span>{primaryColor}</span>
              </dd>
            </div>
            <div>
              <dt>Secondary Color</dt>
              <dd class="color-chip">
                <span class="color-swatch" style={`background:${secondaryColor}`}></span>
                <span>{secondaryColor}</span>
              </dd>
            </div>
          </dl>
        </article>
      </section>

      {
        troopBranches.length > 0 && (
          <section class="branches-section">
            <div class="section-heading">
              <p class="section-kicker">Branch Overview</p>
              <h2>Military Traditions</h2>
              <p>
                Each branch summary preserves the faction flavor notes from the older page while sitting alongside the
                actual troop data.
              </p>
            </div>

            <div class="branch-grid">
              {troopBranches.map((branch) => (
                <article class="branch-card" style={`--branch-color:${TYPE_COLORS[branch.type]};`}>
                  <div class="branch-header">
                    <h3>{branch.name}</h3>
                    <span class="branch-type">{TYPE_LABELS[branch.type]}</span>
                  </div>
                  <div class="branch-meta">
                    <span>{branch.tiers}</span>
                    {branch.region && <span>{branch.region}</span>}
                    {branch.status === 'done' && <span>Ready</span>}
                  </div>
                  <p>{branch.description}</p>
                </article>
              ))}
            </div>
          </section>
        )
      }

      <section class="section-card troop-tree-card" id="troop-tree">
        <div class="section-heading">
          <p class="section-kicker">Military Structure</p>
          <h2>Troop Tree</h2>
          <p>Hover the tree to trace upgrade routes from recruits to elite units.</p>
        </div>

        {
          allTroops.length > 0 ? (
            <TroopTree troops={allTroops} culture={troopCulture} />
          ) : (
            <p class="pending-state">Troop data for this faction is not available in the XML set yet.</p>
          )
        }
      </section>

      <section class="section-card" id="military-roster">
        <div class="section-heading">
          <p class="section-kicker">Field Ledger</p>
          <h2>Military Roster</h2>
          <p>
            The old per-class tables are preserved as tabs here, with sortable columns so infantry, cavalry, and missile
            branches can still be reviewed separately.
          </p>
        </div>

        <article class="controls-card">
          <div class="controls-heading">
            <div>
              <p class="panel-kicker">Filter the Muster</p>
              <h2>Search the Military Roster</h2>
            </div>
            <span class="result-count" id="troop-result-count">{allTroops.length} units</span>
          </div>

          <div class="control-grid">
            <label class="control-field control-search">
              <span>Search</span>
              <input type="text" id="troop-search" placeholder="Search by troop name, ID, or class..." />
            </label>

            <label class="control-field">
              <span>Class</span>
              <select id="troop-group-filter">
                <option value="">All Classes</option>
                {troopGroups.map((group) => <option value={group}>{GROUP_LABELS[group] || group}</option>)}
              </select>
            </label>
          </div>

          <p class="controls-note">
            Troop tabs below still mirror the old class split, but the table now lives in one searchable ledger so it is
            easier to compare units across the whole faction.
          </p>
        </article>

        <div class="tab-strip" role="tablist" aria-label="Select troop class">
          {
            troopTabs.map((tab) => (
              <button
                type="button"
                class:list={['tab-button', { 'is-selected': tab.id === 'all' }]}
                data-troop-group={tab.id}
                role="tab"
                aria-selected={tab.id === 'all' ? 'true' : 'false'}
              >
                <span>{tab.label}</span>
                <small>({tab.count})</small>
              </button>
            ))
          }
        </div>

        <div class="table-shell">
          <div class="table-head">
            <div>
              <p class="table-title">Faction Troops</p>
              <p class="table-subtitle">{displayName} roster pulled directly from the troop XML data.</p>
            </div>
            <span class="table-count" id="troop-table-count">({allTroops.length})</span>
          </div>

          <div class="data-table-wrapper">
            <table class="data-table faction-troop-section">
              <thead>
                <tr>
                  {
                    troopHeaderCols.map((header) => (
                      <th data-col={header.col} class={header.cls}>
                        {header.label}
                      </th>
                    ))
                  }
                </tr>
              </thead>
              <tbody id="troop-table-body">
                {
                  allTroops.map((troop) => (
                    <tr
                      data-search={`${troop.name} ${troop.id} ${troop.defaultGroup}`.toLowerCase()}
                      data-group={troop.defaultGroup}
                    >
                      <td class="troop-name-cell">
                        <span class="troop-name">{troop.name}</span>
                      </td>
                      <td class="col-num">{troop.level}</td>
                      <td>{GROUP_LABELS[troop.defaultGroup] || troop.defaultGroup}</td>
                      <td class={skillCell(troop.athletics, 'section-start')}>{troop.athletics}</td>
                      <td class={skillCell(troop.riding)}>{troop.riding}</td>
                      <td class={skillCell(troop.oneHanded)}>{troop.oneHanded}</td>
                      <td class={skillCell(troop.twoHanded)}>{troop.twoHanded}</td>
                      <td class={skillCell(troop.polearm)}>{troop.polearm}</td>
                      <td class={skillCell(troop.bow)}>{troop.bow}</td>
                      <td class={skillCell(troop.crossbow)}>{troop.crossbow}</td>
                      <td class={skillCell(troop.throwing)}>{troop.throwing}</td>
                      <td class="col-id section-start">{troop.item0}</td>
                      <td class="col-id">{troop.item1}</td>
                      <td class="col-id">{troop.head}</td>
                      <td class="col-id">{troop.body}</td>
                      <td class="col-id section-start">{troop.id}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <p class="empty-state" id="troop-empty-state" hidden>No troops match the current class and search filter.</p>
        </div>
      </section>

      <section class="section-card clan-archive" id="clan-archive">
        <div class="section-heading">
          <p class="section-kicker">House Records</p>
          <h2>Clans and Lords</h2>
          <p>
            Select a clan to switch the visible lord roster below. The membership is resolved from the same clan and
            hero XML data already used elsewhere in the site.
          </p>
        </div>

        {
          clansWithLords.length > 0 ? (
            <div class="clan-layout">
              <div class="clan-browser" role="tablist" aria-label="Select a clan">
                {clansWithLords.map((clan, index) => (
                  <button
                    type="button"
                    class:list={['clan-button', { 'is-selected': index === 0 }]}
                    data-clan-button={clan.id}
                    role="tab"
                    aria-selected={index === 0 ? 'true' : 'false'}
                  >
                    <span class="clan-button-name">{clan.displayName}</span>
                    <span class="clan-button-meta">
                      Tier {clan.tier || 0} | {clan.lords.length} lord{clan.lords.length === 1 ? '' : 's'}
                    </span>
                  </button>
                ))}
              </div>

              <div class="clan-panels">
                {clansWithLords.map((clan, index) => (
                  <section
                    class:list={['clan-panel', { 'is-selected': index === 0 }]}
                    data-clan-panel={clan.id}
                    hidden={index !== 0}
                  >
                    <div class="clan-panel-header">
                      <div>
                        <p class="table-title">{clan.displayName}</p>
                        <p class="table-subtitle">
                          {clan.leader
                            ? `${clan.leader.name} leads this house.`
                            : 'Leader data is incomplete for this house.'}
                        </p>
                      </div>

                      <div class="clan-summary">
                        <article>
                          <span>Tier</span>
                          <strong>{clan.tier || 0}</strong>
                        </article>
                        <article>
                          <span>Culture</span>
                          <strong>{clan.cultureName}</strong>
                        </article>
                        <article>
                          <span>Members</span>
                          <strong>{clan.lords.length}</strong>
                        </article>
                      </div>
                    </div>

                    {clan.lords.length > 0 ? (
                      <>
                        <div class="lord-grid">
                          {clan.lords.map((lord) => (
                            <article class="lord-card">
                              <header class="lord-card-header">
                                <div>
                                  <div class="lord-card-name-row">
                                    <h3>{lord.name}</h3>
                                    {lord.isLeader && <span class="leader-badge">Leader</span>}
                                    {!lord.alive && <span class="dead-badge">Dead</span>}
                                  </div>
                                  <p class="lord-card-role">
                                    {lord.defaultGroup || 'Noble'}
                                    {lord.age ? ` | Age ${lord.age}` : ''}
                                  </p>
                                </div>
                              </header>

                              <div class="lord-skill-grid">
                                {getLordSkillMetrics(lord).map((entry) => (
                                  <div class="skill-meter">
                                    <div class="skill-meter-top">
                                      <span>{entry.label}</span>
                                      <strong>{entry.value}</strong>
                                    </div>
                                    <div class="skill-meter-track">
                                      <div
                                        class="skill-meter-fill"
                                        style={`width: ${Math.min((entry.value / 350) * 100, 100)}%`}
                                      />
                                    </div>
                                  </div>
                                ))}
                              </div>

                              {getTraitEntries(lord).length > 0 && (
                                <div class="trait-list">
                                  {getTraitEntries(lord).map(([trait, value]) => (
                                    <span
                                      class:list={[
                                        'trait-pill',
                                        { 'is-positive': value > 0, 'is-negative': value < 0 },
                                      ]}
                                    >
                                      {trait} {value > 0 ? `+${value}` : value}
                                    </span>
                                  ))}
                                </div>
                              )}

                              {lord.biography && (
                                <details class="lord-biography">
                                  <summary>Biography</summary>
                                  <p>{lord.biography}</p>
                                </details>
                              )}
                            </article>
                          ))}
                        </div>

                        <p class="bio-hint">
                          Each card shows only members of the selected clan, with their strongest skills surfaced first.
                        </p>
                      </>
                    ) : (
                      <p class="pending-state">No parsed lord records were found for this clan.</p>
                    )}
                  </section>
                ))}
              </div>
            </div>
          ) : (
            <p class="pending-state">No clan records were found for this faction in the current XML set.</p>
          )
        }
      </section>
    </main>
  </div>

  <script is:inline>
    const cleanupKey = '__taomFactionPageCleanup';
    const initKey = '__taomFactionPageInit';

    function initFactionPage() {
      const troopSearch = document.getElementById('troop-search');
      const troopGroupFilter = document.getElementById('troop-group-filter');
      const troopResultCount = document.getElementById('troop-result-count');
      const troopTableCount = document.getElementById('troop-table-count');
      const troopEmptyState = document.getElementById('troop-empty-state');
      const troopRows = Array.from(document.querySelectorAll('#troop-table-body tr'));
      const troopTabs = Array.from(document.querySelectorAll('[data-troop-group]'));
      const clanButtons = Array.from(document.querySelectorAll('[data-clan-button]'));
      const clanPanels = Array.from(document.querySelectorAll('[data-clan-panel]'));

      if (typeof window[cleanupKey] === 'function') {
        window[cleanupKey]();
      }

      const controller = new AbortController();
      const { signal } = controller;
      const params = new URLSearchParams(window.location.search);

      let activeTroopGroup = params.get('group') || 'all';
      let activeClan = params.get('clan') || clanButtons[0]?.dataset.clanButton || '';

      if (!troopTabs.some((button) => button.dataset.troopGroup === activeTroopGroup)) {
        activeTroopGroup = 'all';
      }

      if (!clanButtons.some((button) => button.dataset.clanButton === activeClan)) {
        activeClan = clanButtons[0]?.dataset.clanButton || '';
      }

      if (troopSearch instanceof HTMLInputElement) {
        troopSearch.value = params.get('search') || '';
      }

      if (troopGroupFilter instanceof HTMLSelectElement) {
        troopGroupFilter.value = params.get('class') || '';
      }

      function updateUrl() {
        const nextParams = new URLSearchParams();
        const searchValue = troopSearch instanceof HTMLInputElement ? troopSearch.value : '';
        const classValue = troopGroupFilter instanceof HTMLSelectElement ? troopGroupFilter.value : '';

        if (searchValue) nextParams.set('search', searchValue);
        if (classValue) nextParams.set('class', classValue);
        if (activeTroopGroup !== 'all') nextParams.set('group', activeTroopGroup);
        if (activeClan) nextParams.set('clan', activeClan);

        const query = nextParams.toString();
        const url = query ? `${window.location.pathname}?${query}` : window.location.pathname;
        window.history.replaceState({}, '', url);
      }

      function filterTroops() {
        const searchValue = troopSearch instanceof HTMLInputElement ? troopSearch.value.toLowerCase() : '';
        const classValue = troopGroupFilter instanceof HTMLSelectElement ? troopGroupFilter.value : '';
        let visibleCount = 0;

        troopRows.forEach((row) => {
          const searchText = row.dataset.search || '';
          const rowGroup = row.dataset.group || '';
          const matchesTab = activeTroopGroup === 'all' || rowGroup === activeTroopGroup;
          const matchesClass = !classValue || rowGroup === classValue;
          const matchesSearch = !searchValue || searchText.includes(searchValue);
          const show = matchesTab && matchesClass && matchesSearch;

          row.style.display = show ? '' : 'none';
          if (show) visibleCount += 1;
        });

        troopTabs.forEach((button) => {
          const selected = button.dataset.troopGroup === activeTroopGroup;
          button.classList.toggle('is-selected', selected);
          button.setAttribute('aria-selected', selected ? 'true' : 'false');
        });

        if (troopResultCount) troopResultCount.textContent = `${visibleCount} units`;
        if (troopTableCount) troopTableCount.textContent = `(${visibleCount})`;
        if (troopEmptyState) troopEmptyState.hidden = visibleCount !== 0;

        updateUrl();
      }

      function selectClan(clanId) {
        activeClan = clanId;

        clanButtons.forEach((button) => {
          const selected = button.dataset.clanButton === clanId;
          button.classList.toggle('is-selected', selected);
          button.setAttribute('aria-selected', selected ? 'true' : 'false');
        });

        clanPanels.forEach((panel) => {
          const selected = panel.dataset.clanPanel === clanId;
          panel.classList.toggle('is-selected', selected);
          panel.hidden = !selected;
        });

        updateUrl();
      }

      troopTabs.forEach((button) => {
        button.addEventListener(
          'click',
          () => {
            activeTroopGroup = button.dataset.troopGroup || 'all';
            filterTroops();
          },
          { signal },
        );
      });

      clanButtons.forEach((button) => {
        button.addEventListener(
          'click',
          () => {
            const clanId = button.dataset.clanButton;
            if (clanId) selectClan(clanId);
          },
          { signal },
        );
      });

      if (troopSearch instanceof HTMLInputElement) {
        troopSearch.addEventListener('input', filterTroops, { signal });
      }

      if (troopGroupFilter instanceof HTMLSelectElement) {
        troopGroupFilter.addEventListener('change', filterTroops, { signal });
      }

      filterTroops();
      if (activeClan) selectClan(activeClan);

      window[cleanupKey] = () => {
        controller.abort();
      };
    }

    if (!window[initKey]) {
      window[initKey] = true;
      document.addEventListener('astro:page-load', initFactionPage);
    }

    if (document.readyState !== 'loading') {
      initFactionPage();
    } else {
      document.addEventListener('DOMContentLoaded', initFactionPage, { once: true });
    }
  </script>

  <script>
    import { initSorting } from '../../scripts/data-table';

    document.addEventListener('astro:page-load', () => {
      initSorting('table.faction-troop-section');
    });
  </script>
</BaseLayout>

