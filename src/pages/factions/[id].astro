---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TroopTree from '../../components/TroopTree.astro';
import { parseTroops, getCultureDisplayName, isHiddenCulture } from '../../lib/parse-xml';
import { FACTION_TROOPS } from '../../data/faction-troops';

export const PLANNED_FACTIONS: Record<string, string> = {
  lothlorien: 'Lothlorien',
  battania: 'Khand',
  sturgia: 'Dale',
};

export function getStaticPaths() {
  const troops = parseTroops().filter(t => !isHiddenCulture(t.culture));
  const cultures = [...new Set(troops.map(t => t.culture).filter(Boolean))];
  const paths = cultures.map(culture => ({
    params: { id: culture },
    props: { culture },
  }));
  // Add planned faction pages
  for (const id of Object.keys(PLANNED_FACTIONS)) {
    if (!cultures.includes(id)) {
      paths.push({ params: { id }, props: { culture: id } });
    }
  }
  return paths;
}

const { culture } = Astro.props;
const isPlanned = culture in PLANNED_FACTIONS;
const displayName = isPlanned ? PLANNED_FACTIONS[culture] : getCultureDisplayName(culture);

const allTroops = parseTroops().filter(t => t.culture === culture);
const troopsByGroup = new Map<string, typeof allTroops>();
for (const t of allTroops) {
  const group = t.defaultGroup || 'Other';
  if (!troopsByGroup.has(group)) troopsByGroup.set(group, []);
  troopsByGroup.get(group)!.push(t);
}
// Sort troops within each group by level
for (const troops of troopsByGroup.values()) {
  troops.sort((a, b) => a.level - b.level);
}

const GROUP_ORDER = ['Infantry', 'Cavalry', 'Ranged', 'HorseArcher', 'General'];
const sortedGroups = Array.from(troopsByGroup.entries()).sort((a, b) => {
  const ai = GROUP_ORDER.indexOf(a[0]);
  const bi = GROUP_ORDER.indexOf(b[0]);
  return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
});

const totalTroops = allTroops.length;
const minLevel = Math.min(...allTroops.map(t => t.level));
const maxLevel = Math.max(...allTroops.map(t => t.level));

// Faction images
const FACTION_IMAGES: Record<string, string> = {
  mordor: '/images/faction-mordor.jpg',
  dolguldur: '/images/faction-dolguldur.webp',
  erebor: '/images/faction-erebor.jpg',
  khuzait: '/images/faction-rhun.webp',
  gundabad: '/images/faction-gundabad.webp',
  isengard: '/images/faction-isengard.jpg',
  empire: '/images/faction-dunland.jpg',
  rivendell: '/images/faction-rivendell.png',
  mirkwood: '/images/faction-mirkwood.png',
  aserai: '/images/faction-harad.png',
};

const bgImage = FACTION_IMAGES[culture];
const troopBranches = FACTION_TROOPS[culture] || [];

const TYPE_COLORS: Record<string, string> = {
  regular: '#4CAF50',
  noble: '#AB47BC',
  regional: '#42A5F5',
  unique: '#FFA726',
};
---

<BaseLayout title={displayName} description={`${displayName} faction details - troops, lore, and composition in TAOM`}>
  <div class="faction-hero" style={bgImage ? `background-image: url('${bgImage}')` : ''}>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>{displayName} {isPlanned && <span class="planned-badge">Planned</span>}</h1>
      {!isPlanned && (
        <div class="hero-stats">
          <span><strong>{totalTroops}</strong> units</span>
          <span>Levels <strong>{minLevel}</strong>-<strong>{maxLevel}</strong></span>
          <span>{sortedGroups.map(([g]) => g).join(', ')}</span>
        </div>
      )}
    </div>
  </div>

  <div class="page-content faction-page">
    <nav class="faction-breadcrumb">
      <a href="/factions">&larr; All Factions</a>
    </nav>

    {isPlanned ? (
      <section class="faction-section">
        <div class="planned-notice">
          <h2>Planned Faction</h2>
          <p>{displayName} is a planned faction for a future update of TAOM. Troops, equipment, and lore are currently in development.</p>
          <a href="/factions" class="btn btn-secondary">&larr; Back to Factions</a>
        </div>
      </section>
    ) : (
      <>
        <section class="faction-section">
          <h2>Troop Tree</h2>
          <p class="section-desc">Upgrade paths for {displayName} units. Hover to highlight connected paths.</p>
          <TroopTree troops={allTroops} culture={culture} />
        </section>

        <section class="faction-section">
          <h2>Troop Roster</h2>
          <p class="section-desc">All {displayName} units organized by role.</p>

          {sortedGroups.map(([group, troops]) => (
            <div class="group-block">
              <h3>{group} <span class="group-count">({troops.length})</span></h3>
              <div class="data-table-wrapper">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th class="col-num">Level</th>
                      <th class="col-num">1H</th>
                      <th class="col-num">2H</th>
                      <th class="col-num">Pole</th>
                      <th class="col-num">Bow</th>
                      <th class="col-num">XBow</th>
                      <th class="col-num">Throw</th>
                      <th class="col-num">Ath</th>
                      <th class="col-num">Ride</th>
                    </tr>
                  </thead>
                  <tbody>
                    {troops.map(t => (
                      <tr data-culture={culture}>
                        <td>{t.name}</td>
                        <td class="col-num">{t.level}</td>
                        <td class={t.oneHanded === 0 ? 'col-num skill-zero' : 'col-num'}>{t.oneHanded}</td>
                        <td class={t.twoHanded === 0 ? 'col-num skill-zero' : 'col-num'}>{t.twoHanded}</td>
                        <td class={t.polearm === 0 ? 'col-num skill-zero' : 'col-num'}>{t.polearm}</td>
                        <td class={t.bow === 0 ? 'col-num skill-zero' : 'col-num'}>{t.bow}</td>
                        <td class={t.crossbow === 0 ? 'col-num skill-zero' : 'col-num'}>{t.crossbow}</td>
                        <td class={t.throwing === 0 ? 'col-num skill-zero' : 'col-num'}>{t.throwing}</td>
                        <td class={t.athletics === 0 ? 'col-num skill-zero' : 'col-num'}>{t.athletics}</td>
                        <td class={t.riding === 0 ? 'col-num skill-zero' : 'col-num'}>{t.riding}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}
        </section>

        {troopBranches.length > 0 ? (
          <section class="faction-section">
            <h2>Troop Branches</h2>
            <p class="section-desc">The military branches of {displayName}, from common fodder to elite warriors.</p>
            <div class="branch-cards">
              {troopBranches.map(branch => (
                <div class="branch-card" style={`--branch-color: ${TYPE_COLORS[branch.type]}`}>
                  <div class="branch-card-header">
                    <div class="branch-title-row">
                      <h3>{branch.name}</h3>
                      {branch.status === 'done' && <span class="branch-status done">Done</span>}
                    </div>
                    <div class="branch-meta">
                      <span class="branch-tier">{branch.tiers}</span>
                      <span class="branch-type">{branch.type.charAt(0).toUpperCase() + branch.type.slice(1)}</span>
                      {branch.region && <span class="branch-region">{branch.region}</span>}
                    </div>
                  </div>
                  <p class="branch-desc">{branch.description}</p>
                </div>
              ))}
            </div>
          </section>
        ) : (
          <section class="faction-section faction-lore">
            <h2>About {displayName}</h2>
            <div class="coming-soon">
              <p>Detailed faction lore and troop branch information coming soon.</p>
            </div>
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>

<style>
  .faction-hero {
    position: relative;
    min-height: 200px;
    max-height: 300px;
    background: var(--bg-secondary) center center / cover no-repeat;
    display: flex;
    align-items: flex-end;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.3) 50%,
      rgba(25, 25, 25, 0.95) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    width: 100%;
  }

  .hero-content h1 {
    color: var(--accent);
    font-size: 2.5rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8);
    margin-bottom: 0.5rem;
  }

  .hero-stats {
    display: flex;
    gap: 1.5rem;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  .faction-page {
    max-width: 1200px;
  }

  .faction-breadcrumb {
    margin-bottom: 1.5rem;
  }

  .faction-breadcrumb a {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .faction-breadcrumb a:hover {
    color: var(--accent);
  }

  .faction-section {
    margin-bottom: 2.5rem;
  }

  .faction-section h2 {
    color: var(--accent);
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .group-block {
    margin-bottom: 1.5rem;
  }

  .group-block h3 {
    color: var(--text-primary);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .group-count {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 400;
  }

  .faction-lore {
    margin-top: 2rem;
  }

  .coming-soon {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .branch-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .branch-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-left: 4px solid var(--branch-color);
    border-radius: 6px;
    overflow: hidden;
  }

  .branch-card-header {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  .branch-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .branch-card-header h3 {
    color: var(--branch-color);
    font-size: 1rem;
    margin: 0;
  }

  .branch-status.done {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: rgba(76, 175, 80, 0.2);
    color: #4CAF50;
    letter-spacing: 0.5px;
  }

  .branch-meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.75rem;
  }

  .branch-tier {
    color: var(--text-muted);
    font-weight: 600;
  }

  .branch-type {
    color: var(--branch-color);
    font-weight: 600;
  }

  .branch-region {
    color: var(--text-secondary);
  }

  .branch-region::before {
    content: '📍 ';
  }

  .branch-desc {
    padding: 0.75rem 1rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .planned-badge {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.2rem 0.7rem;
    border: 2px dashed #d4a24c;
    border-radius: 4px;
    color: #d4a24c;
    vertical-align: middle;
    margin-left: 0.5rem;
    font-weight: 400;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .planned-notice {
    text-align: center;
    padding: 4rem 1.5rem;
    color: var(--text-secondary);
  }

  .planned-notice h2 {
    color: #d4a24c;
    font-size: 1.6rem;
    margin-bottom: 1rem;
    border: none;
  }

  .planned-notice p {
    font-size: 1rem;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto 1.5rem;
  }
</style>
