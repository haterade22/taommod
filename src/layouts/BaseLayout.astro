---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
  bodyClass?: string;
  mainClass?: string;
}

const { title, description = 'TAOM - Tales From the Age of Men - A total conversion mod for Bannerlord II' } =
  Astro.props;
const { hideNav = false, hideFooter = false, bodyClass, mainClass } = Astro.props;

type NavLink = { href: string; label: string; children?: { href: string; label: string }[] };

const navLinks: NavLink[] = [
  { href: '/', label: 'Home' },
  { href: '/kingdoms', label: 'Kingdoms' },
  {
    href: '/factions',
    label: 'Factions',
    children: [
      { href: '/factions', label: 'Overview' },
      { href: '/factions/gondor', label: 'Gondor' },
      { href: '/factions/mordor', label: 'Mordor' },
      { href: '/factions/erebor', label: 'Erebor' },
      { href: '/factions/isengard', label: 'Isengard' },
      { href: '/factions/gundabad', label: 'Gundabad' },
      { href: '/factions/vlandia', label: 'Rohan' },
      { href: '/factions/empire', label: 'Dunland' },
      { href: '/factions/aserai', label: 'Harad' },
      { href: '/factions/khuzait', label: 'Rhun' },
      { href: '/factions/battania', label: 'Khand' },
      { href: '/factions/dolguldur', label: 'Dol Guldur' },
      { href: '/factions/mirkwood', label: 'Mirkwood' },
      { href: '/factions/rivendell', label: 'Rivendell' },
      { href: '/factions/umbar', label: 'Umbar' },
      { href: '/factions/lothlorien', label: 'Lothlorien' },
      { href: '/factions/sturgia', label: 'Dale' },
    ],
  },
  {
    href: '/database',
    label: 'Database',
    children: [
      { href: '/database', label: 'Overview' },
      { href: '/troops', label: 'Troops' },
      { href: '/lords', label: 'Lords' },
      { href: '/armoury', label: 'Armoury' },
      { href: '/weaponry', label: 'Weaponry' },
    ],
  },
  {
    href: '/mod-info',
    label: 'Mod Info',
    children: [
      { href: '/mod-info', label: 'Overview' },
      { href: '/mod-info/races', label: 'Races & Creatures' },
      { href: '/mod-info/recruitment', label: 'Recruitment System' },
      { href: '/mod-info/balance-overview', label: 'Balance Overview' },
      { href: '/mod-info/troop-balancing', label: 'Troop Balancing' },
      { href: '/mod-info/armour-balancing', label: 'Armour Balancing' },
      { href: '/mod-info/weapon-balancing', label: 'Weapon Balancing' },
      { href: '/mod-info/features', label: 'Coding Features' },
    ],
  },
  { href: '/gallery', label: 'Gallery' },
  { href: '/roadmap', label: 'Roadmap' },
  { href: '/news', label: 'News' },
  { href: '/community', label: 'Community' },
  { href: '/download', label: 'Download' },
  { href: '/troubleshooting', label: 'Troubleshooting' },
  { href: '/credits', label: 'Credits' },
];

const currentPath = Astro.url.pathname;
const layoutMenuId = `site-nav-menu-${Math.random().toString(36).slice(2, 10)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | TAOM</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/cinzel-latin.woff2" as="font" type="font/woff2" crossorigin />
    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    {
      !hideNav && (
        <nav class="site-nav" transition:persist>
          <a class="logo" href="/">
            <img src="/images/logo.png" alt="TAOM" class="nav-logo" />
          </a>
          <button
            class="site-nav-toggle"
            type="button"
            aria-label="Toggle navigation"
            aria-expanded="false"
            aria-controls={layoutMenuId}
            data-site-nav-toggle
          >
            <span class="site-nav-toggle-bar" />
            <span class="site-nav-toggle-bar" />
            <span class="site-nav-toggle-bar" />
          </button>
          <div class="site-nav-menu" id={layoutMenuId} data-site-nav-menu>
            <ul class="nav-links">
              {navLinks.map((link) => (
                <li class:list={[{ 'has-dropdown': !!link.children }]}>
                  <a
                    href={link.href}
                    class:list={[
                      {
                        active:
                          currentPath === link.href ||
                          (link.href !== '/' && currentPath.startsWith(link.href)) ||
                          (link.children &&
                            link.children.some((c) => currentPath === c.href || currentPath.startsWith(c.href + '/'))),
                      },
                    ]}
                  >
                    {link.label}
                    {link.children && <span class="dropdown-arrow">&#9662;</span>}
                  </a>
                  {link.children && (
                    <ul class="dropdown">
                      {link.children.map((child) => (
                        <li>
                          <a href={child.href} class:list={[{ active: currentPath === child.href }]}>
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )
    }

    <main class={mainClass}>
      <slot />
    </main>

    {
      !hideFooter && (
        <footer class="site-footer">
          <p>TAOM - Tales From the Age of Men &middot; A total conversion mod for Bannerlord II</p>
        </footer>
      )
    }
  </body>
</html>

<script is:inline>
  (() => {
    const breakpoint = 1100;

    const closeSiteNav = (nav) => {
      const toggle = nav.querySelector('[data-site-nav-toggle]');
      const menu = nav.querySelector('[data-site-nav-menu]');
      if (!toggle || !menu) return;

      toggle.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-menu-open');
      menu.hidden = window.innerWidth <= breakpoint;
    };

    const initSiteNav = () => {
      document.querySelectorAll('.site-nav').forEach((nav) => {
        if (nav.dataset.siteNavReady === 'true') return;
        nav.dataset.siteNavReady = 'true';

        const toggle = nav.querySelector('[data-site-nav-toggle]');
        const menu = nav.querySelector('[data-site-nav-menu]');
        if (!toggle || !menu) return;

        if (window.innerWidth <= breakpoint) {
          menu.hidden = true;
        }

        toggle.addEventListener('click', () => {
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!isOpen));
          nav.classList.toggle('is-menu-open', !isOpen);
          menu.hidden = isOpen;
        });

        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => closeSiteNav(nav));
        });

        document.addEventListener('click', (event) => {
          if (!nav.contains(event.target)) {
            closeSiteNav(nav);
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > breakpoint) {
            menu.hidden = false;
            toggle.setAttribute('aria-expanded', 'false');
            nav.classList.remove('is-menu-open');
          } else if (!nav.classList.contains('is-menu-open')) {
            menu.hidden = true;
          }
        });
      });
    };

    if (!window.__taomSiteNavInitBound) {
      window.__taomSiteNavInitBound = true;
      document.addEventListener('astro:page-load', initSiteNav);
    }

    initSiteNav();
  })();
</script>

<style is:global>
  @import '../styles/global.css';
</style>
