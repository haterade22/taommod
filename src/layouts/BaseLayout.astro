---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TAOM - Tales From the Age of Men - A total conversion mod for Bannerlord II' } = Astro.props;

type NavLink = { href: string; label: string; children?: { href: string; label: string }[] };

const navLinks: NavLink[] = [
  { href: '/', label: 'Home' },
  { href: '/kingdoms', label: 'Kingdoms' },
  { href: '/factions', label: 'Factions', children: [
    { href: '/factions', label: 'Overview' },
    { href: '/factions/gondor', label: 'Gondor' },
    { href: '/factions/mordor', label: 'Mordor' },
    { href: '/factions/erebor', label: 'Erebor' },
    { href: '/factions/isengard', label: 'Isengard' },
    { href: '/factions/gundabad', label: 'Gundabad' },
    { href: '/factions/vlandia', label: 'Rohan' },
    { href: '/factions/empire', label: 'Dunland' },
    { href: '/factions/aserai', label: 'Harad' },
    { href: '/factions/khuzait', label: 'Rhun' },
    { href: '/factions/battania', label: 'Khand' },
    { href: '/factions/dolguldur', label: 'Dol Guldur' },
    { href: '/factions/mirkwood', label: 'Mirkwood' },
    { href: '/factions/rivendell', label: 'Rivendell' },
    { href: '/factions/umbar', label: 'Umbar' },
    { href: '/factions/lothlorien', label: 'Lothlorien' },
    { href: '/factions/sturgia', label: 'Dale' },
  ]},
  { href: '/database', label: 'Database', children: [
    { href: '/database', label: 'Overview' },
    { href: '/troops', label: 'Troops' },
    { href: '/lords', label: 'Lords' },
    { href: '/armoury', label: 'Armoury' },
    { href: '/weaponry', label: 'Weaponry' },
  ]},
  { href: '/mod-info', label: 'Mod Info', children: [
    { href: '/mod-info', label: 'Overview' },
    { href: '/mod-info/races', label: 'Races & Creatures' },
    { href: '/mod-info/recruitment', label: 'Recruitment System' },
    { href: '/mod-info/troop-balancing', label: 'Troop Balancing' },
    { href: '/mod-info/armour-balancing', label: 'Armour Balancing' },
    { href: '/mod-info/weapon-balancing', label: 'Weapon Balancing' },
    { href: '/mod-info/features', label: 'Coding Features' },
  ]},
  { href: '/community', label: 'Community' },
  { href: '/download', label: 'Download' },
  { href: '/troubleshooting', label: 'Troubleshooting' },
  { href: '/credits', label: 'Credits' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | TAOM</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="site-nav">
      <a class="logo" href="/"><img src="/images/logo.png" alt="TAOM" class="nav-logo" /></a>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li class:list={[{ 'has-dropdown': !!link.children }]}>
            <a
              href={link.href}
              class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) || (link.children && link.children.some(c => currentPath === c.href || currentPath.startsWith(c.href + '/'))) }]}
            >
              {link.label}
              {link.children && <span class="dropdown-arrow">&#9662;</span>}
            </a>
            {link.children && (
              <ul class="dropdown">
                {link.children.map(child => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[{ active: currentPath === child.href }]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>TAOM - Tales From the Age of Men &middot; A total conversion mod for Bannerlord II</p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
