---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Tales From the Age of Men - A Lord of the Rings total conversion mod for Mount & Blade II: Bannerlord' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/troops', label: 'Troops' },
  { href: '/factions', label: 'Factions' },
  { href: '/kingdoms', label: 'Kingdoms' },
  { href: '/download', label: 'Download' },
  { href: '/community', label: 'Community' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | TAOM</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="site-nav">
      <a class="logo" href="/"><img src="/images/logo.png" alt="TAOM" class="nav-logo" /></a>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>TAOM - Tales From the Age of Men &middot; A Lord of the Rings total conversion mod for Bannerlord</p>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
